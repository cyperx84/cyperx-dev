---
import '../styles/global.css';

interface Props {
  title: string;
  activeNav?: string;
}

const { title, activeNav = "" } = Astro.props;
---

<html class="dark" lang="en">
<head>
  <meta charset="utf-8" />
  <meta content="width=device-width, initial-scale=1.0" name="viewport" />
  <title>{title}</title>
  <!-- Google Fonts -->
  <link href="https://fonts.googleapis.com" rel="preconnect" />
  <link crossorigin href="https://fonts.gstatic.com" rel="preconnect" />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&family=Rubik+Glitch&family=Space+Mono:ital,wght@0,400;0,700;1,400;1,700&family=VT323&display=swap" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
</head>
<body class="bg-background-light dark:bg-background-dark font-display text-slate-100 dark:text-slate-100 min-h-[200vh] flex overflow-x-hidden transition-colors duration-300">

  <!-- Ghost Terminals (Chaos Layer) -->
  <div class="ghost-window top-[10%] left-[60%] w-64 h-40" style="--duration: 40s;">
    &gt; exec hallucinate.sh<br />
    [DEBUG] Latent space overflow<br />
    [WARN] Reality buffer low...<br />
    0x00FF82: SIGKILL received<br />
    &gt; _
  </div>
  <div class="ghost-window bottom-[15%] left-[5%] w-72 h-32" style="--duration: 35s;">
    for(let i=0; i&lt;INF; i++) {'{'}<br />
    &nbsp;&nbsp;glitch.render(Math.random());<br />
    &nbsp;&nbsp;system.shred();<br />
    {'}'}<br />
    // FIXME: stop reality leaking
  </div>

  <!-- Emoji Animation Layer -->
  <div class="fixed inset-0 pointer-events-none overflow-hidden z-0">
    <div class="floating-emoji text-6xl" style="top: 10%; left: 5%; --duration: 38s;">💀</div>
    <div class="floating-emoji text-5xl" style="top: 70%; left: 15%; --duration: 12s;">🍄</div>
    <div class="floating-emoji text-7xl" style="top: 40%; left: 80%; --duration: 45s;">🏂</div>
    <div class="floating-emoji text-4xl" style="top: 20%; left: 60%; --duration: 15s;">🦞</div>
    <div class="floating-emoji text-5xl" style="top: 85%; left: 45%; --duration: 10s;">🛹</div>
    <div class="floating-emoji text-6xl" style="top: 50%; left: 30%; --duration: 32s;">🤙</div>
    <div class="floating-emoji text-4xl" style="top: 5%; left: 90%; --duration: 42s;">🍄</div>
    <div class="floating-emoji text-6xl" style="top: 60%; left: 70%; --duration: 18s;">💀</div>
    <div class="floating-emoji text-6xl" style="top: 30%; left: 85%; --duration: 25s;">👽</div>
    <div class="floating-emoji text-5xl" style="top: 15%; left: 25%; --duration: 28s;">🦞</div>
    <div class="floating-emoji text-7xl" style="top: 75%; left: 85%; --duration: 33s;">🤙</div>
  </div>

  <!-- Glitch Tile Background -->
  <div class="ascii-bg">
    01001101 01000001 01001110 01001001 01000110 01000101 01010011 01010100 01001111 %#@!&amp; SYSTEM FAILURE %#@!&amp; KICKFLIP THE MAINFRAME 01010011 01011001 01010011 01010100 01000101 01001101 ERROR ERROR ERROR %#@!&amp; 🍄🛹💀 AI_HALLUCINATION %#@!&amp; 🦞🤙💀
  </div>

  <!-- SideNavBar -->
  <div class="w-[250px] sticky top-0 h-screen flex-shrink-0 border-r-4 border-primary/40 bg-[#050505] z-30 shadow-[4px_0_15px_rgba(6,249,249,0.1)]">
    <div class="flex h-full flex-col justify-between p-4 bg-[#111111]/80 backdrop-blur-sm">
      <div class="flex flex-col gap-6 mt-4">
        <div class="flex gap-3 items-center">
          <div class="bg-center bg-no-repeat aspect-square bg-cover rounded-none border-2 border-primary size-12" style='background-image: url("https://lh3.googleusercontent.com/aida-public/AB6AXuBEU3Kv5k_jC3kl1ujtbmnQmwNSyTORLrqZdzLXzzYl4PqWo-K9JVrKdn8HCPLSqo8C6waHpDi84qXpc9zB-ZgOioKfr0p9Aemd1pnK3E19PvyFFaSUVa80NBW8zLny8_lkxL0eoWR5hQe4okxxyKbDxXNppJCeulc4dEdYI2oFgMXUmuoKwV_aE8wGrzi1nFqNiZdoK_hrCg6sZSAPEXRQ8_Gx9cCkEE9-6lchNlNh3GfD_XTd1e6jwJz8AAZNJxYWvsi1RirHWTRz");'></div>
          <div class="flex flex-col">
            <h1 class="text-white text-lg font-bold leading-normal glitch-text uppercase tracking-widest">SYSTEM_SYS</h1>
            <p class="text-primary text-xs font-mono leading-normal">V. 9.0.1</p>
          </div>
        </div>

        <div class="flex flex-col gap-2 mt-8">
          <a class:list={[
            "flex items-center gap-3 px-3 py-3 cursor-pointer transition-colors border border-transparent group",
            activeNav === "home" ? "bg-primary/20 border-2 !border-primary relative overflow-hidden" : "hover:bg-[#FF003C]/20 hover:border-[#FF003C]"
          ]} href="/">
            {activeNav === "home" && <div class="absolute inset-0 bg-primary/10 glitch-bg"></div>}
            <div class:list={["transition-colors relative z-10", activeNav === "home" ? "text-primary" : "text-primary group-hover:text-[#FF003C]"]}>
              <span class="material-symbols-outlined">terminal</span>
            </div>
            <p class:list={["text-sm font-bold tracking-wider relative z-10", activeNav === "home" ? "text-primary glitch-text" : "text-white group-hover:text-[#FF003C] group-hover:glitch-text transition-all"]}>[&gt; HOME]</p>
          </a>

          <a class:list={[
            "flex items-center gap-3 px-3 py-3 cursor-pointer transition-colors border border-transparent group",
            activeNav === "manifesto" ? "bg-primary/20 border-2 !border-primary relative overflow-hidden" : "hover:bg-[#FF003C]/20 hover:border-[#FF003C]"
          ]} href="/manifesto">
            {activeNav === "manifesto" && <div class="absolute inset-0 bg-primary/10 glitch-bg"></div>}
            <div class:list={["transition-colors relative z-10", activeNav === "manifesto" ? "text-primary" : "text-primary group-hover:text-[#FF003C]"]}>
              <span class="material-symbols-outlined" style={activeNav === "manifesto" ? "font-variation-settings: 'FILL' 1;" : ""}>code</span>
            </div>
            <p class:list={["text-sm font-bold tracking-wider relative z-10", activeNav === "manifesto" ? "text-primary glitch-text" : "text-white group-hover:text-[#FF003C] group-hover:glitch-text transition-all"]}>[&gt; MANIFESTO]</p>
          </a>

          <a class:list={[
            "flex items-center gap-3 px-3 py-3 cursor-pointer transition-colors border border-transparent group",
            activeNav === "fragments" ? "bg-primary/20 border-2 !border-primary relative overflow-hidden" : "hover:bg-[#FF003C]/20 hover:border-[#FF003C]"
          ]} href="/fragments">
            {activeNav === "fragments" && <div class="absolute inset-0 bg-primary/10 glitch-bg"></div>}
            <div class:list={["transition-colors relative z-10", activeNav === "fragments" ? "text-primary" : "text-primary group-hover:text-[#FF003C]"]}>
              <span class="material-symbols-outlined">hive</span>
            </div>
            <p class:list={["text-sm font-bold tracking-wider relative z-10", activeNav === "fragments" ? "text-primary glitch-text" : "text-white group-hover:text-[#FF003C] group-hover:glitch-text transition-all"]}>[&gt; FRAGMENTS]</p>
          </a>

          <a class:list={[
            "flex items-center gap-3 px-3 py-3 cursor-pointer transition-colors border border-transparent mt-12 group",
            activeNav === "fatal_error" ? "bg-[#FF003C]/20 border-2 !border-[#FF003C]" : "hover:bg-[#FF003C]/20 hover:border-[#FF003C]"
          ]} href="/404">
            <div class="text-[#FF003C]">
              <span class="material-symbols-outlined">warning</span>
            </div>
            <p class="text-[#FF003C] text-sm font-bold tracking-wider glitch-text group-hover:scale-105 transition-transform">[&gt; FATAL_ERROR]</p>
          </a>
        </div>
      </div>

      <button id="toggle-mode" class="mt-auto p-3 border-2 border-primary/40 text-primary hover:border-primary transition-all font-bold text-xs uppercase tracking-tighter cursor-pointer">
        [ TOGGLE_MODE ]
      </button>
    </div>
  </div>

  <!-- Main Content -->
  <main class="flex-1 flex flex-col items-center gap-24 p-4 md:p-8 relative z-10">
    <slot />
  </main>

  <script>
    // Dark mode toggle
    document.getElementById('toggle-mode')?.addEventListener('click', () => {
      document.documentElement.classList.toggle('dark');
      document.documentElement.classList.toggle('light');
    });

    // Intersection Observer for scroll-triggered "hallucinations"
    const observerOptions = {
      threshold: 0.15,
      rootMargin: "0px 0px -50px 0px"
    };

    const revealObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('active');
          entry.target.classList.add('hallucinate-entry');
          setTimeout(() => {
            entry.target.classList.remove('hallucinate-entry');
          }, 800);
        }
      });
    }, observerOptions);

    document.querySelectorAll('.reveal-element').forEach(el => {
      revealObserver.observe(el);
    });

    // Simple scroll parallax for background characters
    window.addEventListener('scroll', () => {
      const scrolled = window.pageYOffset;
      const asciiBg = document.querySelector('.ascii-bg');
      if (asciiBg) {
        (asciiBg as HTMLElement).style.transform = `translateY(${scrolled * 0.25}px)`;
      }

      // Morph floating elements slightly on scroll
      document.querySelectorAll('.floating-emoji').forEach(emoji => {
        const el = emoji as HTMLElement;
        const speed = parseInt(el.style.getPropertyValue('--duration')) || 20;
        el.style.filter = `blur(${1 + (scrolled/500)}px) hue-rotate(${scrolled/10}deg)`;
      });
    });
  </script>
</body>
</html>
