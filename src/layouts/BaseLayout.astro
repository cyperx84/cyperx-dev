---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title?: string;
  activeNav?: 'home' | 'blog' | 'projects';
}
const { title = 'CYPERX.DEV', activeNav } = Astro.props;
const pageAttr = activeNav ?? 'home';
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <!-- Apply theme BEFORE first paint to prevent flash -->
  <script is:inline>
    (function(){
      var t = localStorage.getItem('cyperx-theme') || 'extreme';
      document.documentElement.className = 'theme-' + t;
    })();
    // Preserve theme class during Astro View Transitions swap
    document.addEventListener('astro:before-swap', function(e) {
      var t = localStorage.getItem('cyperx-theme') || 'extreme';
      e.newDocument.documentElement.className = 'theme-' + t;
    });
  </script>
  <meta name="description" content="CyperX — builder, breaker, automator. AI agent infrastructure, distributed fleets, and tools that compound over time." />
  <meta name="theme-color" content="#131313" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preload" href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;700;900&display=swap" as="style" />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;700;900&display=swap" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet" media="print" onload="this.media='all'" />
  <noscript><link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet" /></noscript>
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" media="print" onload="this.media='all'" />
  <noscript><link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" /></noscript>
  <ClientRouter />
  <style is:global>
    /* ── Page Transition: Glitch Wipe ── */
    @keyframes page-glitch-out {
      0%   { opacity: 1; transform: translate(0) skew(0); filter: none; }
      15%  { opacity: 1; transform: translate(-3px, 2px) skew(-2deg); filter: hue-rotate(90deg); }
      30%  { opacity: 0.8; transform: translate(5px, -1px) skew(3deg); filter: hue-rotate(180deg) saturate(2); }
      50%  { opacity: 0.5; transform: translate(-2px, 3px) skew(-1deg); filter: hue-rotate(270deg) blur(1px); }
      70%  { opacity: 0.3; transform: translate(0) skew(0); filter: blur(4px); }
      100% { opacity: 0; transform: translate(0) scale(0.98); filter: blur(8px); }
    }
    @keyframes page-glitch-in {
      0%   { opacity: 0; transform: scale(1.02); filter: blur(8px) hue-rotate(180deg); }
      20%  { opacity: 0.3; transform: translate(4px, -2px) skew(2deg); filter: blur(3px) hue-rotate(90deg); }
      40%  { opacity: 0.6; transform: translate(-3px, 1px) skew(-1deg); filter: blur(1px) hue-rotate(45deg); }
      60%  { opacity: 0.8; transform: translate(2px, -1px) skew(0.5deg); filter: hue-rotate(20deg); }
      80%  { opacity: 0.95; transform: translate(-1px, 0); filter: none; }
      100% { opacity: 1; transform: translate(0) skew(0); filter: none; }
    }

    /* Light theme: glitch slice — horizontal bands split apart */
    @keyframes page-slice-out {
      0%   { opacity: 1; transform: translateX(0); filter: none; clip-path: inset(0); }
      15%  { opacity: 1; transform: translateX(8px); filter: hue-rotate(30deg); clip-path: inset(0 0 60% 0); }
      30%  { opacity: 0.9; transform: translateX(-12px); filter: hue-rotate(90deg) saturate(1.5); clip-path: inset(20% 0 30% 0); }
      50%  { opacity: 0.6; transform: translateX(5px) skewX(-2deg); filter: hue-rotate(60deg) blur(1px); }
      75%  { opacity: 0.3; transform: translateX(-3px); filter: blur(3px) brightness(1.5); }
      100% { opacity: 0; transform: translateX(0); filter: blur(6px) brightness(2); }
    }
    @keyframes page-slice-in {
      0%   { opacity: 0; transform: translateX(-15px) skewX(3deg); filter: blur(6px) brightness(2) hue-rotate(90deg); }
      20%  { opacity: 0.3; transform: translateX(10px) skewX(-2deg); filter: blur(3px) brightness(1.5) hue-rotate(60deg); }
      40%  { opacity: 0.6; transform: translateX(-6px) skewX(1deg); filter: blur(1px) hue-rotate(30deg); }
      60%  { opacity: 0.8; transform: translateX(3px); filter: hue-rotate(15deg); }
      80%  { opacity: 0.95; transform: translateX(-1px); filter: none; }
      100% { opacity: 1; transform: translateX(0) skewX(0); filter: none; }
    }

    /* Extreme: chaos transition */
    @keyframes page-chaos-out {
      0%   { opacity: 1; transform: scale(1) rotate(0); filter: none; }
      20%  { opacity: 1; transform: scale(1.01) rotate(0.5deg); filter: hue-rotate(60deg) saturate(3); }
      50%  { opacity: 0.6; transform: scale(0.95) rotate(-1deg) skew(3deg); filter: hue-rotate(180deg) contrast(2); }
      80%  { opacity: 0.2; transform: scale(0.9) rotate(0.5deg); filter: blur(6px) hue-rotate(300deg); }
      100% { opacity: 0; transform: scale(0.85); filter: blur(12px); }
    }
    @keyframes page-chaos-in {
      0%   { opacity: 0; transform: scale(1.15) rotate(-1deg); filter: blur(12px) hue-rotate(300deg); }
      20%  { opacity: 0.3; transform: scale(1.08) rotate(0.5deg) skew(-2deg); filter: blur(4px) hue-rotate(180deg) contrast(2); }
      50%  { opacity: 0.7; transform: scale(1.02) rotate(-0.3deg); filter: hue-rotate(60deg) saturate(2); }
      80%  { opacity: 0.95; transform: scale(1.005) rotate(0.1deg); filter: hue-rotate(20deg); }
      100% { opacity: 1; transform: scale(1) rotate(0); filter: none; }
    }

    /* Default: dark theme glitch */
    ::view-transition-old(root) {
      animation: page-glitch-out 0.3s ease-in forwards;
    }
    ::view-transition-new(root) {
      animation: page-glitch-in 0.35s ease-out forwards;
      animation-delay: 0.05s;
    }

    /* Light theme: glitch slice */
    .theme-light::view-transition-old(root) {
      animation: page-slice-out 0.35s ease-in forwards;
    }
    .theme-light::view-transition-new(root) {
      animation: page-slice-in 0.4s ease-out forwards;
      animation-delay: 0.05s;
    }

    /* Extreme theme: chaos */
    .theme-extreme::view-transition-old(root) {
      animation: page-chaos-out 0.4s ease-in forwards;
    }
    .theme-extreme::view-transition-new(root) {
      animation: page-chaos-in 0.45s ease-out forwards;
      animation-delay: 0.05s;
    }
  </style>
</head>
<body class="overflow-x-hidden" data-page={pageAttr}>

  <!-- ── Scroll Progress Bar ── -->
  <div id="scroll-progress" class="fixed top-0 left-0 h-[3px] w-0 z-[190] pointer-events-none" style="transition:width 0.05s linear" transition:persist></div>

  <!-- ── Cursor Canvas (z-[200], above everything) ── -->
  <canvas id="cursor-canvas" class="fixed inset-0 z-[200] pointer-events-none" transition:persist></canvas>

  <!-- ── Three.js Background Canvas ── -->
  <canvas id="three-bg" class="fixed inset-0 pointer-events-none" style="z-index:-20" transition:persist></canvas>

  <!-- ── CRT / Scanline Overlay (theme-aware) ── -->
  <div id="crt-layer" class="fixed inset-0 z-[100] pointer-events-none crt-theme-overlay" transition:persist></div>

  <!-- ── Background Ambient Effects (theme-aware) ── -->
  <div class="bg-ambient-effects fixed inset-0 pointer-events-none -z-10">
    <!-- Dark: subtle fractal blooms -->
    <div class="bg-fx-dark">
      <div class="absolute top-1/4 -left-20 w-96 h-96 fractal-bloom opacity-30"></div>
      <div class="absolute bottom-1/4 -right-20 w-96 h-96 opacity-20" style="background:radial-gradient(circle at 50% 50%,rgba(255,81,250,0.1) 0%,transparent 70%);filter:blur(40px)"></div>
    </div>
    <!-- Extreme: fractal bg + vortex -->
    <div class="bg-fx-extreme">
      <div class="fractal-bg"></div>
      <div class="black-hole-vortex"></div>
    </div>
    <!-- Extreme: noise overlay -->
    <div class="bg-fx-extreme-noise noise-overlay"></div>
  </div>

  <!-- ── Unified Header / Nav ── -->
  <header class="site-header fixed top-0 w-full flex justify-between items-center px-4 sm:px-8 py-4 sm:py-6 backdrop-blur-xl z-50">
    <a href="/" class="logo-text text-2xl sm:text-3xl font-black text-[#39FF14] font-['Space_Grotesk'] uppercase tracking-tighter italic no-underline" aria-label="CYPERX.DEV home">
      CYPERX<span class="logo-dot">.</span>DEV
    </a>
    <nav class="hidden md:flex gap-8 lg:gap-10 font-['Space_Grotesk'] uppercase tracking-tighter italic">
      <a class={`nav-link hover:text-[#FF51FA] transition-all duration-150 ${activeNav === 'home' ? 'active' : ''}`} href="/">HOME</a>
      <a class={`nav-link hover:text-[#FF51FA] transition-all duration-150 ${activeNav === 'blog' ? 'active' : ''}`} href="/blog">BLOG</a>
      <a class={`nav-link hover:text-[#FF51FA] transition-all duration-150 ${activeNav === 'projects' ? 'active' : ''}`} href="/projects">PROJECTS</a>
    </nav>
    <div class="flex items-center gap-3">
      <button
        id="theme-toggle"
        class="theme-toggle-btn bg-[#39FF14] text-black px-4 sm:px-6 py-2 font-black italic text-xs sm:text-sm transition-all relative overflow-hidden"
        style="clip-path: polygon(10% 0,100% 0,90% 100%,0 100%)"
        aria-label="Cycle theme"
        onclick="(function(){var T=['extreme','dark','light'];var c=localStorage.getItem('cyperx-theme')||'extreme';var n=T[(T.indexOf(c)+1)%T.length];document.documentElement.className='theme-'+n;localStorage.setItem('cyperx-theme',n);})()"
      >
        <span class="toggle-icon inline-block mr-1">⚡</span><span class="toggle-label">TRIPP_MODE</span>
      </button>
      <!-- Mobile hamburger -->
      <button id="mobile-menu-btn" class="md:hidden flex flex-col gap-1.5 p-2" aria-label="Menu" transition:persist>
        <span class="hamburger-line w-6 h-0.5 bg-[#39FF14] transition-all duration-300"></span>
        <span class="hamburger-line w-6 h-0.5 bg-[#39FF14] transition-all duration-300"></span>
        <span class="hamburger-line w-6 h-0.5 bg-[#39FF14] transition-all duration-300"></span>
      </button>
    </div>
  </header>

  <!-- ── Page Content ── -->
  <slot />

  <!-- ── Unified Footer ── -->
  <footer class="site-footer w-full py-10 sm:py-12 px-6 sm:px-10 flex flex-col md:flex-row justify-between items-end gap-4">
    <div class="flex flex-col gap-2">
      <a href="/" class="footer-brand text-[#39FF14] font-bold text-xl font-['Space_Grotesk'] uppercase tracking-tighter italic no-underline">CYPERX.DEV</a>
      <p class="footer-tagline font-mono text-[10px] uppercase tracking-widest">SYSTEM ENTROPY: 99.9% | STABLE BEYOND VOID</p>
    </div>
    <div class="flex gap-6 sm:gap-8 font-mono text-[10px] uppercase tracking-widest">
      {['TERMINAL','REACH_OUT','LEGAL_VOID'].map(l => (
        <a class="footer-link transition-all" href="#">{l}</a>
      ))}
    </div>
    <div class="footer-copy font-mono text-[10px]"><span class="footer-rights" data-typewriter="60">© NO_RIGHTS_RESERVED</span></div>
  </footer>

  <!-- ── Mobile Slide-Down Menu ── -->
  <div id="mobile-menu" class="mobile-menu md:hidden fixed top-0 left-0 right-0 z-[55] transition-transform duration-300 ease-out" style="transform:translateY(-100%)" transition:persist>
    <div class="mobile-menu-inner pt-20 pb-8 px-6 flex flex-col gap-1 shadow-2xl">
      {[
        ['home','HOME','/'],
        ['terminal','BLOG','/blog'],
        ['shield','PROJECTS','/projects']
      ].map(([icon, label, href]) => (
        <a href={href} class={`mobile-menu-link flex items-center gap-4 py-4 px-4 font-['Space_Grotesk'] uppercase tracking-tighter italic text-xl font-black transition-all duration-200 ${activeNav === label.toLowerCase() ? 'active' : ''}`}>
          <span class="material-symbols-outlined text-2xl">{icon}</span>
          <span>{label}</span>
        </a>
      ))}
    </div>
  </div>

  <!-- ── Three.js Background (lazy loaded — not render critical) ── -->
  <script>
    if (!(window as any).__threeBgInit) {
      (window as any).__threeBgInit = true;
      // Defer Three.js load until after first paint
      if ('requestIdleCallback' in window) {
        (window as any).requestIdleCallback(() => {
          import('../scripts/three-bg').then(m => m.initThreeBg());
        });
      } else {
        setTimeout(() => {
          import('../scripts/three-bg').then(m => m.initThreeBg());
        }, 100);
      }
    }
  </script>

  <!-- ── Cursor + Sparkle Effects (deferred) ── -->
  <script>
    import { initCursor } from '../scripts/cursor';
    if (!(window as any).__cursorInit) {
      (window as any).__cursorInit = true;
      document.addEventListener('DOMContentLoaded', () => { initCursor(); });
    }
  </script>

  <!-- ── Theme Toggle + Mobile Menu + Animations Script ── -->
  <script is:inline>
    const THEMES = ['extreme', 'dark', 'light'];
    const THEME_LABELS = {
      extreme: 'TRIPP_MODE',
      dark: 'VOID_MODE',
      light: 'CLEAN_MODE',
    };
    const THEME_ICONS = {
      extreme: '⚡',
      dark: '💀',
      light: '☀️',
    };

    function applyTheme(theme) {
      var html = document.documentElement;
      html.className = 'theme-' + theme;
      localStorage.setItem('cyperx-theme', theme);
      try { updateToggleLabel(theme); } catch(e) {}
      try { updateScrollProgress(); } catch(e) {}
    }

    function updateToggleLabel(theme) {
      const label = document.querySelector('.toggle-label');
      const icon = document.querySelector('.toggle-icon');
      if (label) label.textContent = THEME_LABELS[theme] || 'TRIPP_MODE';
      if (icon) icon.textContent = THEME_ICONS[theme] || '⚡';
    }

    // Init on load
    const saved = localStorage.getItem('cyperx-theme') || 'extreme';
    applyTheme(saved);

    // Theme toggle handler is inline on the button element (HMR-safe)

    // Mobile menu toggle — re-bind safe for view transitions
    function initMobileMenu() {
      var menuBtn = document.getElementById('mobile-menu-btn');
      var menu = document.getElementById('mobile-menu');
      if (!menuBtn || !menu) return;
      // Reset state
      menu.style.transform = 'translateY(-100%)';
      menuBtn.classList.remove('menu-open');
      var open = false;
      menuBtn.onclick = function() {
        open = !open;
        menu.style.transform = open ? 'translateY(0)' : 'translateY(-100%)';
        menuBtn.classList.toggle('menu-open', open);
      };
      menu.querySelectorAll('a').forEach(function(a) {
        a.onclick = function() {
          open = false;
          menu.style.transform = 'translateY(-100%)';
          menuBtn.classList.remove('menu-open');
        };
      });
    }
    initMobileMenu();

    // ── Scroll Progress Bar ──
    function updateScrollProgress() {
      const bar = document.getElementById('scroll-progress');
      if (!bar) return;
      const scrolled = window.scrollY;
      const total = document.documentElement.scrollHeight - window.innerHeight;
      const pct = total > 0 ? (scrolled / total) * 100 : 0;
      bar.style.width = pct + '%';

      const theme = localStorage.getItem('cyperx-theme') || 'extreme';
      if (theme === 'dark') {
        bar.style.background = 'linear-gradient(to right, #39FF14, #FF51FA)';
      } else if (theme === 'light') {
        bar.style.background = 'linear-gradient(to right, #FF51FA, #AC89FF)';
      } else {
        // extreme: animated rainbow — use inline keyframe via CSS var
        bar.style.background = `linear-gradient(to right, hsl(${(Date.now()/30)%360},100%,60%), hsl(${((Date.now()/30)+120)%360},100%,60%), hsl(${((Date.now()/30)+240)%360},100%,60%))`;
      }
    }

    window.addEventListener('scroll', updateScrollProgress, { passive: true });

    // Animate rainbow on extreme
    function animateRainbow() {
      const theme = localStorage.getItem('cyperx-theme') || 'extreme';
      if (theme === 'extreme') updateScrollProgress();
      requestAnimationFrame(animateRainbow);
    }
    animateRainbow();

    // ── Typewriter effect ──
    function initTypewriters() {
      document.querySelectorAll('[data-typewriter]').forEach(el => {
        if (el.dataset.twDone) return;
        el.dataset.twDone = '1';
        const text = el.textContent;
        el.textContent = '';
        el.style.visibility = 'visible';
        let i = 0;
        const speed = parseInt(el.dataset.typewriter) || 50;

        function type() {
          if (i < text.length) {
            el.textContent += text.charAt(i);
            i++;
            setTimeout(type, speed);
          }
        }

        const obs = new IntersectionObserver(entries => {
          if (entries[0].isIntersecting) { type(); obs.disconnect(); }
        }, { threshold: 0.3 });
        obs.observe(el);
      });
    }

    // ── Staggered Scroll Reveal ──
    function initScrollReveal() {
      const isExtreme = document.documentElement.classList.contains('theme-extreme');

      // Only target data-reveal elements inside the VISIBLE variant
      const allReveals = document.querySelectorAll('[data-reveal]');
      
      allReveals.forEach((el, idx) => {
        if (el.dataset.revealDone) return;
        
        // Skip elements inside hidden variants (display:none parents)
        const parent = el.closest('.variant-dark, .variant-light, .variant-extreme');
        if (parent && getComputedStyle(parent).display === 'none') return;

        const variant = el.dataset.reveal || 'slide-up';

        // Set initial hidden state via inline styles
        el.style.opacity = '0';

        if (variant === 'slide-left') {
          el.style.transform = 'translateX(-40px)';
        } else if (variant === 'slide-right') {
          el.style.transform = 'translateX(40px)';
        } else if (variant === 'scale') {
          el.style.transform = 'scale(0.85)';
        } else {
          el.style.transform = 'translateY(40px)';
        }

        // Stagger delay based on sibling index
        const siblings = el.parentElement ? Array.from(el.parentElement.querySelectorAll('[data-reveal]')) : [];
        const siblingIdx = siblings.indexOf(el);
        const delay = siblingIdx >= 0 ? siblingIdx * 80 : idx * 60;

        function reveal() {
          if (el.dataset.revealDone) return;
          el.dataset.revealDone = '1';
          requestAnimationFrame(() => {
            el.style.transition = `opacity 0.7s cubic-bezier(0.16,1,0.3,1) ${delay}ms, transform 0.7s cubic-bezier(0.16,1,0.3,1) ${delay}ms`;
            el.style.opacity = '1';
            el.style.transform = 'none';
            if (isExtreme) {
              el.classList.add('reveal-glitch');
              setTimeout(() => el.classList.remove('reveal-glitch'), 300);
            }
          });
        }

        // Check if already in viewport
        const rect = el.getBoundingClientRect();
        if (rect.top < window.innerHeight && rect.bottom > 0) {
          // Already visible — reveal with a small delay for stagger effect
          setTimeout(reveal, 50 + delay);
        } else {
          // Not yet visible — use IntersectionObserver
          const obs = new IntersectionObserver(entries => {
            if (entries[0].isIntersecting) {
              reveal();
              obs.disconnect();
            }
          }, { threshold: 0.05 });
          obs.observe(el);
        }
      });
    }

    // ── Hero Parallax ──
    function initParallax() {
      const heroes = document.querySelectorAll('.parallax-hero, .shard-hero');
      if (!heroes.length) return;
      window.addEventListener('scroll', () => {
        if (document.hidden) return;
        const scrollY = window.scrollY;
        heroes.forEach(el => {
          el.style.transform = `translateY(${scrollY * 0.1}px)`;
        });
      }, { passive: true });
    }

    // ── Footer typewriter re-trigger on scroll into view ──
    function initFooterTypewriter() {
      const el = document.querySelector('.footer-rights');
      if (!el || el.dataset.twDone) return;
      const originalText = '© NO_RIGHTS_RESERVED';

      function runTypewriter() {
        el.dataset.twDone = '1';
        el.style.visibility = 'visible';
        el.textContent = '';
        let i = 0;
        function type() {
          if (i < originalText.length) {
            el.textContent += originalText[i];
            i++;
            setTimeout(type, 55);
          }
        }
        type();
      }

      const obs = new IntersectionObserver(entries => {
        if (entries[0].isIntersecting) {
          runTypewriter();
          obs.disconnect();
        }
      }, { threshold: 0.5 });
      obs.observe(el);
    }

    // Init — works for both initial load and Astro client-side navigations
    function initAll() {
      initTypewriters();
      initScrollReveal();
      initParallax();
      initFooterTypewriter();
      initMobileMenu();
      // Re-apply theme from localStorage (in case of client nav)
      var t = localStorage.getItem('cyperx-theme') || 'extreme';
      document.documentElement.className = 'theme-' + t;
    }

    document.addEventListener('DOMContentLoaded', initAll);
    document.addEventListener('astro:page-load', initAll);
  </script>
</body>
</html>
