---
import '../styles/global.css';

interface Props {
  title?: string;
  activeNav?: 'home' | 'blog' | 'projects';
}
const { title = 'CYPERX.DEV', activeNav } = Astro.props;
---
<!doctype html>
<html lang="en" class="theme-dark">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />

</head>
<body class="overflow-x-hidden">
  <slot />

  <!-- ── Theme Toggle (fixed, always visible) ── -->
  <div id="theme-toggle-wrap" class="fixed bottom-6 right-6 z-[500] flex flex-col items-end gap-2">
    <div id="theme-label" class="font-mono text-[10px] uppercase tracking-widest text-[#39FF14] bg-black/80 px-2 py-1">THEME: DARK</div>
    <button
      id="theme-toggle"
      class="bg-[#39FF14] text-black px-5 py-2 font-black uppercase tracking-widest text-xs hover:bg-[#FF51FA] hover:text-white transition-all"
      style="clip-path: polygon(10% 0, 100% 0, 90% 100%, 0 100%);"
      aria-label="Cycle theme"
    >
      SHIFT_REALITY
    </button>
  </div>

  <script is:inline>
    const THEMES = ['dark', 'light', 'extreme'];
    const LABELS = { dark: 'THEME: DARK', light: 'THEME: LIGHT', extreme: 'THEME: EXTREME' };

    function applyTheme(theme) {
      const html = document.documentElement;
      THEMES.forEach(t => html.classList.remove('theme-' + t));
      html.classList.add('theme-' + theme);
      localStorage.setItem('cyperx-theme', theme);
      const lbl = document.getElementById('theme-label');
      if (lbl) lbl.textContent = LABELS[theme];
    }

    // Init on load
    const saved = localStorage.getItem('cyperx-theme') || 'dark';
    applyTheme(saved);

    // Cycle on click
    document.getElementById('theme-toggle').addEventListener('click', () => {
      const current = localStorage.getItem('cyperx-theme') || 'dark';
      const next = THEMES[(THEMES.indexOf(current) + 1) % THEMES.length];
      applyTheme(next);
    });
  </script>
</body>
</html>
