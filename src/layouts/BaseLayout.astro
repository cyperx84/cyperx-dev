---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title?: string;
  activeNav?: 'home' | 'blog' | 'projects' | 'about' | 'datablock' | 'fragments' | 'manifesto' | '';
  description?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  ogType?: string;
}
const {
  title = 'CYPERX.DEV',
  activeNav,
  description,
  ogTitle,
  ogDescription,
  ogImage,
  ogType,
} = Astro.props;

const defaultDescription = 'CyperX — builder, breaker, automator. AI agent infrastructure, distributed fleets, and tools that compound over time.';
const defaultOgImage = 'https://cyperx.dev/og-image.png';

const resolvedDescription = description ?? defaultDescription;
const resolvedOgTitle = ogTitle ?? title;
const resolvedOgDescription = ogDescription ?? defaultDescription;
const resolvedOgImage = ogImage ?? defaultOgImage;
const resolvedOgType = ogType ?? 'website';
const pageAttr = activeNav ?? 'home';
---
<!doctype html>
<html lang="en">
<head>
  <!-- importmap: three.js loaded from CDN, not bundled (498KB → 10KB in our bundle) -->
  <script type="importmap">
    {"imports":{"three":"https://esm.sh/three@0.183.2","three/":"https://esm.sh/three@0.183.2/"}}
  </script>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <!-- Apply theme BEFORE first paint to prevent flash -->
  <script is:inline>
    (function(){
      var t = localStorage.getItem('cyperx-theme') || 'extreme';
      document.documentElement.className = 'theme-' + t;
    })();
    // Preserve theme class during Astro View Transitions swap
    document.addEventListener('astro:before-swap', function(e) {
      var t = localStorage.getItem('cyperx-theme') || 'extreme';
      e.newDocument.documentElement.className = 'theme-' + t;
    });
  </script>
  <meta name="description" content={resolvedDescription} />
  <meta name="theme-color" content="#131313" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <link rel="canonical" href={Astro.url.href} />
  <!-- Open Graph -->
  <meta property="og:type" content={resolvedOgType} />
  <meta property="og:title" content={resolvedOgTitle} />
  <meta property="og:description" content={resolvedOgDescription} />
  <meta property="og:url" content={Astro.url.href} />
  <meta property="og:site_name" content="CyperX.dev" />
  <meta property="og:image" content={resolvedOgImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:site" content="@cyperx" />
  <meta name="twitter:title" content={resolvedOgTitle} />
  <meta name="twitter:description" content={resolvedOgDescription} />
  <meta name="twitter:image" content={resolvedOgImage} />
  <slot name="head" />
  <!-- Space Grotesk — self-hosted, preloaded (eliminates Google Fonts RTT, no CLS) -->
  <link rel="preload" href="/fonts/space-grotesk-v22-latin-regular.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/space-grotesk-v22-latin-700.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/Lazer84.woff2" as="font" type="font/woff2" crossorigin />
  <!-- ZedMono/Monaspace not preloaded — accent/terminal fonts, font-display:swap handles them without blocking FCP -->
  <!-- JetBrains Mono — deferred (mono/code only, non-critical) -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet" media="print" onload="this.media='all'" />
  <noscript><link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet" /></noscript>

  <!-- Material Symbols — deferred, only 10 icons used -->
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0&icon_names=arrow_forward,construction,format_quote,hub,leak_add,open_in_new,person,radar,shield,terminal&display=swap" rel="stylesheet" media="print" onload="this.media='all'" />
  <noscript><link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0&icon_names=arrow_forward,construction,format_quote,hub,leak_add,open_in_new,person,radar,shield,terminal&display=swap" rel="stylesheet" /></noscript>
  <ClientRouter />
  <style is:global>
    /* ── Page Transition: Glitch Wipe ── */
    @keyframes page-glitch-out {
      0%   { opacity: 1; transform: translate(0) skew(0); filter: none; }
      15%  { opacity: 1; transform: translate(-3px, 2px) skew(-2deg); filter: hue-rotate(90deg); }
      30%  { opacity: 0.8; transform: translate(5px, -1px) skew(3deg); filter: hue-rotate(180deg) saturate(2); }
      50%  { opacity: 0.5; transform: translate(-2px, 3px) skew(-1deg); filter: hue-rotate(270deg) blur(1px); }
      70%  { opacity: 0.3; transform: translate(0) skew(0); filter: blur(4px); }
      100% { opacity: 0; transform: translate(0) scale(0.98); filter: blur(8px); }
    }
    @keyframes page-glitch-in {
      0%   { opacity: 0; transform: scale(1.02); filter: blur(8px) hue-rotate(180deg); }
      20%  { opacity: 0.3; transform: translate(4px, -2px) skew(2deg); filter: blur(3px) hue-rotate(90deg); }
      40%  { opacity: 0.6; transform: translate(-3px, 1px) skew(-1deg); filter: blur(1px) hue-rotate(45deg); }
      60%  { opacity: 0.8; transform: translate(2px, -1px) skew(0.5deg); filter: hue-rotate(20deg); }
      80%  { opacity: 0.95; transform: translate(-1px, 0); filter: none; }
      100% { opacity: 1; transform: translate(0) skew(0); filter: none; }
    }

    /* Light theme: glitch slice — horizontal bands split apart */
    @keyframes page-slice-out {
      0%   { opacity: 1; transform: translateX(0); filter: none; clip-path: inset(0); }
      15%  { opacity: 1; transform: translateX(8px); filter: hue-rotate(30deg); clip-path: inset(0 0 60% 0); }
      30%  { opacity: 0.9; transform: translateX(-12px); filter: hue-rotate(90deg) saturate(1.5); clip-path: inset(20% 0 30% 0); }
      50%  { opacity: 0.6; transform: translateX(5px) skewX(-2deg); filter: hue-rotate(60deg) blur(1px); }
      75%  { opacity: 0.3; transform: translateX(-3px); filter: blur(3px) brightness(1.5); }
      100% { opacity: 0; transform: translateX(0); filter: blur(6px) brightness(2); }
    }
    @keyframes page-slice-in {
      0%   { opacity: 0; transform: translateX(-15px) skewX(3deg); filter: blur(6px) brightness(2) hue-rotate(90deg); }
      20%  { opacity: 0.3; transform: translateX(10px) skewX(-2deg); filter: blur(3px) brightness(1.5) hue-rotate(60deg); }
      40%  { opacity: 0.6; transform: translateX(-6px) skewX(1deg); filter: blur(1px) hue-rotate(30deg); }
      60%  { opacity: 0.8; transform: translateX(3px); filter: hue-rotate(15deg); }
      80%  { opacity: 0.95; transform: translateX(-1px); filter: none; }
      100% { opacity: 1; transform: translateX(0) skewX(0); filter: none; }
    }

    /* Extreme: chaos transition */
    @keyframes page-chaos-out {
      0%   { opacity: 1; transform: scale(1) rotate(0); filter: none; }
      20%  { opacity: 1; transform: scale(1.01) rotate(0.5deg); filter: hue-rotate(60deg) saturate(3); }
      50%  { opacity: 0.6; transform: scale(0.95) rotate(-1deg) skew(3deg); filter: hue-rotate(180deg) contrast(2); }
      80%  { opacity: 0.2; transform: scale(0.9) rotate(0.5deg); filter: blur(6px) hue-rotate(300deg); }
      100% { opacity: 0; transform: scale(0.85); filter: blur(12px); }
    }
    @keyframes page-chaos-in {
      0%   { opacity: 0; transform: scale(1.15) rotate(-1deg); filter: blur(12px) hue-rotate(300deg); }
      20%  { opacity: 0.3; transform: scale(1.08) rotate(0.5deg) skew(-2deg); filter: blur(4px) hue-rotate(180deg) contrast(2); }
      50%  { opacity: 0.7; transform: scale(1.02) rotate(-0.3deg); filter: hue-rotate(60deg) saturate(2); }
      80%  { opacity: 0.95; transform: scale(1.005) rotate(0.1deg); filter: hue-rotate(20deg); }
      100% { opacity: 1; transform: scale(1) rotate(0); filter: none; }
    }

    /* Default: dark theme glitch */
    ::view-transition-old(root) {
      animation: page-glitch-out 0.3s ease-in forwards;
    }
    ::view-transition-new(root) {
      animation: page-glitch-in 0.35s ease-out forwards;
      animation-delay: 0.05s;
    }

    /* Light theme: glitch slice */
    .theme-light::view-transition-old(root) {
      animation: page-slice-out 0.35s ease-in forwards;
    }
    .theme-light::view-transition-new(root) {
      animation: page-slice-in 0.4s ease-out forwards;
      animation-delay: 0.05s;
    }

    /* Extreme theme: chaos */
    .theme-extreme::view-transition-old(root) {
      animation: page-chaos-out 0.4s ease-in forwards;
    }
    .theme-extreme::view-transition-new(root) {
      animation: page-chaos-in 0.45s ease-out forwards;
      animation-delay: 0.05s;
    }
  </style>
</head>
<body class="overflow-x-hidden" data-page={pageAttr}>

  <!-- ── Scroll Progress Bar ── -->
  <div id="scroll-progress" class="fixed top-0 left-0 h-[3px] w-0 z-[190] pointer-events-none" style="transition:width 0.05s linear" transition:persist></div>

  <!-- ── Cursor Canvas (z-[200], above everything) ── -->
  <canvas id="cursor-canvas" class="fixed inset-0 z-[200] pointer-events-none" transition:persist></canvas>

  <!-- ── Three.js Background Canvas ── -->
  <canvas id="three-bg" class="fixed inset-0 pointer-events-none" style="z-index:-20" transition:persist></canvas>

  <!-- ── CRT / Scanline Overlay (theme-aware) ── -->
  <div id="crt-layer" class="fixed inset-0 z-[100] pointer-events-none crt-theme-overlay" transition:persist></div>

  <!-- ── Background Ambient Effects (theme-aware) ── -->
  <div class="bg-ambient-effects fixed inset-0 pointer-events-none -z-10">
    <!-- Dark: subtle fractal blooms -->
    <div class="bg-fx-dark">
      <div class="absolute top-1/4 -left-20 w-96 h-96 fractal-bloom opacity-30"></div>
      <div class="absolute bottom-1/4 -right-20 w-96 h-96 opacity-20" style="background:radial-gradient(circle at 50% 50%,rgba(255,81,250,0.1) 0%,transparent 70%);filter:blur(40px)"></div>
    </div>
    <!-- Extreme: fractal bg + vortex -->
    <div class="bg-fx-extreme">
      <div class="fractal-bg"></div>
      <div class="black-hole-vortex"></div>
    </div>
    <!-- Extreme: noise overlay -->
    <div class="bg-fx-extreme-noise noise-overlay"></div>
  </div>

  <!-- ── Unified Header / Nav ── -->
  <header class="site-header fixed top-0 w-full flex justify-between items-center px-4 sm:px-8 py-4 sm:py-6 backdrop-blur-xl z-50">
    <a href="/" class="logo-text text-2xl sm:text-3xl font-black text-[#39FF14] font-['Space_Grotesk'] uppercase tracking-tighter italic no-underline" aria-label="CYPERX.DEV home">
      CYPERX<span class="logo-dot">.</span>DEV
    </a>
    <nav class="hidden md:flex gap-8 lg:gap-10 font-['Space_Grotesk'] uppercase tracking-tighter italic">
      <a class={`nav-link hover:text-[#FF51FA] transition-all duration-150 ${activeNav === 'blog' ? 'active' : ''}`} href="/blog">BLOG</a>
      <a class={`nav-link hover:text-[#FF51FA] transition-all duration-150 ${activeNav === 'projects' ? 'active' : ''}`} href="/projects">PROJECTS</a>
      <a class={`nav-link hover:text-[#FF51FA] transition-all duration-150 ${activeNav === 'about' ? 'active' : ''}`} href="/about">ABOUT</a>
    </nav>
    <div class="flex items-center gap-3">
      <button
        id="theme-toggle"
        class="theme-toggle-btn relative w-12 h-12 sm:w-14 sm:h-14 flex items-center justify-center rounded-xl transition-all duration-300 overflow-hidden group"
        aria-label="Cycle theme"
        onclick="(function(){var T=['extreme','dark','light'];var c=localStorage.getItem('cyperx-theme')||'extreme';var n=T[(T.indexOf(c)+1)%T.length];document.documentElement.className='theme-'+n;localStorage.setItem('cyperx-theme',n);})()"
      >
        <span class="theme-toggle-glow absolute inset-0 rounded-lg"></span>
        <span class="toggle-icon relative z-10 text-lg sm:text-xl leading-none theme-toggle-icon">💀</span>
      </button>
      <!-- Mobile hamburger -->
      <!-- Reset bullet holes -->
      <button
        id="reset-bullets-btn"
        class="relative w-10 h-10 sm:w-11 sm:h-11 flex items-center justify-center rounded-lg transition-all duration-300 opacity-0 pointer-events-none"
        aria-label="Reset bullet holes"
        title="Repair bullet holes"
        onclick="if(window.__clearBulletHoles){window.__clearBulletHoles();this.style.opacity='0';this.style.pointerEvents='none';}"
      >
        <span class="relative z-10 text-lg sm:text-xl leading-none">🔧</span>
      </button>
      <button id="mobile-menu-btn" class="md:hidden flex flex-col gap-1.5 p-2" aria-label="Menu">
        <span class="hamburger-line w-6 h-0.5 bg-[#39FF14] transition-all duration-300"></span>
        <span class="hamburger-line w-6 h-0.5 bg-[#39FF14] transition-all duration-300"></span>
        <span class="hamburger-line w-6 h-0.5 bg-[#39FF14] transition-all duration-300"></span>
      </button>
    </div>
  </header>

  <!-- ── Page Content (GSAP transition wrapper) ── -->
  <div id="page-content">
    <slot />

  <!-- ── Unified Footer ── -->
  <footer class="site-footer w-full py-10 sm:py-12 px-6 sm:px-10 flex flex-col md:flex-row justify-between items-end gap-4 relative z-10 bg-black/90 backdrop-blur-md">
    <div class="flex flex-col gap-2">
      <a href="/" class="footer-brand text-[#39FF14] font-bold text-xl font-['Space_Grotesk'] uppercase tracking-tighter italic no-underline">CYPERX.DEV</a>
      <p class="footer-tagline font-mono text-[10px] uppercase tracking-widest">BUILDING THINGS THAT COMPOUND</p>
    </div>
    <div class="flex gap-6 sm:gap-8 font-mono text-[10px] uppercase tracking-widest">
      <a class="footer-link transition-all" href="/about">ABOUT</a>
      <a class="footer-link transition-all" href="https://github.com/cyperx84" target="_blank" rel="noopener">GITHUB</a>
      <a class="footer-link transition-all" href="https://x.com/cyperx" target="_blank" rel="noopener">X</a>
    </div>
    <div class="footer-copy font-mono text-[10px]"><span class="footer-rights" data-typewriter="60">© 2026 CyperX</span></div>
  </footer>
  </div><!-- /#page-content -->

  <!-- ── Mobile Slide-Down Menu ── -->
  <div id="mobile-menu" class="mobile-menu md:hidden fixed top-0 left-0 right-0 z-[55] transition-transform duration-300 ease-out" style="transform:translateY(-100%)">
    <div class="mobile-menu-inner pt-16 pb-8 px-6 flex flex-col gap-1 shadow-2xl">
      <!-- Close button -->
      <button id="mobile-menu-close" class="absolute top-5 right-5 w-10 h-10 flex items-center justify-center text-2xl font-black opacity-60 hover:opacity-100 transition-opacity" aria-label="Close menu">✕</button>
      {[
        ['terminal','BLOG','/blog'],
        ['shield','PROJECTS','/projects'],
        ['person','ABOUT','/about']
      ].map(([icon, label, href]) => (
        <a href={href} class={`mobile-menu-link flex items-center gap-4 py-4 px-4 font-['Space_Grotesk'] uppercase tracking-tighter italic text-xl font-black transition-all duration-200 ${activeNav === label.toLowerCase() ? 'active' : ''}`}>
          <span class="material-symbols-outlined text-2xl">{icon}</span>
          <span>{label}</span>
        </a>
      ))}
    </div>
  </div>

  <!-- ── Lenis Smooth Scroll + Three.js Background ── -->
  <script>
    let lenis: any = null;
    let threeBgModule: any = null;

    async function initLenis() {
      // Destroy previous instance on page transitions
      if (lenis) { lenis.destroy(); lenis = null; }

      // Dynamic import — doesn't block FCP
      const { default: Lenis } = await import('lenis');

      lenis = new Lenis({
        lerp: 0.08,
        smoothWheel: true,
        overscroll: false,
      });

      // Feed scroll velocity into Three.js scene (lazy — waits for three-bg to load via idle callback)
      lenis.on('scroll', (e: any) => {
        if (!threeBgModule) {
          // Check if three-bg was loaded by the idle callback; cache ref if so
          threeBgModule = (window as any).__threeBgModule || null;
        }
        if (threeBgModule) {
          const maxScroll = document.documentElement.scrollHeight - window.innerHeight;
          const progress = maxScroll > 0 ? window.scrollY / maxScroll : 0;
          threeBgModule.setScrollData(e.velocity, progress);
        }
      });

      // Connect Lenis to GSAP ScrollTrigger — only after scroll-animations is loaded
      const connectWhenReady = () => {
        if ((window as any).__scrollAnimationsModule) {
          (window as any).__scrollAnimationsModule.connectLenis(lenis);
        } else {
          setTimeout(connectWhenReady, 200);
        }
      };
      setTimeout(connectWhenReady, 300);
    }

    // Init on first load
    if (!(window as any).__lenisInit) {
      (window as any).__lenisInit = true;
      initLenis();
    }
    // Re-init on Astro page transitions
    document.addEventListener('astro:page-load', () => {
      initLenis();
    });

    // Expose for cleanup
    (window as any).__lenisInstance = () => lenis;
  </script>

  <!-- ── Three.js Background (lazy loaded — not render critical) ── -->
  <script>
    if (!(window as any).__threeBgInit) {
      (window as any).__threeBgInit = true;
      // Defer Three.js load well after FCP to avoid blocking main thread
      const loadThree = () => {
        import(/* @vite-ignore */ '../scripts/three-bg').then(m => {
          (window as any).__threeBgModule = m;
          m.initThreeBg();
        });
      };
      if ('requestIdleCallback' in window) {
        // Wait for idle after a short delay to let FCP + LCP complete
        (window as any).requestIdleCallback(loadThree, { timeout: 3000 });
      } else {
        setTimeout(loadThree, 3000);
      }
    }
  </script>

  <!-- ── Cursor + Bullet Holes (idle — decorative, non-critical) ── -->
  <script>
    const runCursor = () => import('../scripts/cursor').then(m => m.initCursor?.() ?? m.default?.());
    const runBulletHoles = () => import('../scripts/bullet-holes').then(m => m.initBulletHoles?.() ?? m.default?.());

    if (!(window as any).__cursorInit || !(window as any).__bulletsInit) {
      (window as any).__cursorInit = true;
      (window as any).__bulletsInit = true;
      // Purely decorative — defer both to a single idle callback so they don't compete with LCP/FCP
      if ('requestIdleCallback' in window) {
        requestIdleCallback(() => { runCursor(); runBulletHoles(); }, { timeout: 2000 });
      } else {
        setTimeout(() => { runCursor(); runBulletHoles(); }, 500);
      }
    }
    // Re-init on every Astro page transition (already past initial paint by then)
    document.addEventListener('astro:page-load', runBulletHoles);
    (window as any).__clearBulletHoles = () => import('../scripts/bullet-holes').then(m => m.clearBulletHoles());
  </script>

  <!-- ── Theme Toggle + Mobile Menu + Animations Script ── -->
  <script is:inline>
    const THEMES = ['extreme', 'dark', 'light'];
    const THEME_ICONS = {
      extreme: '💀',
      dark: '💀',
      light: '💀',
    };

    function applyTheme(theme) {
      var html = document.documentElement;
      html.className = 'theme-' + theme;
      localStorage.setItem('cyperx-theme', theme);
      try { updateToggleIcon(theme); } catch(e) {}
      try { updateScrollProgress(); } catch(e) {}
    }

    function updateToggleIcon(theme) {
      const icon = document.querySelector('.toggle-icon');
      if (icon) icon.textContent = THEME_ICONS[theme] || '⚡';
    }

    // Init on load
    const saved = localStorage.getItem('cyperx-theme') || 'extreme';
    applyTheme(saved);

    // Theme toggle handler is inline on the button element (HMR-safe)

    // Mobile menu toggle — re-bind safe for view transitions
    function initMobileMenu() {
      var menuBtn = document.getElementById('mobile-menu-btn');
      var menu = document.getElementById('mobile-menu');
      var closeBtn = document.getElementById('mobile-menu-close');
      if (!menuBtn || !menu) return;
      // Reset state
      menu.style.transform = 'translateY(-100%)';
      menuBtn.classList.remove('menu-open');
      var open = false;
      function closeMenu() {
        open = false;
        menu.style.transform = 'translateY(-100%)';
        menuBtn.classList.remove('menu-open');
      }
      function toggleMenu() {
        open = !open;
        menu.style.transform = open ? 'translateY(0)' : 'translateY(-100%)';
        menuBtn.classList.toggle('menu-open', open);
      }
      menuBtn.onclick = toggleMenu;
      if (closeBtn) closeBtn.onclick = closeMenu;
      menu.querySelectorAll('a').forEach(function(a) {
        a.onclick = closeMenu;
      });
    }
    initMobileMenu();

    // ── Scroll Progress Bar ──
    function updateScrollProgress() {
      const bar = document.getElementById('scroll-progress');
      if (!bar) return;
      const scrolled = window.scrollY;
      const total = document.documentElement.scrollHeight - window.innerHeight;
      const pct = total > 0 ? (scrolled / total) * 100 : 0;
      bar.style.width = pct + '%';

      // Theme colors set via CSS classes, no per-frame JS needed
      const theme = localStorage.getItem('cyperx-theme') || 'extreme';
      if (theme === 'dark') {
        bar.style.background = 'linear-gradient(to right, #39FF14, #FF51FA)';
      } else if (theme === 'light') {
        bar.style.background = 'linear-gradient(to right, #FF51FA, #AC89FF)';
      } else {
        // Extreme: use CSS @property animation (no JS rAF loop needed)
        bar.style.background = '';
        bar.classList.add('scroll-rainbow');
      }
    }

    window.addEventListener('scroll', updateScrollProgress, { passive: true });

    // ── Typewriter effect ──
    function initTypewriters() {
      document.querySelectorAll('[data-typewriter]').forEach(el => {
        if (el.dataset.twDone) return;
        el.dataset.twDone = '1';
        const text = el.textContent;
        // Reserve height before clearing to prevent CLS
        const rect = el.getBoundingClientRect();
        if (rect.height > 0) el.style.minHeight = rect.height + 'px';
        el.textContent = '';
        el.style.visibility = 'visible';
        let i = 0;
        const speed = parseInt(el.dataset.typewriter) || 50;

        function type() {
          if (i < text.length) {
            el.textContent += text.charAt(i);
            i++;
            setTimeout(type, speed);
          }
        }

        const obs = new IntersectionObserver(entries => {
          if (entries[0].isIntersecting) { type(); obs.disconnect(); }
        }, { threshold: 0.3 });
        obs.observe(el);
      });
    }

    // ── Scroll Reveal + Parallax (powered by GSAP ScrollTrigger) ──
    // Handled by scroll-animations.ts — connected to Lenis above

    // ── Footer typewriter re-trigger on scroll into view ──
    function initFooterTypewriter() {
      const el = document.querySelector('.footer-rights');
      if (!el || el.dataset.twDone) return;
      const originalText = '© 2026 CyperX';

      function runTypewriter() {
        el.dataset.twDone = '1';
        el.style.visibility = 'visible';
        el.textContent = '';
        let i = 0;
        function type() {
          if (i < originalText.length) {
            el.textContent += originalText[i];
            i++;
            setTimeout(type, 55);
          }
        }
        type();
      }

      const obs = new IntersectionObserver(entries => {
        if (entries[0].isIntersecting) {
          runTypewriter();
          obs.disconnect();
        }
      }, { threshold: 0.5 });
      obs.observe(el);
    }

    // Init — works for both initial load and Astro client-side navigations
    function initAll() {
      initTypewriters();
      // GSAP ScrollTrigger handles reveals + parallax (loaded from bundled script below)
      if (window.__initScrollAnimations) window.__initScrollAnimations();
      initFooterTypewriter();
      initMobileMenu();
      // Re-apply theme from localStorage (in case of client nav)
      var t = localStorage.getItem('cyperx-theme') || 'extreme';
      document.documentElement.className = 'theme-' + t;
    }

    document.addEventListener('DOMContentLoaded', initAll);
    document.addEventListener('astro:page-load', initAll);
  </script>

  <!-- GSAP scroll animations — deferred past LCP via idle callback -->
  <script>
    const loadScrollAnimations = () => {
      import('../scripts/scroll-animations').then(m => {
        (window as any).__scrollAnimationsModule = m;
        (window as any).__initScrollAnimations = m.initScrollAnimations;
        m.initScrollAnimations();
      });
    };
    if ('requestIdleCallback' in window) {
      requestIdleCallback(loadScrollAnimations, { timeout: 2500 });
    } else {
      setTimeout(loadScrollAnimations, 500);
    }
    document.addEventListener('astro:page-load', () => {
      if ((window as any).__initScrollAnimations) (window as any).__initScrollAnimations();
    });
  </script>

  <!-- GSAP page transitions — deferred, not critical for LCP -->
  <script>
    const loadPageTransitions = () => {
      import('../scripts/page-transitions').then(m => {
        if (!(window as any).__pageTransitionsInit) {
          (window as any).__pageTransitionsInit = true;
          m.initPageTransitions();
        }
      });
    };
    if ('requestIdleCallback' in window) {
      requestIdleCallback(loadPageTransitions, { timeout: 3000 });
    } else {
      setTimeout(loadPageTransitions, 800);
    }
  </script>
</body>
</html>
