---
import '../styles/global.css';

interface Props {
  title?: string;
  activeNav?: 'home' | 'blog' | 'projects';
}
const { title = 'CYPERX.DEV', activeNav } = Astro.props;
---
<!doctype html>
<html lang="en" class="theme-light">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
</head>
<body class="overflow-x-hidden">

  <!-- ── CRT / Scanline Overlay (theme-aware) ── -->
  <div id="crt-layer" class="fixed inset-0 z-[100] pointer-events-none crt-theme-overlay"></div>

  <!-- ── Background Ambient Effects (theme-aware) ── -->
  <div class="bg-ambient-effects fixed inset-0 pointer-events-none -z-10">
    <!-- Dark: subtle fractal blooms -->
    <div class="bg-fx-dark">
      <div class="absolute top-1/4 -left-20 w-96 h-96 fractal-bloom opacity-30"></div>
      <div class="absolute bottom-1/4 -right-20 w-96 h-96 opacity-20" style="background:radial-gradient(circle at 50% 50%,rgba(255,81,250,0.1) 0%,transparent 70%);filter:blur(40px)"></div>
    </div>
    <!-- Extreme: fractal bg + vortex -->
    <div class="bg-fx-extreme">
      <div class="fractal-bg"></div>
      <div class="black-hole-vortex"></div>
    </div>
    <!-- Extreme: noise overlay -->
    <div class="bg-fx-extreme-noise noise-overlay"></div>
  </div>

  <!-- ── Unified Header / Nav ── -->
  <header class="site-header fixed top-0 w-full flex justify-between items-center px-4 sm:px-8 py-4 sm:py-6 backdrop-blur-xl z-50">
    <a href="/" class="text-2xl sm:text-3xl font-black text-[#39FF14] [text-shadow:2px_0_#FF51FA,-2px_0_#AC89FF] animate-pulse font-['Space_Grotesk'] uppercase tracking-tighter italic no-underline">CYPERX.DEV</a>
    <nav class="hidden md:flex gap-8 lg:gap-10 font-['Space_Grotesk'] uppercase tracking-tighter italic">
      <a class={`nav-link hover:text-[#FF51FA] hover:skew-x-12 transition-all duration-75 ${activeNav === 'home' ? 'active' : ''}`} href="/">HOME</a>
      <a class={`nav-link hover:text-[#FF51FA] hover:skew-x-12 transition-all duration-75 ${activeNav === 'blog' ? 'active' : ''}`} href="/blog">BLOG</a>
      <a class={`nav-link hover:text-[#FF51FA] hover:skew-x-12 transition-all duration-75 ${activeNav === 'projects' ? 'active' : ''}`} href="/projects">PROJECTS</a>
    </nav>
    <div class="flex items-center gap-3">
      <button
        id="theme-toggle"
        class="bg-[#39FF14] text-black px-4 sm:px-6 py-2 font-black italic text-xs sm:text-sm hover:bg-[#FF51FA] hover:text-white transition-all"
        style="clip-path: polygon(10% 0,100% 0,90% 100%,0 100%)"
        aria-label="Cycle theme"
      >TRIPP_MODE</button>
      <!-- Mobile hamburger -->
      <button id="mobile-menu-btn" class="md:hidden flex flex-col gap-1.5 p-2" aria-label="Menu">
        <span class="hamburger-line w-6 h-0.5 bg-[#39FF14] transition-all duration-300"></span>
        <span class="hamburger-line w-6 h-0.5 bg-[#39FF14] transition-all duration-300"></span>
        <span class="hamburger-line w-6 h-0.5 bg-[#39FF14] transition-all duration-300"></span>
      </button>
    </div>
  </header>

  <!-- ── Page Content ── -->
  <slot />

  <!-- ── Unified Footer ── -->
  <footer class="site-footer w-full py-10 sm:py-12 px-6 sm:px-10 flex flex-col md:flex-row justify-between items-end gap-4">
    <div class="flex flex-col gap-2">
      <a href="/" class="text-[#39FF14] font-bold text-xl font-['Space_Grotesk'] uppercase tracking-tighter italic no-underline">CYPERX.DEV</a>
      <p class="footer-tagline font-mono text-[10px] uppercase tracking-widest">SYSTEM ENTROPY: 99.9% | STABLE BEYOND VOID</p>
    </div>
    <div class="flex gap-6 sm:gap-8 font-mono text-[10px] uppercase tracking-widest">
      {['TERMINAL','REACH_OUT','LEGAL_VOID'].map(l => (
        <a class="footer-link hover:line-through hover:blur-[1px] transition-all" href="#">{l}</a>
      ))}
    </div>
    <div class="footer-copy font-mono text-[10px]">© NO_RIGHTS_RESERVED</div>
  </footer>

  <!-- ── Mobile Slide-Down Menu ── -->
  <div id="mobile-menu" class="mobile-menu md:hidden fixed top-0 left-0 right-0 z-[55] transition-transform duration-300 ease-out" style="transform:translateY(-100%)">
    <div class="mobile-menu-inner pt-20 pb-8 px-6 flex flex-col gap-1 shadow-2xl">
      {[
        ['home','HOME','/'],
        ['terminal','BLOG','/blog'],
        ['shield','PROJECTS','/projects']
      ].map(([icon, label, href]) => (
        <a href={href} class={`mobile-menu-link flex items-center gap-4 py-4 px-4 font-['Space_Grotesk'] uppercase tracking-tighter italic text-xl font-black transition-all duration-200 ${activeNav === label.toLowerCase() ? 'active' : ''}`}>
          <span class="material-symbols-outlined text-2xl">{icon}</span>
          <span>{label}</span>
        </a>
      ))}
    </div>
  </div>

  <!-- ── Theme Toggle + Mobile Menu + Animations Script ── -->
  <script is:inline>
    const THEMES = ['extreme', 'dark', 'light'];

    function applyTheme(theme) {
      const html = document.documentElement;
      THEMES.forEach(t => html.classList.remove('theme-' + t));
      html.classList.add('theme-' + theme);
      localStorage.setItem('cyperx-theme', theme);
    }

    // Init on load
    const saved = localStorage.getItem('cyperx-theme') || 'extreme';
    applyTheme(saved);

    // Cycle on click (light → dark → extreme)
    document.getElementById('theme-toggle').addEventListener('click', () => {
      const current = localStorage.getItem('cyperx-theme') || 'extreme';
      const next = THEMES[(THEMES.indexOf(current) + 1) % THEMES.length];
      applyTheme(next);
    });

    // Mobile menu toggle
    const menuBtn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    let menuOpen = false;
    if (menuBtn && menu) {
      menuBtn.addEventListener('click', () => {
        menuOpen = !menuOpen;
        menu.style.transform = menuOpen ? 'translateY(0)' : 'translateY(-100%)';
        menuBtn.classList.toggle('menu-open', menuOpen);
      });
      // Close on link click
      menu.querySelectorAll('a').forEach(a => {
        a.addEventListener('click', () => {
          menuOpen = false;
          menu.style.transform = 'translateY(-100%)';
          menuBtn.classList.remove('menu-open');
        });
      });
    }

    // Typewriter effect for elements with data-typewriter
    function initTypewriters() {
      document.querySelectorAll('[data-typewriter]').forEach(el => {
        if (el.dataset.twDone) return;
        el.dataset.twDone = '1';
        const text = el.textContent;
        el.textContent = '';
        el.style.visibility = 'visible';
        let i = 0;
        const speed = parseInt(el.dataset.typewriter) || 50;
        function type() {
          if (i < text.length) {
            el.textContent += text.charAt(i);
            i++;
            setTimeout(type, speed);
          }
        }
        // Start when element is in viewport
        const obs = new IntersectionObserver(entries => {
          if (entries[0].isIntersecting) { type(); obs.disconnect(); }
        }, { threshold: 0.3 });
        obs.observe(el);
      });
    }

    // Scroll-triggered fade-in
    function initScrollReveal() {
      document.querySelectorAll('[data-reveal]').forEach(el => {
        el.style.opacity = '0';
        el.style.transform = 'translateY(30px)';
        el.style.transition = 'opacity 0.6s ease, transform 0.6s ease';
        const obs = new IntersectionObserver(entries => {
          if (entries[0].isIntersecting) {
            el.style.opacity = '1';
            el.style.transform = 'translateY(0)';
            obs.disconnect();
          }
        }, { threshold: 0.1 });
        obs.observe(el);
      });
    }

    // Init animations
    document.addEventListener('DOMContentLoaded', () => {
      initTypewriters();
      initScrollReveal();
    });
  </script>
</body>
</html>
