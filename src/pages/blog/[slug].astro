---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import fs from 'node:fs';
import path from 'node:path';

const allPosts = await getCollection('blog');
const posts = allPosts.sort((a, b) => {
  const dateA = a.data.date.replace(/\./g, '-');
  const dateB = b.data.date.replace(/\./g, '-');
  return new Date(dateB).getTime() - new Date(dateA).getTime();
});

export async function getStaticPaths() {
  const allPosts = await getCollection('blog');
  return allPosts.map((post) => ({
    params: { slug: post.data.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
// Check at build time whether an audio file exists for this post so we can
// skip rendering the player entirely (avoids 404 network noise on missing files).
const hasAudio = fs.existsSync(path.resolve(`public/audio/blog/${post.data.slug}.mp3`));
const currentIndex = posts.findIndex(p => p.data.slug === post.data.slug);
const prevPost = currentIndex > 0 ? posts[currentIndex - 1] : null;
const nextPost = currentIndex < posts.length - 1 ? posts[currentIndex + 1] : null;

const postOgImage = post.data.heroImage ?? 'https://cyperx.dev/og-image.png';

// Extract first inline image from the markdown body at build time so we can
// preload it with fetchpriority=high — it's almost always the LCP element on
// blog post pages.
let firstProseImage: string | undefined;
try {
  const rawBody = (post as any).body as string | undefined;
  if (rawBody) {
    const m = rawBody.match(/!\[[^\]]*\]\((\/[^)]+)\)/);
    if (m) firstProseImage = m[1];
  }
} catch {}
---
<BaseLayout
  title={`CYPERX.DEV // ${post.data.title.toUpperCase()}`}
  activeNav="blog"
  ogTitle={post.data.title}
  ogDescription={post.data.excerpt}
  ogImage={postOgImage}
  ogType="article"
  heroPreload={firstProseImage}
>

  <!-- Reading progress bar -->
  <div id="blog-progress" class="fixed top-0 left-0 h-[3px] z-[9999] transition-none" style="width:0%;"></div>

  <!-- Reading time indicator -->
  <div id="reading-indicator" class="fixed top-20 sm:top-28 right-3 sm:right-4 z-[100] font-mono text-[10px] px-2.5 py-1.5 opacity-0 transition-opacity duration-300" style="background:rgba(0,0,0,0.7); color:#39FF14;">
    0 min read
  </div>

  <!-- Floating Audio Player — rendered only when an mp3 actually exists -->
  {hasAudio && (
  <div id="audio-player" class="fixed bottom-0 left-0 right-0 z-40 backdrop-blur-md border-t px-3 py-2 sm:px-4 sm:py-2.5 hidden" data-theme="dark">
    <div class="max-w-4xl mx-auto flex items-center gap-2 sm:gap-3">
      <button id="play-btn" class="w-10 h-10 sm:w-9 sm:h-9 flex items-center justify-center border font-mono text-sm shrink-0 transition-colors rounded-sm" aria-label="Play audio">▶</button>
      <div class="flex-1 min-w-0">
        <div id="audio-title" class="font-mono text-[8px] truncate mb-1"></div>
        <div class="flex items-center gap-2">
          <span id="audio-time" class="font-mono text-[9px] shrink-0">0:00</span>
          <div class="flex-1 h-6 sm:h-1 flex items-center cursor-pointer" id="progress-bar">
            <div id="progress-fill" class="h-1 sm:h-full w-full rounded-full transition-none" style="width:0%"></div>
          </div>
          <span id="audio-duration" class="font-mono text-[9px] shrink-0">0:00</span>
        </div>
      </div>
      <button id="speed-btn" class="min-w-[40px] min-h-[40px] px-3 py-2 sm:min-w-0 sm:min-h-0 sm:px-2 sm:py-1 border font-mono text-[10px] sm:text-[8px] transition-colors shrink-0 rounded-sm" aria-label="Playback speed">1x</button>
    </div>
      <audio id="blog-audio" preload="metadata" src={`/audio/blog/${post.data.slug}.mp3`}></audio>
  </div>
  )}

  ════════════════════════════════════════ -->

  <!-- ════════════════════════════════════════
