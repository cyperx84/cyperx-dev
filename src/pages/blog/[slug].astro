<script>
  // ── Reading progress bar ──
  const progressBar = document.getElementById('blog-progress');
  const readingIndicator = document.getElementById('reading-indicator');

  function updateBlogProgress() {
    const scrollTop = window.scrollY;
    const docHeight = document.documentElement.scrollHeight - window.innerHeight;
    if (docHeight > 0 && progressBar) {
      const pct = scrollTop / docHeight;
      progressBar.style.width = (pct * 100) + '%';

      // Update reading time indicator
      if (readingIndicator) {
        const readTimeEl = document.querySelector('header .flex span:nth-child(3)');
        const readTimeText = readTimeEl?.textContent || '10 MIN';
        const totalMin = parseInt(readTimeText) || 10;
        const currentMin = Math.ceil(pct * totalMin);
        readingIndicator.textContent = currentMin + ' / ' + totalMin + ' min';
        readingIndicator.style.opacity = scrollTop > 100 ? '1' : '0';
      }
    }
  }
  window.addEventListener('scroll', updateBlogProgress, { passive: true });

  // ── Wrap blog prose images in jagged border + clip-path wrappers ──
  const JAG_CLIP = 'polygon(0% 15%, 5% 0%, 15% 12%, 25% 0%, 35% 8%, 45% 0%, 55% 10%, 65% 0%, 75% 6%, 85% 0%, 95% 5%, 100% 10%, 95% 25%, 100% 40%, 95% 55%, 100% 70%, 95% 85%, 100% 100%, 90% 92%, 80% 100%, 70% 95%, 60% 100%, 50% 93%, 40% 100%, 30% 96%, 20% 100%, 10% 94%, 0% 100%, 5% 80%, 0% 65%, 5% 50%, 0% 35%, 5% 20%)';
  const ACCENT_COLORS = ['#39FF14', '#FF51FA', '#AC89FF'];

  document.querySelectorAll('.blog-prose img:not(.jag-img)').forEach((img, idx) => {
    const imgEl = img as HTMLImageElement;
    const alt = imgEl.getAttribute('alt') || '';
    const parent = imgEl.parentElement;
    if (!parent || parent.classList.contains('jag-img-wrap')) return;

    const accent = ACCENT_COLORS[idx % ACCENT_COLORS.length];
    const delay = (idx * 0.3).toFixed(1);

    // Build jag wrapper
    const wrap = document.createElement('div');
    wrap.className = 'jag-img-wrap blog-jag-wrap';

    imgEl.className = (imgEl.className + ' jag-img').trim();
    (imgEl.style as any).clipPath = JAG_CLIP;

    // SVG animated border
    const svgNS = 'http://www.w3.org/2000/svg';
    const svg = document.createElementNS(svgNS, 'svg');
    svg.setAttribute('class', 'jag-border');
    svg.setAttribute('viewBox', '0 0 100 100');
    svg.setAttribute('preserveAspectRatio', 'none');
    svg.setAttribute('aria-hidden', 'true');

    const outer = document.createElementNS(svgNS, 'polygon');
    outer.setAttribute('points', '2,0 14,6 25,0 38,5 52,0 65,3 80,0 92,4 100,2 98,16 100,32 97,48 100,64 98,80 100,95 94,100 80,97 65,100 48,96 32,100 18,98 0,96 3,82 0,65 4,48 0,32 2,16');
    outer.setAttribute('class', 'jag-stroke-outer');
    outer.setAttribute('style', `stroke:${accent}`);

    const inner = document.createElementNS(svgNS, 'polygon');
    inner.setAttribute('points', '4,2 16,8 27,2 40,7 54,2 67,5 82,2 94,6 98,4 96,18 98,34 95,50 98,66 96,82 98,97 92,98 78,95 63,98 46,94 30,98 16,96 2,94 5,80 2,63 6,46 2,30 4,18');
    inner.setAttribute('class', 'jag-stroke-inner');
    inner.setAttribute('style', `stroke:${accent}; animation-delay:${delay}s`);

    svg.appendChild(outer);
    svg.appendChild(inner);

    // Fade-in wrapper (starts hidden, revealed by IntersectionObserver below)
    const figure = document.createElement('figure');
    figure.className = 'blog-jag-figure';

    const caption = document.createElement('figcaption');
    caption.textContent = alt;

    if (parent.tagName === 'P' && parent.children.length === 1) {
      parent.parentElement?.insertBefore(figure, parent);
      parent.parentElement?.removeChild(parent);
    } else {
      parent.insertBefore(figure, imgEl);
    }

    wrap.appendChild(imgEl);
    wrap.appendChild(svg);
    figure.appendChild(wrap);
    figure.appendChild(caption);
  });

  // ── Fade in jag images when loaded ──
  document.querySelectorAll('.blog-jag-wrap .jag-img').forEach(img => {
    const el = img as HTMLImageElement;
    if (el.complete && el.naturalWidth > 0) {
      el.classList.add('jag-loaded');
    } else {
      el.addEventListener('load', () => el.classList.add('jag-loaded'));
      el.addEventListener('error', () => el.classList.add('jag-loaded')); // show even on error
    }
  });

  // ── Blog editorial scroll reveal ──
  const blogProseContainers = document.querySelectorAll('.blog-prose');
  blogProseContainers.forEach(container => {
    container.classList.add('blog-prose-ready'); // only hide when JS is active
    const elements = container.querySelectorAll('p, h2, ul, li, blockquote, figure, hr');

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const el = entry.target as HTMLElement;
          if (el.tagName === 'H2') {
            el.classList.add('bp-glitch');
          } else {
            el.classList.add('bp-visible');
          }
          observer.unobserve(el);
        }
      });
    }, { threshold: 0.1 });

    elements.forEach(el => observer.observe(el));
  });
</script>
