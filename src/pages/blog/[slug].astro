---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={`DATABLOCK: ${post.data.title}`} activeNav="datablocks">
  <div class="pt-32 pb-32 relative z-10">

    <!-- Sticky Header Bar -->
    <div class="fixed top-0 left-0 w-full z-50 bg-background-dark/95 border-b-2 border-primary backdrop-blur-md p-4 flex justify-between items-center flicker-glitch lg:pl-[380px]">
      <div class="flex items-center gap-6">
        <a class="text-primary hover:text-accent-red font-code font-bold uppercase flex items-center gap-2 group transition-colors" href="/blog/">
          <span class="material-symbols-outlined group-hover:-translate-x-1 transition-transform">arrow_back</span>
          [<span class="chromatic-text" data-text="ABORT">ABORT</span>]
        </a>
      </div>
      <div class="font-code text-accent-red text-sm flicker-glitch">CRITICAL_OVERHEAT: 99%</div>
    </div>

    <article class="max-w-[800px] mx-auto">
      <!-- Post Header -->
      <header class="mb-16 relative">
        <div class="ghost-skull-bg">
      ______
   .-"      "-.
  /            \
 |              |
 |,  .-.  .-.  ,|
 | )(__/  \__)( |
 |/     /\     \|
 (_     ^^     _)
  \__|IIIIII|__/
   | \IIIIII/ |
   \          /
    `--------`
        </div>

        <h1 class="font-heading text-[50px] md:text-[80px] leading-[0.75] text-white uppercase glitch-shadow-intense break-words mb-8 relative z-10 melting-text">
          {post.data.title}
        </h1>

        <div class="flex flex-wrap gap-4 font-code text-sm">
          <span class="text-muted font-bold">&gt; TS: {post.data.date}</span>
          {post.data.tags.map((tag: string) => (
            <span class="corrupt-meta font-bold">[FRAG: {tag}]</span>
          ))}
        </div>
      </header>

      <!-- Post Content -->
      <div class="prose-cyperx space-y-8 text-white font-body text-[22px] leading-relaxed relative">
        <Content />
      </div>

      <!-- Footer -->
      <footer class="mt-32 border-t-2 border-primary/30 pt-12 flex flex-col items-center gap-8">
        <a class="inline-block border-2 border-primary text-primary font-code font-bold uppercase px-12 py-6 hover:bg-accent-red hover:text-white hover:border-accent-red transition-all relative group overflow-hidden" href="/blog/">
          <span class="absolute inset-0 bg-primary opacity-0 group-hover:opacity-20 mix-blend-screen transition-opacity"></span>
          <span class="relative z-10">[&gt; RUN_DIAGNOSTICS &lt;]</span>
        </a>
        <div class="text-[14px] font-code text-muted uppercase tracking-widest flicker-glitch">
          System Entropy: Increasing...
        </div>
      </footer>
    </article>
  </div>
</BaseLayout>

<style>
  /* Prose styles for blog content */
  .prose-cyperx :global(p) {
    margin-bottom: 1.5rem;
    opacity: 0.9;
  }

  .prose-cyperx :global(strong) {
    color: #FF003C;
    font-weight: 700;
  }

  .prose-cyperx :global(em) {
    color: #FF00FF;
    font-style: italic;
  }

  .prose-cyperx :global(code) {
    font-family: 'Space Mono', monospace;
    color: #FF003C;
    background: #0a0a0a;
    padding: 0.125rem 0.5rem;
    border: 1px solid rgba(255, 0, 60, 0.3);
    font-size: 16px;
  }

  .prose-cyperx :global(pre) {
    background: #0a0a0a;
    border: 2px solid transparent;
    background-clip: padding-box;
    padding: 2rem;
    overflow-x: auto;
    position: relative;
    margin: 2rem 0;
    box-shadow: 0 0 30px rgba(0, 255, 255, 0.1);
  }

  .prose-cyperx :global(pre code) {
    font-family: 'Space Mono', monospace;
    color: #39FF14;
    background: transparent;
    border: none;
    padding: 0;
    font-size: 14px;
    line-height: 1.6;
  }

  .prose-cyperx :global(blockquote) {
    position: relative;
    padding: 3rem 2rem;
    background: #000;
    clip-path: polygon(0% 15%, 15% 0%, 85% 5%, 100% 20%, 95% 80%, 80% 100%, 20% 95%, 0% 85%);
    box-shadow: 0 0 50px rgba(255, 0, 255, 0.4);
    border: 1px solid rgba(0, 255, 255, 0.3);
    margin: 3rem 0;
    font-family: 'Rubik Glitch', system-ui;
    font-size: 2rem;
    line-height: 0.9;
    text-align: center;
    text-shadow: 4px 0 #FF003C, -4px 0 #00FFFF, 0 3px #FF00FF;
  }

  .prose-cyperx :global(blockquote p) {
    margin: 0;
    opacity: 1;
  }

  .prose-cyperx :global(a) {
    color: #00FFFF;
    text-decoration: underline;
    text-decoration-color: #FF003C;
    text-underline-offset: 4px;
  }

  .prose-cyperx :global(h2), .prose-cyperx :global(h3) {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 900;
    text-transform: uppercase;
    color: #00FFFF;
    margin-top: 3rem;
    margin-bottom: 1rem;
    text-shadow: 2px 0 #FF003C, -2px 0 #00FFFF;
  }
</style>
