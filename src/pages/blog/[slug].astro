  /* ══════════════════════════════════════════
     IMAGE STYLES (inline markdown images)
  ══════════════════════════════════════════ */

  /* ── Paragraphs containing only an image: kill the inline strut ── */
  .blog-prose p:has(> img:only-child) {
    line-height: 0;
    font-size: 0;
    margin: 2.5rem 0;
  }

  /* ── Blog prose images: jagged clip-path directly on img ── */
  .blog-prose p:has(> img:only-child) > img {
    display: block;
    width: calc(100% - 32px);
    margin: 0 16px;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    clip-path: polygon(0% 15%, 5% 0%, 15% 12%, 25% 0%, 35% 8%, 45% 0%, 55% 10%, 65% 0%, 75% 6%, 85% 0%, 95% 5%, 100% 10%, 95% 25%, 100% 40%, 95% 55%, 100% 70%, 95% 85%, 100% 100%, 90% 92%, 80% 100%, 70% 95%, 60% 100%, 50% 93%, 40% 100%, 30% 96%, 20% 100%, 10% 94%, 0% 100%, 5% 80%, 0% 65%, 5% 50%, 0% 35%, 5% 20%);
    opacity: 0.85;
    transition: opacity 0.4s ease, transform 0.4s ease;
  }
  .blog-prose p:has(> img:only-child) > img:hover {
    opacity: 1;
    transform: scale(1.01);
  }
  .theme-extreme .blog-prose { cursor: crosshair; }
  .theme-extreme .blog-prose img { filter: saturate(1.2) contrast(1.1); opacity: 0.9; }
  .theme-dark .blog-prose img { filter: saturate(0.85) contrast(1.08); }

  /* LCP: let the browser skip offscreen prose rendering until scrolled */
  .blog-prose > * {
    content-visibility: auto;
    contain-intrinsic-size: auto 600px;
  }
  /* But never skip the first few blocks — they are above the fold and
     skipping them measurably hurts LCP. */
  .blog-prose > :nth-child(-n+4) {
    content-visibility: visible;
    contain-intrinsic-size: auto;
  }

  /* Legacy wrapper classes — kept for any cached pages */
  .blog-jag-outer { display: block; position: relative; }
  .blog-jag-wrap { display: block; }

  /* Caption */
  .blog-jag-figure {
    margin: 2.5rem 0;
  }
  .blog-jag-figure figcaption {
    font-family: 'ZedMono NFM', monospace;
    font-size: 0.7rem;
    margin-top: 0.75rem;
    opacity: 0.45;
    text-align: center;
  }

  /* ══════════════════════════════════════════
     BLOG SCROLL ANIMATIONS
  ══════════════════════════════════════════ */

  /* h2 glitch-flash on enter */
  @keyframes glitch-flash {
    0%   { opacity: 0; transform: scale(0.97) translate(-3px, 0); filter: hue-rotate(90deg); }
    50%  { opacity: 0.7; transform: scale(1.01) translate(3px, 0); filter: hue-rotate(-90deg); }
    100% { opacity: 1; transform: scale(1) translate(0, 0); filter: hue-rotate(0deg); }
  }
  .blog-prose h2.bp-glitch {
    animation: glitch-flash 0.15s ease-out forwards;
  }

  /* Pull-quote style for blockquotes */
  .blog-prose blockquote {
    position: relative;
    padding-left: 2.5rem;
    font-size: 1.15rem;
    font-style: italic;
  }
  .blog-prose blockquote::before {
    content: '\201C';
    position: absolute;
    left: 0;
    top: -0.25rem;
    font-size: 3rem;
    line-height: 1;
    font-weight: 900;
