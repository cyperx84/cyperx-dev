      <!-- Article Body -->
      <article class="prose-dark blog-prose mb-16 sm:mb-24 text-[#e2e2e2] max-w-none sm:max-w-none" style="max-width:72ch"><Content /></article>

      <!-- Bottom Navigation -->
      <nav class="border-t border-[#e2e2e2]/10 pt-8 sm:pt-12 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
