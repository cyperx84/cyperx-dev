        <a href="#" onclick="event.preventDefault(); window.scrollTo({top:0,behavior:'smooth'})" class="group bg-[#111] p-6 border-t-4 sm:border-t-0 sm:border-l-4 lg:border-l-0 lg:border-t-4 border-[#ac89ff] hover:bg-[#191919] transition-all x-glitch-hover text-center">
