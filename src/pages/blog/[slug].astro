<script>
function initBlogPage() {
  // ── Reading progress bar ──
  const progressBar = document.getElementById('blog-progress');
  const readingIndicator = document.getElementById('reading-indicator');

  function updateBlogProgress() {
    const scrollTop = window.scrollY;
    const docHeight = document.documentElement.scrollHeight - window.innerHeight;
    if (docHeight > 0 && progressBar) {
      const pct = scrollTop / docHeight;
      progressBar.style.width = (pct * 100) + '%';

      // Update reading time indicator
      if (readingIndicator) {
        const readTimeEl = document.querySelector('[data-reading-time]');
        const readTimeText = readTimeEl?.getAttribute('data-reading-time') || '10 min';
        const totalMin = parseInt(readTimeText, 10) || 10;
        const currentMin = Math.ceil(pct * totalMin);
        readingIndicator.textContent = currentMin + ' / ' + totalMin + ' min';
        readingIndicator.style.opacity = scrollTop > 100 ? '1' : '0';
      }
    }
  }
  window.removeEventListener('scroll', updateBlogProgress);
  window.addEventListener('scroll', updateBlogProgress, { passive: true });

  // ── Wrap blog prose images in jagged border + clip-path wrappers ──
  const JAG_CLIP = 'polygon(0% 15%, 5% 0%, 15% 12%, 25% 0%, 35% 8%, 45% 0%, 55% 10%, 65% 0%, 75% 6%, 85% 0%, 95% 5%, 100% 10%, 95% 25%, 100% 40%, 95% 55%, 100% 70%, 95% 85%, 100% 100%, 90% 92%, 80% 100%, 70% 95%, 60% 100%, 50% 93%, 40% 100%, 30% 96%, 20% 100%, 10% 94%, 0% 100%, 5% 80%, 0% 65%, 5% 50%, 0% 35%, 5% 20%)';
  // SVG animated borders disabled — clip-path is pure CSS now
  // Keeping fade-in logic below
  document.querySelectorAll('.blog-prose img').forEach(img => img.setAttribute('data-jag-done', '1'));
  /*
  const ACCENT_COLORS = ['#39FF14', '#FF51FA', '#AC89FF'];
  document.querySelectorAll('.blog-prose img:not([data-jag-done])').forEach((img, idx) => {
    // ... wrapper injection removed for CSS-only clip-path approach
  });
  */

  // ── LCP: first prose image gets eager+high priority, rest are lazy ──
  const proseImgs = document.querySelectorAll<HTMLImageElement>('.blog-prose img');
  proseImgs.forEach((img, i) => {
    if (i === 0) {
      img.setAttribute('loading', 'eager');
      img.setAttribute('fetchpriority', 'high');
      img.setAttribute('decoding', 'async');
    } else {
      img.setAttribute('loading', 'lazy');
      img.setAttribute('decoding', 'async');
    }
  });

  // ── Fade in blog images on load ──
  document.querySelectorAll('.blog-prose img').forEach(img => {
    const el = img as HTMLImageElement;
    if (el.complete && el.naturalWidth > 0) {
      el.classList.add('jag-loaded');
    } else {
      el.addEventListener('load', () => el.classList.add('jag-loaded'));
      el.addEventListener('error', () => el.classList.add('jag-loaded'));
    }
  });

  // ── H2 glitch-flash on enter (IntersectionObserver) ──
  const blogProseContainers = document.querySelectorAll('.blog-prose');
  blogProseContainers.forEach(container => {
    const h2s = container.querySelectorAll('h2');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('bp-glitch');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });
    h2s.forEach(h => observer.observe(h));
  });

  // ── A11y: ensure blog-prose images have alt attribute (decorative fallback) ──
  document.querySelectorAll('.blog-prose img').forEach(img => {
    if (!img.hasAttribute('alt')) img.setAttribute('alt', '');
  });

  // ── Table of Contents (dark variant, desktop only, 2+ h2 headings) ──
  buildToc();

  // (.x-fractal-bg deferred-load is handled centrally by BaseLayout)
} // end initBlogPage

function slugify(str) {
  return str.toLowerCase().trim()
    .replace(/[^\w\s-]/g, '')
    .replace(/\s+/g, '-')
    .replace(/-+/g, '-');
}

function buildToc() {
  // Remove any prior ToC (handles re-init on view transitions)
  const prior = document.getElementById('blog-toc');
  if (prior) prior.remove();

  if (!document.documentElement.classList.contains('theme-dark')) return;
  const prose = document.querySelector('.blog-prose');
  if (!prose) return;
  const h2s = Array.from(prose.querySelectorAll('h2'));
  if (h2s.length < 2) return;

  // Assign IDs
  const used = new Set();
  h2s.forEach(h => {
    let id = h.id || slugify(h.textContent || '');
    if (!id) return;
    let base = id, i = 2;
    while (used.has(id)) { id = base + '-' + i; i++; }
    used.add(id);
    h.id = id;
  });

  const toc = document.createElement('nav');
  toc.id = 'blog-toc';
  toc.className = 'hidden lg:block fixed left-4 top-1/2 -translate-y-1/2 z-30 max-w-[200px]';
  toc.setAttribute('aria-label', 'Table of contents');
  toc.innerHTML = `
    <div class="font-mono text-[9px] uppercase tracking-wider mb-3" style="color:#39FF14;opacity:0.7">// CONTENTS</div>
    <ul class="space-y-2 border-l border-[#39FF14]/30 pl-3">
      ${h2s.map(h => `<li><a href="#${h.id}" data-toc-link="${h.id}" class="block font-mono text-[10px] leading-snug text-[#e2e2e2]/60 hover:text-[#39FF14] transition-colors">${(h.textContent || '').replace(/</g,'&lt;')}</a></li>`).join('')}
    </ul>
  `;
  document.body.appendChild(toc);

  // Smooth scroll
  toc.querySelectorAll('a[data-toc-link]').forEach(a => {
    a.addEventListener('click', (e) => {
      e.preventDefault();
      const id = a.getAttribute('data-toc-link');
      const target = id ? document.getElementById(id) : null;
      if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  });

  // Highlight active via IO
  const links = new Map();
  toc.querySelectorAll('a[data-toc-link]').forEach(a => {
    links.set(a.getAttribute('data-toc-link'), a);
  });
  const activeObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      const link = links.get(entry.target.id);
      if (!link) return;
      if (entry.isIntersecting) {
        links.forEach(l => { l.style.color = ''; l.style.fontWeight = ''; });
        link.style.color = '#39FF14';
        link.style.fontWeight = '700';
      }
    });
  }, { rootMargin: '-20% 0px -70% 0px', threshold: 0 });
  h2s.forEach(h => activeObserver.observe(h));
}

// Audio Player — single floating bar, theme-adaptive
function initAudioPlayer() {
  const player = document.getElementById('audio-player');
  const audio = document.getElementById('blog-audio');
  const playBtn = document.getElementById('play-btn');
  const speedBtn = document.getElementById('speed-btn');
  const progressBar = document.getElementById('progress-bar');
  const progressFill = document.getElementById('progress-fill');
  const timeDisplay = document.getElementById('audio-time');
  const durationDisplay = document.getElementById('audio-duration');
  const titleDisplay = document.getElementById('audio-title');
  if (!player || !audio || !playBtn) return;

  const themes = {
    dark:    { bg: 'rgba(14,14,14,0.95)', border: '#39FF14', accent: '#39FF14', text: '#e2e2e2', track: 'rgba(57,255,20,0.15)' },
    light:   { bg: 'rgba(255,255,255,0.95)', border: '#FF51FA', accent: '#FF51FA', text: '#131313', track: 'rgba(255,81,250,0.15)' },
    extreme: { bg: 'rgba(10,0,16,0.95)', border: '#8eff71', accent: '#8eff71', text: '#fff', track: 'rgba(142,255,113,0.15)' },
  };

  function applyTheme() {
    const html = document.documentElement;
    let t = 'dark';
    if (html.classList.contains('theme-light')) t = 'light';
    else if (html.classList.contains('theme-extreme')) t = 'extreme';
    const c = themes[t];
    player.style.background = c.bg;
    player.style.borderTopColor = c.border + '33';
    playBtn.style.borderColor = c.accent;
    playBtn.style.color = c.accent;
    speedBtn.style.borderColor = c.accent + '44';
    speedBtn.style.color = c.text;
    progressFill.style.background = c.accent;
    progressBar.style.background = c.track;
    titleDisplay.style.color = c.accent + '99';
    timeDisplay.style.color = c.text;
    durationDisplay.style.color = c.text;
    titleDisplay.textContent = 'LISTEN · ' + document.title.split(' | ')[0].toUpperCase();
  }

  applyTheme();

  // Player only rendered when audio exists (guarded at build time), so we can
  // reveal it directly once metadata loads.
  player.classList.add('hidden');
  audio.addEventListener('loadedmetadata', () => player.classList.remove('hidden'), { once: true });
  audio.addEventListener('error', () => player.classList.add('hidden'));

  const speeds = [1, 1.25, 1.5, 2];
  let speedIdx = 0;
  function fmt(s) {
    const m = Math.floor(s / 60);
    const sec = Math.floor(s % 60);
    return `${m}:${sec.toString().padStart(2, '0')}`;
  }

  playBtn.addEventListener('click', () => {
    if (audio.paused) { audio.play(); playBtn.textContent = '⏸'; }
    else { audio.pause(); playBtn.textContent = '▶'; }
  });

  speedBtn.addEventListener('click', () => {
    speedIdx = (speedIdx + 1) % speeds.length;
    audio.playbackRate = speeds[speedIdx];
    speedBtn.textContent = speeds[speedIdx] + 'x';
  });

  audio.addEventListener('timeupdate', () => {
    if (!audio.duration) return;
    progressFill.style.width = (audio.currentTime / audio.duration * 100) + '%';
    timeDisplay.textContent = fmt(audio.currentTime);
    durationDisplay.textContent = fmt(audio.duration);
  });

  audio.addEventListener('ended', () => {
    playBtn.textContent = '▶';
    progressFill.style.width = '0%';
  });

  progressBar.addEventListener('click', (e) => {
    if (!audio.duration) return;
    const rect = progressBar.getBoundingClientRect();
    audio.currentTime = ((e.clientX - rect.left) / rect.width) * audio.duration;
  });

  // Touch feedback for player buttons
  [playBtn, speedBtn].forEach(btn => {
    btn.addEventListener('touchstart', () => { btn.style.transform = 'scale(0.88)'; }, { passive: true });
    btn.addEventListener('touchend', () => { btn.style.transform = 'scale(1)'; }, { passive: true });
    btn.addEventListener('touchcancel', () => { btn.style.transform = 'scale(1)'; }, { passive: true });
  });
  // Progress bar touch scrub
  let scrubbing = false;
  progressBar.addEventListener('touchstart', (e) => {
    scrubbing = true;
    handleScrub(e.touches[0]);
  }, { passive: true });
  progressBar.addEventListener('touchmove', (e) => {
    if (scrubbing) handleScrub(e.touches[0]);
  }, { passive: true });
  progressBar.addEventListener('touchend', () => { scrubbing = false; }, { passive: true });
  function handleScrub(touch) {
    if (!audio.duration) return;
    const rect = progressBar.getBoundingClientRect();
    const ratio = Math.max(0, Math.min(1, (touch.clientX - rect.left) / rect.width));
    audio.currentTime = ratio * audio.duration;
  }

  // Re-apply theme when <html> class changes (theme switch)
  const themeObs = new MutationObserver(applyTheme);
  themeObs.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
}

initAudioPlayer();
document.addEventListener('astro:page-load', initAudioPlayer);

document.addEventListener('astro:page-load', initBlogPage);
if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', initBlogPage);
} else {
  initBlogPage();
}
</script>

