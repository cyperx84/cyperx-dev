        <a href="#" onclick="event.preventDefault(); window.scrollTo({top:0,behavior:'smooth'})" class="group bg-[#f5f5f5] p-6 hover:bg-[#ebebeb] transition-colors text-center" style="clip-path:polygon(5% 0,100% 0,95% 100%,0 100%)">
