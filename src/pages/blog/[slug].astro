        <a href="#" onclick="event.preventDefault(); window.scrollTo({top:0,behavior:'smooth'})" class="group bg-[#0e0e0e] p-6 border-t-4 sm:border-t-0 sm:border-l-4 lg:border-l-0 lg:border-t-4 border-[#39FF14] hover:bg-[#1f1f1f] transition-colors text-center">
          <div class="font-mono text-[9px] text-[#e2e2e2]/40 mb-2">BACK TO TOP &uarr;</div>
