---
import BaseLayout from '../layouts/BaseLayout.astro';
import { projects } from '../data/projects';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const posts = allPosts
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 2);
---

<BaseLayout title="CYPERX.DEV" activeNav="home">

  <!-- ════════════════════════════════════════
       DARK VARIANT
  ════════════════════════════════════════ -->
  <div class="variant-dark bg-transparent text-[#e2e2e2] min-h-screen overflow-x-hidden">

    <!-- Ambient orbs -->
    <div aria-hidden="true" class="fixed inset-0 pointer-events-none overflow-hidden z-0">
      <div class="orb orb-1"></div>
      <div class="orb orb-2"></div>
      <div class="orb orb-3"></div>
    </div>

    <main class="relative z-10 pt-28 sm:pt-36 pb-24 space-y-28 sm:space-y-48">

      <!-- ── HERO ── -->
      <section class="px-4 sm:px-6 max-w-7xl mx-auto">
        <p class="hero-sub font-mono text-[#39FF14] text-xs tracking-widest mb-6">BRISBANE · BUILDER · SHIPS DAILY</p>
        <h1 class="hero-title leading-none pb-2 overflow-visible" style="pointer-events:none;">
          <span class="block bg-clip-text text-transparent bg-gradient-to-r from-[#39FF14] via-[#AC89FF] to-[#FF51FA] pr-2 hero-lazer-glitch"
            style="font-family:'Lazer84',cursive; font-size:clamp(3rem,14vw,14rem); letter-spacing:-0.01em; pointer-events:none;">CyperX</span>
        </h1>
        <p class="hero-desc max-w-2xl text-[#baccb0] text-base sm:text-xl leading-relaxed mt-4 mb-10">
          I build tools and systems that compound. Right now: AI agent fleets, automation pipelines, and whatever plumbing keeps the whole thing running — all orchestrated from an M4 Mac Mini and a phone.
        </p>
        <div class="hero-cta flex flex-wrap gap-4">
          <a href="/projects" class="bg-[#39FF14] text-black px-8 py-3 font-black text-sm uppercase tracking-widest hover:scale-105 hover:bg-[#FF51FA] hover:text-white transition-all" style="clip-path:polygon(0 0,100% 0,95% 100%,5% 95%)">PROJECTS</a>
          <a href="/blog" class="border-2 border-[#FF51FA]/40 text-[#FF51FA] px-8 py-3 font-black text-sm uppercase tracking-widest hover:border-[#FF51FA] hover:bg-[#FF51FA]/10 transition-all" style="clip-path:polygon(2% 5%,100% 0,98% 95%,0 100%)">BLOG</a>
          <a href="/about" class="border-2 border-[#AC89FF]/30 text-[#AC89FF] px-8 py-3 font-black text-sm uppercase tracking-widest hover:border-[#AC89FF] hover:bg-[#AC89FF]/10 transition-all active:scale-95" style="clip-path:polygon(0 3%,100% 0,97% 100%,3% 97%)">ABOUT</a>
        </div>
      </section>

      <!-- ── MARQUEE TICKER ── -->
      <div class="marquee-strip border-y border-[#39FF14]/20 py-3 overflow-hidden bg-[#39FF14]/5" aria-hidden="true">
        <div class="marquee-inner whitespace-nowrap font-mono text-xs tracking-widest text-[#39FF14]/70">
          {Array(3).fill([
            "CYPERX.DEV", "CHANGELOGS.INFO", "DOTFILES", "M4 MAC MINI",
            "CLAUDE CODE", "CODEX", "OPENCLAW", "NEOVIM", "TMUX", "GHOSTTY",
            "AGENT FLEET ONLINE", "SHIPS DAILY", "BRISBANE AU",
          ]).flat().map((t, i) => (
            <span class="inline-block px-8">{t} <span class="text-[#FF51FA]/50">·</span></span>
          ))}
        </div>
      </div>

      <!-- ── PROJECTS ── -->
      <section class="px-4 sm:px-6 max-w-7xl mx-auto" data-reveal-section>
        <div class="flex items-baseline gap-4 mb-12 flex-wrap">
          <p class="font-mono text-[10px] text-[#39FF14]/60 tracking-[0.5em]">PROJECTS</p>
          <div class="h-px flex-grow bg-[#39FF14]/10"></div>
          <a href="/projects" class="font-mono text-[10px] text-[#e2e2e2]/40 hover:text-[#39FF14] tracking-widest transition-colors">ALL →</a>
        </div>

        <div class="relative grid grid-cols-1 gap-6 md:gap-0 md:grid-cols-3">
          {projects.map((p, i) => {
            const accent = ["#39FF14", "#FF51FA", "#AC89FF"][i];
            const shapes = ["x-shard-1", "shard-card-2", "x-shard-3"];
            const offsets = ["", "md:mt-10 md:-ml-6 z-30", "md:mt-24 md:-ml-4 z-10"];
            const zs = ["z-20", "z-30", "z-10"];
            return (
              <a href={`/projects/${p.slug}`} class={`project-card group block no-underline ${shapes[i]} ${offsets[i]} ${zs[i]} hover:scale-[1.03] transition-transform relative`} style={`background:#0e0e0e;`}>
                <svg class="card-svg-border" viewBox="0 0 100 100" preserveAspectRatio="none" aria-hidden="true">
                  <polygon points="0,8 6,2 18,7 28,0 42,5 55,0 68,4 78,0 90,3 100,6 97,14 100,28 96,42 100,58 97,72 100,85 98,100 85,96 72,100 58,97 42,100 28,97 14,100 0,94 3,85 0,72 4,58 0,42 3,28 0,14" class="card-jag-outer" style={`stroke:${accent};`} />
                  <polygon points="2,10 8,4 20,9 30,2 44,7 57,2 70,6 80,2 92,5 98,8 95,16 98,30 94,44 98,60 95,74 98,87 96,98 83,94 70,98 56,95 40,98 26,95 12,98 2,92 5,83 2,70 6,56 2,40 5,26 2,12" class="card-jag-inner" style={`stroke:${accent}; animation-delay:0.8s`} />
                </svg>
                {p.image && (
                  <div class="jag-img-wrap" style="height:160px;">
                    <img src={p.image} alt={p.name} class="jag-img group-hover:opacity-90 group-hover:scale-105" loading="lazy" decoding="async" width="600" height="160" />
                    <svg class="jag-border" viewBox="0 0 100 100" preserveAspectRatio="none" aria-hidden="true">
                      <polygon points="2,0 14,6 25,0 38,5 52,0 65,3 80,0 92,4 100,2 98,16 100,32 97,48 100,64 98,80 100,95 94,100 80,97 65,100 48,96 32,100 18,98 0,96 3,82 0,65 4,48 0,32 2,16" class="jag-stroke-outer" style={`stroke:${accent};`} />
                      <polygon points="4,2 16,8 27,2 40,7 54,2 67,5 82,2 94,6 98,4 96,18 98,34 95,50 98,66 96,82 98,97 92,98 78,95 63,98 46,94 30,98 16,96 2,94 5,80 2,63 6,46 2,30 4,18" class="jag-stroke-inner" style={`stroke:${accent}; animation-delay:${i*0.3}s`} />
                    </svg>
                  </div>
                )}
                <div class="p-6 sm:p-7">
                  <div class="flex items-center justify-between mb-3">
                    <span class="font-mono text-[10px] px-2 py-0.5 font-black" style={`background:${accent}; color:black`}>{p.status}</span>

                  </div>
                  <h3 class="text-lg font-black italic tracking-tight mb-2" style={`color:${accent}`}>{p.name}</h3>
                  <p class="text-[#baccb0] text-xs leading-relaxed mb-4">{p.tagline}</p>
                  <div class="flex gap-2 flex-wrap">
                    {p.stack.slice(0, 3).map(t => (
                      <span class="font-mono text-[9px] text-[#e2e2e2]/25 bg-[#1f1f1f] px-2 py-1">{t}</span>
                    ))}
                  </div>
                </div>
              </a>
            );
          })}
        </div>
      </section>

      <!-- ── STAT ROW ── -->
      <section class="px-4 sm:px-6 max-w-7xl mx-auto">
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 sm:gap-4">
          {[
            { n: "3", label: "LIVE PROJECTS", shape: "polygon(0 0, 92% 0, 88% 100%, 8% 100%)", mt: "" },
            { n: "4", label: "AI AGENTS",     shape: "polygon(5% 0, 100% 8%, 95% 100%, 0 88%)", mt: "mt-4" },
            { n: "M4", label: "MAC MINI",     shape: "polygon(0% 5%, 95% 0%, 100% 95%, 5% 100%)", mt: "" },
            { n: "∞", label: "COMPOUNDING",  shape: "polygon(8% 0%, 100% 0%, 92% 100%, 0% 94%)", mt: "mt-8" },
          ].map((s, i) => (
            <div class={`stat-card bg-[#0e0e0e] p-8 sm:p-10 text-center hover:bg-[#161616] transition-colors ${s.mt}`} style={`clip-path:${s.shape};`}>
              <div class="text-4xl sm:text-6xl font-black italic text-[#39FF14] mb-2">{s.n}</div>
              <div class="font-mono text-[10px] text-[#e2e2e2]/30 tracking-widest">{s.label}</div>
            </div>
          ))}
        </div>
      </section>

      <!-- ── BLOG ── -->
      <section class="px-4 sm:px-6 max-w-7xl mx-auto" data-reveal-section>
        <div class="flex items-baseline gap-4 mb-12 flex-wrap">
          <p class="font-mono text-[10px] text-[#FF51FA]/60 tracking-[0.5em]">LATEST POSTS</p>
          <div class="h-px flex-grow bg-[#FF51FA]/10"></div>
          <a href="/blog" class="font-mono text-[10px] text-[#e2e2e2]/40 hover:text-[#FF51FA] tracking-widest transition-colors">ALL →</a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 sm:gap-8">
          {posts.map((post, i) => {
            const accent = ["#FF51FA", "#AC89FF"][i];
            const shapes = ["x-shard-sidebar", "x-shard-4"];
            const offsets = ["", "mt-10 md:mt-16"];
            return (
              <a href={`/blog/${post.data.slug}`} class={`blog-card group block no-underline ${shapes[i]} ${offsets[i]} p-6 sm:p-8 hover:scale-[1.02] transition-transform relative`} style={`background:#0e0e0e;`}>
                <svg class="card-svg-border" viewBox="0 0 100 100" preserveAspectRatio="none" aria-hidden="true">
                  <polygon points="0,5 10,0 22,6 35,0 48,4 60,0 75,5 88,0 100,8 96,20 100,35 97,52 100,68 95,82 100,100 88,96 75,100 60,97 48,100 35,96 22,100 10,98 0,95 4,80 0,65 3,50 0,35 5,20" class="card-jag-outer" style={`stroke:${accent};`} />
                  <polygon points="2,7 12,2 24,8 37,2 50,6 62,2 77,7 90,2 98,10 94,22 98,37 95,54 98,70 93,84 98,98 86,94 73,98 58,95 46,98 33,94 20,98 8,96 2,93 6,78 2,63 5,48 2,33 7,18" class="card-jag-inner" style={`stroke:${accent}; animation-delay:${i*0.5}s`} />
                </svg>
                <div class="flex items-center justify-between mb-5">
                  <span class="font-mono text-[10px] px-2 py-0.5 font-black" style={`background:${accent}20; color:${accent}; border:1px solid ${accent}40`}>{post.data.category}</span>
                  <span class="font-mono text-[10px] text-[#e2e2e2]/25">{post.data.readTime}</span>
                </div>
                <h3 class="text-lg sm:text-xl font-black italic tracking-tight leading-snug mb-3 group-hover:text-[#e2e2e2] transition-colors" style={`color:${accent}`}>{post.data.title}</h3>
                <p class="text-[#baccb0] text-sm leading-relaxed mb-6">{post.data.excerpt}</p>
                <div class="flex items-center justify-between">
                  <div class="flex gap-2 flex-wrap">
                    {post.data.tags.slice(0, 3).map((t: string) => (
                      <span class="font-mono text-[9px] text-[#e2e2e2]/25">{t}</span>
                    ))}
                  </div>

                </div>
              </a>
            );
          })}
        </div>
      </section>

    </main>
  </div>


  <!-- ════════════════════════════════════════
       LIGHT VARIANT
  ════════════════════════════════════════ -->
  <div class="variant-light bg-white/90 text-[#131313] min-h-screen overflow-x-hidden">
    <main class="pt-28 sm:pt-36 pb-24 space-y-24">

      <!-- Hero -->
      <section class="px-4 sm:px-6 max-w-7xl mx-auto">
        <p class="font-mono text-[#FF51FA] text-xs tracking-widest mb-6">BRISBANE · BUILDER · SHIPS DAILY</p>
        <h1 class="leading-none pb-2 overflow-visible" style="pointer-events:none;">
          <span class="block bg-clip-text text-transparent bg-gradient-to-r from-[#FF51FA] via-[#AC89FF] to-[#39FF14] pr-2 hero-lazer-glitch"
            style="font-family:'Lazer84',cursive; font-size:clamp(3rem,13vw,13rem); letter-spacing:-0.01em; pointer-events:none;">CyperX</span>
        </h1>
        <p class="max-w-2xl text-[#555] text-base sm:text-xl leading-relaxed mt-4 mb-10">
          I build tools and systems that compound. Right now: AI agent fleets, automation pipelines, and whatever plumbing keeps the whole thing running.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="/projects" class="bg-[#FF51FA] text-white px-8 py-3 font-black text-sm uppercase tracking-widest hover:bg-[#39FF14] hover:text-black transition-all active:scale-95" style="clip-path:polygon(0 0,100% 5%,92% 100%,5% 95%)">PROJECTS</a>
          <a href="/blog" class="border-2 border-[#131313] text-[#131313] px-8 py-3 font-black text-sm uppercase tracking-widest hover:bg-[#131313] hover:text-white transition-all active:scale-95" style="clip-path:polygon(3% 0,100% 0,97% 100%,0 95%)">BLOG</a>
          <a href="/about" class="border-2 border-[#AC89FF]/50 text-[#AC89FF] px-8 py-3 font-black text-sm uppercase tracking-widest hover:border-[#AC89FF] hover:bg-[#AC89FF]/10 transition-all active:scale-95" style="clip-path:polygon(0 5%,97% 0,100% 95%,3% 100%)">ABOUT</a>
        </div>
      </section>

      <!-- Marquee -->
      <div class="marquee-strip border-y border-[#FF51FA]/20 py-3 overflow-hidden bg-[#FF51FA]/5" aria-hidden="true">
        <div class="marquee-inner whitespace-nowrap font-mono text-xs tracking-widest text-[#FF51FA]/70">
          {Array(3).fill(["CYPERX.DEV","CHANGELOGS.INFO","DOTFILES","M4 MAC MINI","CLAUDE CODE","CODEX","OPENCLAW","NEOVIM","AGENT FLEET"]).flat().map((t, i) => (
            <span class="inline-block px-8">{t} <span class="text-[#131313]/20">·</span></span>
          ))}
        </div>
      </div>

      <!-- Projects -->
      <section class="px-4 sm:px-6 max-w-7xl mx-auto">
        <div class="flex items-baseline gap-4 mb-10 border-b-2 border-[#131313] pb-4">
          <h2 class="text-3xl font-black italic tracking-tighter">PROJECTS</h2>
          <a href="/projects" class="ml-auto font-mono text-xs text-[#FF51FA] hover:text-[#39FF14] transition-colors">VIEW ALL →</a>
        </div>
        <div class="relative grid grid-cols-1 gap-6 md:gap-0 md:grid-cols-3">
          {projects.map((p, i) => {
            const accent = ["#39FF14", "#FF51FA", "#AC89FF"][i];
            const shapes = ["shard-card-1", "x-shard-3", "shard-card-2"];
            const offsets = ["", "md:mt-12 md:-ml-4 z-20", "md:mt-6 md:-ml-6 z-10"];
            return (
              <a href={`/projects/${p.slug}`} class={`project-card group block no-underline ${shapes[i]} ${offsets[i]} hover:scale-[1.02] transition-transform overflow-hidden relative`} style={`background:white; border-top:4px solid ${accent};`}>
                {p.image && (
                  <div class="jag-img-wrap" style="height:140px;">
                    <img src={p.image} alt={p.name} class="jag-img group-hover:scale-105" loading="lazy" decoding="async" width="600" height="140" />
                    <svg class="jag-border" viewBox="0 0 100 100" preserveAspectRatio="none" aria-hidden="true">
                      <polygon points="3,0 15,5 30,0 45,6 58,0 72,4 85,0 100,5 98,18 100,35 97,50 100,65 98,82 96,100 82,97 68,100 52,96 38,100 22,97 8,100 0,96 4,82 0,68 3,52 0,38 5,22" class="jag-stroke-outer" style={`stroke:${accent}; animation-delay:${i*0.5}s`} />
                      <polygon points="5,2 17,7 32,2 47,8 60,2 74,6 87,2 98,7 96,20 98,37 95,52 98,67 96,84 94,98 80,95 66,98 50,94 36,98 20,95 6,98 2,94 6,80 2,66 5,50 2,36 7,20" class="jag-stroke-inner" style={`stroke:${accent}; animation-delay:${i*0.2}s`} />
                    </svg>
                  </div>
                )}
                <div class="p-5">
                  <span class="font-mono text-[9px] font-black" style={`color:${accent}`}>{p.status}</span>
                  <h3 class="text-base font-black italic mt-1 mb-2">{p.name}</h3>
                  <p class="text-xs text-[#555]">{p.tagline}</p>
                </div>
              </a>
            );
          })}
        </div>
      </section>

      <!-- Stats -->
      <section class="px-4 sm:px-6 max-w-7xl mx-auto">
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-6">
          {[
            { n: "3", label: "LIVE PROJECTS", c: "#39FF14", shape: "polygon(0 0, 92% 0, 88% 100%, 8% 100%)", mt: "" },
            { n: "4", label: "AI AGENTS",     c: "#FF51FA", shape: "polygon(5% 0, 100% 8%, 95% 100%, 0 88%)", mt: "mt-4" },
            { n: "M4", label: "MAC MINI",     c: "#AC89FF", shape: "polygon(0% 5%, 95% 0%, 100% 95%, 5% 100%)", mt: "" },
            { n: "∞", label: "COMPOUNDING",  c: "#131313", shape: "polygon(8% 0%, 100% 0%, 92% 100%, 0% 94%)", mt: "mt-6" },
          ].map((s, i) => (
            <div class={`stat-card p-6 ${s.mt}`} style={`border:2px solid ${s.c}; background:white; clip-path:${s.shape};`}>
              <div class="text-4xl font-black italic mb-1" style={`color:${s.c}`}>{s.n}</div>
              <div class="font-mono text-[10px] text-[#131313]/50 tracking-widest">{s.label}</div>
            </div>
          ))}
        </div>
      </section>

      <!-- Blog -->
      <section class="px-4 sm:px-6 max-w-7xl mx-auto">
        <div class="flex items-baseline gap-4 mb-10 border-b-2 border-[#131313] pb-4">
          <h2 class="text-3xl font-black italic tracking-tighter">LATEST POSTS</h2>
          <a href="/blog" class="ml-auto font-mono text-xs text-[#FF51FA] hover:text-[#39FF14] transition-colors">ALL →</a>
        </div>
        <div class="relative grid grid-cols-1 gap-6 md:gap-0 md:grid-cols-2">
          {posts.map((post, i) => {
            const accent = ["#FF51FA", "#AC89FF"][i];
            const shapes = ["x-shard-sidebar", "shard-card-3"];
            const offsets = ["", "md:mt-14 md:-ml-4"];
            return (
              <a href={`/blog/${post.data.slug}`} class={`blog-card group block no-underline ${shapes[i]} ${offsets[i]} p-6 sm:p-8 hover:scale-[1.02] transition-transform`} style={`background:white; border-left:4px solid ${accent};`}>
                <span class="font-mono text-[10px]" style={`color:${accent}`}>{post.data.category} · {post.data.readTime}</span>
                <h3 class="text-lg font-black italic mt-2 mb-3 group-hover:text-[#FF51FA] transition-colors">{post.data.title}</h3>
                <p class="text-sm text-[#555] leading-relaxed">{post.data.excerpt}</p>
              </a>
            );
          })}
        </div>
      </section>

    </main>
  </div>


  <!-- ════════════════════════════════════════
       EXTREME VARIANT
  ════════════════════════════════════════ -->
  <div class="variant-extreme min-h-screen text-white overflow-x-hidden">
    <!-- Canvas starfield background -->
    <canvas id="starfield" class="fixed inset-0 pointer-events-none z-0" aria-hidden="true"></canvas>

    <main class="relative z-10 pt-28 sm:pt-40 pb-24 space-y-32 sm:space-y-56">

      <!-- Hero -->
      <section class="px-4 sm:px-6 max-w-7xl mx-auto relative">
        <p class="font-mono text-[#8eff71] text-xs tracking-widest mb-6 animate-pulse">BRISBANE · BUILDER · SHIPS DAILY</p>
        <h1 class="leading-none pb-2 overflow-visible x-vibrating-text" style="pointer-events:none;">
          <span class="hero-lazer-glitch-solid" style="font-family:'Lazer84',cursive; font-size:clamp(3rem,14vw,14rem); letter-spacing:-0.01em; color:#8eff71; pointer-events:none;">CyperX</span><span class="text-[#ff51fa]" style="font-family:'Lazer84',cursive; font-size:clamp(3rem,14vw,14rem); pointer-events:none;">.</span>
        </h1>
        <p class="max-w-2xl text-white/70 font-mono text-sm sm:text-base leading-relaxed mt-6 mb-12 border-l-4 border-[#ff51fa] pl-6">
          I build tools and systems that compound. AI agent fleets, automation pipelines, the plumbing that keeps it running. All orchestrated from an M4 Mac Mini.
        </p>
        <div class="flex flex-wrap gap-6">
          <a href="/projects" class="bg-[#8eff71] text-black px-10 py-4 font-black text-sm uppercase tracking-widest hover:scale-105 hover:bg-[#ff51fa] hover:text-white transition-all active:scale-95 shadow-[6px_6px_0_#ff51fa] hover:shadow-[6px_6px_0_#8eff71]" style="clip-path:polygon(0 0,95% 3%,100% 97%,5% 100%)">PROJECTS</a>
          <a href="/blog" class="border-2 border-[#ff51fa] text-[#ff51fa] px-10 py-4 font-black text-sm uppercase tracking-widest hover:bg-[#ff51fa] hover:text-white transition-all active:scale-95" style="clip-path:polygon(3% 0,100% 5%,97% 100%,0 95%)">BLOG</a>
        </div>
      </section>

      <!-- Marquee -->
      <div class="marquee-strip border-y border-[#8eff71]/20 py-3 overflow-hidden" aria-hidden="true">
        <div class="marquee-inner whitespace-nowrap font-mono text-xs tracking-widest text-[#8eff71]/60">
          {Array(3).fill(["CYPERX.DEV","CHANGELOGS.INFO","DOTFILES","M4 MAC MINI","CLAUDE CODE","CODEX","OPENCLAW","NEOVIM","TMUX","AGENT FLEET ONLINE"]).flat().map((t, i) => (
            <span class="inline-block px-8">{t} <span class="text-[#ff51fa]/40">·</span></span>
          ))}
        </div>
      </div>

      <!-- Projects -->
      <section class="px-4 sm:px-6 max-w-7xl mx-auto">
        <div class="flex items-baseline gap-4 mb-12">
          <p class="font-mono text-[10px] text-[#8eff71]/60 tracking-[0.5em]">// PROJECTS</p>
          <div class="h-px flex-grow bg-[#8eff71]/10"></div>
          <a href="/projects" class="font-mono text-[10px] text-white/30 hover:text-[#8eff71] tracking-widest transition-colors">ALL →</a>
        </div>
        <div class="relative grid grid-cols-1 gap-6 md:gap-0 md:grid-cols-3">
          {projects.map((p, i) => {
            const accent = ["#8eff71", "#ff51fa", "#ac89ff"][i];
            const shapes = ["x-shard-1", "acid-mask-1", "x-shard-melt-intense"];
            const offsets = ["z-30", "md:mt-16 md:-ml-6 z-20", "md:mt-8 md:-ml-8 z-10"];
            return (
              <a href={`/projects/${p.slug}`} class={`project-card group block no-underline ${shapes[i]} ${offsets[i]} hover:scale-[1.03] transition-transform overflow-hidden relative`} style={`background:rgba(0,0,0,0.75);`}>
                {p.image && (
