---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="CYPERX.DEV" activeNav="home">

  <!-- ════════════════════════════════════════
       DARK VARIANT — home-dark-void
  ════════════════════════════════════════ -->
  <div class="variant-dark bg-[#131313] text-[#e2e2e2] min-h-screen">
    <div class="fixed inset-0 z-[100] crt-overlay opacity-20 pointer-events-none"></div>

    <!-- Header -->
    <header class="fixed top-0 w-full flex justify-between items-center px-4 sm:px-8 py-4 sm:py-6 bg-[#131313]/80 backdrop-blur-xl z-50 nav-header">
      <div class="text-2xl sm:text-3xl font-black text-[#39FF14] [text-shadow:2px_0_#FF51FA,-2px_0_#AC89FF] animate-pulse font-['Space_Grotesk'] uppercase tracking-tighter italic">CYPERX.DEV</div>
      <nav class="hidden md:flex gap-8 lg:gap-10 font-['Space_Grotesk'] uppercase tracking-tighter italic">
        <a class="text-[#39FF14] border-b-2 border-[#39FF14] pb-1 hover:text-[#FF51FA] hover:skew-x-12 transition-all duration-75" href="/">HOME</a>
        <a class="text-[#e2e2e2] hover:text-[#FF51FA] hover:skew-x-12 transition-all duration-75" href="/blog">BLOG</a>
        <a class="text-[#e2e2e2] hover:text-[#FF51FA] hover:skew-x-12 transition-all duration-75" href="/projects">PROJECTS</a>
      </nav>
      <button class="bg-[#39FF14] text-black px-4 sm:px-6 py-2 font-black italic text-xs sm:text-sm" style="clip-path: polygon(10% 0,100% 0,90% 100%,0 100%)">TRIPP_MODE</button>
    </header>

    <main class="pt-28 sm:pt-32 pb-20 px-4 sm:px-6 max-w-7xl mx-auto space-y-24 sm:space-y-40">
      <!-- Hero -->
      <section class="relative">
        <div class="shard-hero w-full h-[400px] sm:h-[600px] lg:h-[716px] relative bg-[#0e0e0e] overflow-hidden">
          <div class="absolute inset-0 bg-gradient-to-br from-[#131313] via-[#1a0a2e] to-[#0a1a0a] opacity-80"></div>
          <div class="absolute inset-0 flex items-center justify-center p-6 sm:p-12">
            <div class="text-center z-10">
              <p class="font-mono text-[#39FF14] text-xs sm:text-sm tracking-[0.5em] mb-4">ESTABLISHING CONNECTION...</p>
              <h1 class="text-4xl sm:text-6xl lg:text-9xl font-black italic tracking-tighter glitch-text leading-none mb-6 sm:mb-8">
                CYPERX.DEV <br/><span class="text-[#e2e2e2] opacity-90">//</span> BEYOND_THE_VOID
              </h1>
              <div class="flex flex-wrap justify-center gap-4 sm:gap-6">
                <button class="bg-[#39FF14] text-black px-6 sm:px-10 py-3 sm:py-4 text-base sm:text-xl font-black italic shard-card-3 hover:scale-105 transition-transform">ENTER_SYSTEM</button>
                <button class="border-2 border-[#FF51FA]/30 text-[#FF51FA] px-6 sm:px-10 py-3 sm:py-4 text-base sm:text-xl font-black italic shard-card-1 hover:border-[#FF51FA] transition-all">VIEW_ARCHIVES</button>
              </div>
            </div>
          </div>
          <div class="absolute top-10 right-10 w-24 sm:w-32 h-24 sm:h-32 border-t-2 border-r-2 border-[#39FF14]/20"></div>
          <div class="absolute bottom-10 left-10 w-24 sm:w-32 h-24 sm:h-32 border-b-2 border-l-2 border-[#FF51FA]/20"></div>
        </div>
      </section>

      <!-- THE_BREACH -->
      <section>
        <div class="mb-8 sm:mb-16 flex items-baseline gap-4 flex-wrap">
          <h2 class="text-3xl sm:text-5xl font-black italic text-[#39FF14] tracking-tighter">THE_BREACH</h2>
          <div class="h-[2px] flex-grow bg-gradient-to-r from-[#39FF14]/50 to-transparent"></div>
          <span class="font-mono text-xs opacity-50">STATUS: COMPROMISED</span>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-0 relative">
          <div class="shard-card-1 bg-[#2a2a2a] p-6 sm:p-8 group hover:bg-[#393939] transition-colors relative z-20 md:-mr-4">
            <span class="material-symbols-outlined text-4xl sm:text-5xl text-[#39FF14] mb-4 sm:mb-6 block">terminal</span>
            <h3 class="text-xl sm:text-2xl font-bold mb-3 sm:mb-4 italic tracking-tight">KRNL_OVERFLOW</h3>
            <p class="text-sm opacity-70 font-mono leading-relaxed mb-4 sm:mb-6">System breach detected at sector 7G. Memory leak propagating through neural links. Data integrity failing... [REDACTED]</p>
            <div class="font-mono text-[10px] text-[#39FF14]/60">UID: 0x99281-ALPHA</div>
          </div>
          <div class="shard-card-2 bg-[#353535] p-6 sm:p-8 group hover:bg-[#393939] transition-colors relative z-30 md:-mt-0 md:mt-10">
            <div class="mb-4 sm:mb-6 flex justify-between">
              <span class="material-symbols-outlined text-4xl sm:text-5xl text-[#FF51FA]" style="font-variation-settings:'FILL' 1">skull</span>
              <span class="text-[#FF51FA] font-black text-3xl sm:text-4xl">77%</span>
            </div>
            <h3 class="text-xl sm:text-2xl font-bold mb-3 sm:mb-4 italic tracking-tight">BIO_HAZARD_01</h3>
            <p class="text-sm opacity-70 font-mono leading-relaxed mb-4 sm:mb-6">Biological interfaces responding to psychedelic stimuli. Synthetic consciousness approaching transcendence.</p>
            <div class="w-full bg-[#131313] h-1"><div class="bg-[#FF51FA] h-full w-[77%] animate-pulse"></div></div>
          </div>
          <div class="shard-card-3 bg-[#1f1f1f] p-6 sm:p-8 group hover:bg-[#393939] transition-colors relative z-10 md:-ml-4">
            <span class="material-symbols-outlined text-4xl sm:text-5xl text-[#AC89FF] mb-4 sm:mb-6 block">electric_bolt</span>
            <h3 class="text-xl sm:text-2xl font-bold mb-3 sm:mb-4 italic tracking-tight">VOID_PROTOCOL</h3>
            <p class="text-sm opacity-70 font-mono leading-relaxed mb-4 sm:mb-6">The silence is screaming. Sub-atomic vibrations detected within the firewall. Prepare for total system ego death.</p>
            <button class="text-[10px] font-black uppercase tracking-widest text-[#AC89FF] border-b border-[#AC89FF]/30 pb-1 hover:border-[#AC89FF] transition-all">INITIALIZE_SHUTDOWN</button>
          </div>
        </div>
      </section>

      <!-- CORE_PROTOCOL Timeline -->
      <section class="max-w-4xl mx-auto">
        <div class="mb-12 sm:mb-20 text-center">
          <h2 class="text-3xl sm:text-5xl font-black italic text-[#FF51FA] tracking-tighter mb-2">CORE_PROTOCOL</h2>
          <p class="font-mono text-xs opacity-40">LATEST_CORRUPTIONS_LOG_V4.0.2</p>
        </div>
        <div class="space-y-16 sm:space-y-24 relative">
          <div class="absolute left-1/2 top-0 bottom-0 w-[1px] bg-gradient-to-b from-[#39FF14] via-[#FF51FA] to-[#AC89FF] opacity-20 hidden md:block"></div>
          {[
            { ts: '04:22:11', color: '#39FF14', title: 'Fragmented Reality', body: 'Visual sharding applied to all root nodes. The grid is no longer a safety net; it is a cage we have broken.', img: 'https://lh3.googleusercontent.com/aida-public/AB6AXuBtMsYO-2f_RpqhdW_Nn5fWBdMIVS6ZoIlxrccJyoAmO1BQLb4gEDhus1D2sr6lptV_UWDWmti0kUMECFKpWGdnUlPku3EebLKSSNmifSu1i9b5GY5C_E0WcKQ3nOrIqYFvNn22Q5cDtbZJAQ9y4wxrnOBYZ-K3eEW4emc_eTaObJAkclFeo5QhhyN98P4MnmA83IV_U8uIUNBvTcU4EjsFuCRUnXwVXiosWJvnSjQGSsMlTSiD5Tyty0Gl9BtE--fv8_BR_7d1ahc', rev: false },
            { ts: '09:15:00', color: '#FF51FA', title: 'Neural Breach', body: 'Injected sensory overload scripts into the user interface. Experience is now measured in hertz and hallucinations.', img: 'https://lh3.googleusercontent.com/aida-public/AB6AXuAYHjP9kd6Vy4XqZtabv_c5sML3yf3hdJBy0pr6ENA2fgBP2EoAzv2Y1DxXAgHPHWp2rBF4yBNk3M0FvNUEHLmhkeIuPtcBm9T4WxuSSe8dX-Tm3cnUCu7BXRmtrYBuHwOqzNJrr1c3X4LJqat2zrqwOlA-6hZtkyWwJ7wsIbG3eYHzPty-ZDn44OHpLBoqmViS-UcJCfDCgbx5k22KJZXKEaJQmJHnfm6efsjB7Q7LqbOe94qAhAqU26W_c4WTXpZpeG9EV337fMY', rev: true },
            { ts: '23:59:59', color: '#AC89FF', title: 'System Ego Death', body: 'Total convergence achieved. The boundary between user and machine has dissolved into white noise.', img: 'https://lh3.googleusercontent.com/aida-public/AB6AXuDGI4RqT5TIHkBUwzRwnMAdWHBHuBu9leC3Ve6p5HJyY9y6mSWPHXjkfTRLf5rbhXJ803ZWPYcReiYIOdzUT-ALE_N9fe_ej0DiYkhc5B3bRswd-ao4-kyOgn1CLMIzBQsNKCdD9qXnD9XuWioTxPzFcgtLE0IDBGzdJtc6DxzvM5zlGk6086l0DZyDdj1x-7QwCgLO63O97z8N3TGjhbLBBNKj-ZWobwz8TUD-iNSANTCSY6ZER_qXyEGXEh1xRdlDJU1CAwMbUbE', rev: false }
          ].map(({ ts, color, title, body, img, rev }) => (
            <div class={`relative flex flex-col ${rev ? 'md:flex-row-reverse' : 'md:flex-row'} items-center gap-8 sm:gap-12 group`}>
              <div class={`w-full md:w-1/2 ${rev ? 'text-left' : 'text-right'}`}>
                <h4 class="font-mono text-xs mb-2" style={`color: ${color}`}>TIMESTAMP: {ts}</h4>
                <h3 class="text-2xl sm:text-3xl font-black italic uppercase leading-none mb-3 sm:mb-4">{title}</h3>
                <p class="text-sm opacity-60">{body}</p>
              </div>
              <div class="z-10 w-3 sm:w-4 h-3 sm:h-4 rotate-45 hidden md:block" style={`background: ${color}; box-shadow: 0 0 15px ${color}`}></div>
              <div class="w-full md:w-1/2">
                <div class="bg-[#2a2a2a] aspect-video shard-card-1 relative overflow-hidden group-hover:scale-105 transition-transform">
                  <img class="w-full h-full object-cover opacity-50 grayscale hover:grayscale-0 transition-all duration-500" src={img} alt={title} loading="lazy" />
                </div>
              </div>
            </div>
          ))}
          <div class="mt-20 sm:mt-32 flex justify-center">
            <button class="relative group">
              <div class="absolute inset-0 bg-[#39FF14] blur-xl opacity-20 group-hover:opacity-40 transition-opacity"></div>
              <div class="relative bg-[#131313] border-2 border-[#39FF14] text-[#39FF14] px-8 sm:px-12 py-4 sm:py-5 font-black text-xl sm:text-2xl italic tracking-widest shard-card-1 group-hover:bg-[#39FF14] group-hover:text-black transition-all">INITIATE_INSANITY_V2</div>
            </button>
          </div>
        </div>
      </section>
    </main>

    <!-- Footer -->
    <footer class="w-full py-10 sm:py-12 px-6 sm:px-10 flex flex-col md:flex-row justify-between items-end gap-4 bg-[#0e0e0e] site-footer">
      <div class="flex flex-col gap-2">
        <div class="text-[#39FF14] font-bold text-xl font-mono uppercase tracking-widest">CYPERX.DEV</div>
        <p class="text-[#AC89FF] font-mono text-[10px] uppercase tracking-widest">SYSTEM ENTROPY: 99.9% | STABLE BEYOND VOID</p>
      </div>
      <div class="flex gap-6 sm:gap-8 items-center">
        {['TERMINAL','REACH_OUT','LEGAL_VOID'].map(l => (
          <a class="text-[#e2e2e2]/60 font-mono text-[10px] uppercase tracking-widest hover:text-[#39FF14] hover:line-through hover:blur-[1px] transition-all" href="#">{l}</a>
        ))}
      </div>
      <div class="text-[10px] font-mono opacity-20">© NO_RIGHTS_RESERVED</div>
    </footer>

    <!-- Mobile nav -->
    <div class="md:hidden fixed bottom-0 left-0 right-0 bg-[#131313]/90 backdrop-blur-lg border-t border-[#39FF14]/20 flex justify-around items-center py-3 z-50">
      {[['home','HOME','/'],['terminal','BLOG','/blog'],['shield','PROJECTS','/projects']].map(([icon, label, href]) => (
        <a href={href} class="flex flex-col items-center text-[#39FF14]">
          <span class="material-symbols-outlined text-xl">{icon}</span>
          <span class="text-[10px] font-mono mt-1">{label}</span>
        </a>
      ))}
    </div>
  </div>


  <!-- ════════════════════════════════════════
       LIGHT VARIANT — home-blinding-light
  ════════════════════════════════════════ -->
  <div class="variant-light bg-white text-[#131313] min-h-screen">
    <div class="fixed inset-0 z-[100] light-scanline opacity-30 pointer-events-none"></div>

    <header class="fixed top-0 w-full flex justify-between items-center px-4 sm:px-8 py-4 sm:py-6 z-50 bg-white/80 backdrop-blur-xl nav-header">
      <div class="text-2xl sm:text-3xl font-black text-[#39FF14] [text-shadow:2px_0_#FF51FA,-2px_0_#AC89FF] animate-pulse font-['Space_Grotesk'] uppercase tracking-tighter italic">CYPERX.DEV</div>
      <nav class="hidden md:flex gap-8 lg:gap-10 font-['Space_Grotesk'] uppercase tracking-tighter italic">
        <a class="text-[#39FF14] border-b-2 border-[#39FF14] pb-1 hover:text-[#FF51FA] transition-all duration-75" href="/">HOME</a>
        <a class="text-[#131313] hover:text-[#FF51FA] transition-all duration-75" href="/blog">BLOG</a>
        <a class="text-[#131313] hover:text-[#FF51FA] transition-all duration-75" href="/projects">PROJECTS</a>
      </nav>
      <button class="bg-[#39FF14] text-black px-4 sm:px-6 py-2 font-bold text-xs sm:text-sm" style="clip-path: polygon(10% 0,100% 0,90% 100%,0 100%)">TRIPP_MODE</button>
    </header>

    <main class="pt-28 sm:pt-32 min-h-screen">
      <!-- Hero -->
      <section class="relative px-4 sm:px-8 py-16 sm:py-20 flex flex-col items-center justify-center min-h-[500px] sm:min-h-[819px] bg-white overflow-hidden">
        <div class="absolute inset-0 opacity-10 bg-[url('https://images.unsplash.com/photo-1618005182384-a83a8bd57fbe?q=80&w=2564&auto=format&fit=crop')] bg-cover bg-center grayscale contrast-200"></div>
        <div class="relative z-10 text-center space-y-4 sm:space-y-6">
          <p class="font-mono text-[#FF51FA] tracking-[0.5em] text-sm" style="animation: flicker 0.1s infinite">SYSTEM_INITIALIZED_2024</p>
          <h1 class="text-5xl sm:text-7xl lg:text-9xl font-black italic tracking-tighter glitch-text leading-none">VOID<br/>GAZER</h1>
          <p class="max-w-xl mx-auto text-[#131313]/80 text-base sm:text-lg uppercase font-medium">Decoding the sensory overload of the blinding digital frontier. Pure white entropy at 99.9% stability.</p>
          <div class="flex flex-wrap justify-center gap-4 mt-8 sm:mt-12">
            <button class="bg-[#39FF14] text-black px-8 sm:px-10 py-3 sm:py-4 text-lg sm:text-xl font-black hover:bg-[#FF51FA] hover:text-white transition-all" style="clip-path: polygon(0 0,100% 0,95% 100%,5% 95%)">INITIALIZE_BREACH</button>
            <button class="border-2 border-[#FF51FA] text-[#FF51FA] px-8 sm:px-10 py-3 sm:py-4 text-lg sm:text-xl font-black hover:bg-[#FF51FA] hover:text-white transition-all" style="clip-path: polygon(2% 5%,100% 0,98% 95%,0 100%)">VIEW_RECORDS</button>
          </div>
        </div>
        <!-- Metadata -->
        <div class="absolute bottom-8 sm:bottom-10 left-8 sm:left-10 hidden lg:block bg-[#ebebeb] p-4 sm:p-6 chroma-bleed" style="clip-path: polygon(0 15%,95% 0,100% 85%,5% 100%)">
          <div class="font-mono text-xs space-y-1">
            <p class="text-[#39FF14]">CORE_TEMP: 0.00K</p>
            <p class="text-[#FF51FA]">UPLINK: ACTIVE</p>
            <p class="text-[#131313]">LOC: NEON_VOID_V2</p>
          </div>
        </div>
      </section>

      <!-- Bento Grid -->
      <section class="px-4 sm:px-8 py-16 sm:py-24 space-y-8 sm:space-y-12">
        <div class="flex justify-between items-end border-b-4 border-[#39FF14] pb-4 flex-wrap gap-4">
          <h2 class="text-3xl sm:text-5xl font-black italic tracking-tighter text-[#131313]">SHARD_COLLECTION</h2>
          <span class="font-mono text-[#FF51FA] text-sm">[003_ACTIVE_NODES]</span>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-12 gap-6 sm:gap-8">
          <!-- Large shard -->
          <div class="md:col-span-8 bg-[#f0f0f0] p-1 hover:scale-[1.01] transition-transform group" style="clip-path: polygon(0 0,100% 0,95% 100%,5% 95%)">
            <div class="bg-white h-full p-6 sm:p-8 flex flex-col justify-between relative overflow-hidden">
              <div class="absolute top-0 right-0 p-4 font-mono text-[#39FF14] opacity-20 text-5xl sm:text-6xl font-black select-none">01</div>
              <div class="space-y-3 sm:space-y-4 relative z-10">
                <span class="bg-[#FF51FA] text-white text-xs px-2 py-1 font-mono">EXPERIMENTAL</span>
                <h3 class="text-2xl sm:text-4xl font-black text-[#131313] group-hover:text-[#39FF14] transition-colors">NEURAL_LIQUID_UI</h3>
                <p class="text-[#131313]/70 max-w-md">Interfaces that melt and reform based on user biometric data. A breakthrough in organic silicon interaction.</p>
              </div>
              <div class="mt-8 sm:mt-12 flex items-center gap-4">
                <span class="material-symbols-outlined text-[#39FF14]">terminal</span>
                <span class="font-mono text-sm tracking-widest uppercase">system_access_granted</span>
              </div>
            </div>
          </div>
          <!-- Small shards -->
          <div class="md:col-span-4 bg-[#39FF14] p-1 group" style="clip-path: polygon(2% 5%,100% 0,98% 95%,0 100%)">
            <div class="bg-white h-full p-6 sm:p-8 flex flex-col justify-between">
              <div class="space-y-3 sm:space-y-4">
                <span class="bg-[#131313] text-white text-xs px-2 py-1 font-mono">PROTOCOL</span>
                <h3 class="text-2xl sm:text-3xl font-black text-[#131313]">DEEP_LIGHT</h3>
              </div>
              <p class="text-[#131313]/70 mt-4 font-mono text-xs">REDACTED DATA STREAM // LEVEL 9 CLEARANCE REQUIRED</p>
              <button class="mt-6 sm:mt-8 text-[#39FF14] font-black flex items-center gap-2 group-hover:translate-x-2 transition-transform">DECRYPT <span class="material-symbols-outlined">arrow_forward</span></button>
            </div>
          </div>
          <div class="md:col-span-4 bg-[#FF51FA] p-1 group" style="clip-path: polygon(0 15%,95% 0,100% 85%,5% 100%)">
            <div class="bg-white h-full p-6 sm:p-8 flex flex-col justify-between">
              <div class="space-y-3 sm:space-y-4">
                <span class="bg-[#39FF14] text-black text-xs px-2 py-1 font-mono">SIGNAL</span>
                <h3 class="text-2xl sm:text-3xl font-black text-[#131313]">GHOST_FREQ</h3>
              </div>
              <div class="mt-6 sm:mt-8 h-16 sm:h-20 bg-[#f8f8f8] border-l-2 border-[#FF51FA] animate-pulse flex items-center justify-center">
                <span class="material-symbols-outlined text-[#FF51FA] text-3xl sm:text-4xl">graphic_eq</span>
              </div>
            </div>
          </div>
          <!-- Medium shard -->
          <div class="md:col-span-8 bg-[#ebebeb] p-1 hover:shadow-2xl transition-all" style="clip-path: polygon(0 0,100% 0,95% 100%,5% 95%)">
            <div class="bg-white h-full p-6 sm:p-8 grid sm:grid-cols-2 gap-6 sm:gap-8 items-center">
              <div class="relative aspect-video bg-[#131313] overflow-hidden" style="clip-path: polygon(2% 5%,100% 0,98% 95%,0 100%)">
                <img class="w-full h-full object-cover mix-blend-screen opacity-60" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBfrb9kxpwOQmoXnv-TklDn7U-0DMieU2XzZ2nvrADZ_YCfryxccZHMswn5s8HGfu_6rM2Vgmi3tzlHEZehG_W_ojPlqgbpuuhFytV-bJxyDGelWjdCUouRXccLYJBLxXR9FKWEaXSL2s5b_0sJKhyLNM-oqkELDbfdsr_3lE-aZyWbCuU9Vhh0MQJ_8WFx6kqeR6i-Iogv_7jQw4-rqjWYjAHJtUwQuuf5rovooA3HZjDVfZBJHPHCQM4KEFG_Qc7RwdY6bnCAe18" alt="Circuitry" loading="lazy" />
              </div>
              <div class="space-y-3 sm:space-y-4">
                <h3 class="text-2xl sm:text-3xl font-black uppercase text-[#131313]">Synapse_Bridge</h3>
                <p class="text-sm text-[#131313]/80">Connecting the physical neural pathways to the high-brightness white void of the meta-web.</p>
                <div class="flex gap-2"><div class="w-2 h-2 bg-[#39FF14]"></div><div class="w-2 h-2 bg-[#FF51FA]"></div><div class="w-2 h-2 bg-[#AC89FF]"></div></div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Quote -->
      <section class="py-20 sm:py-32 bg-[#39FF14] text-black mx-4 sm:mx-8 relative overflow-hidden" style="clip-path: polygon(2% 5%,100% 0,98% 95%,0 100%)">
        <div class="absolute inset-0 opacity-20 pointer-events-none text-6xl sm:text-8xl font-black italic break-all leading-[0.8] select-none">VOID VOID VOID VOID VOID VOID VOID VOID VOID VOID VOID VOID</div>
        <div class="relative z-10 max-w-4xl mx-auto px-6 sm:px-8 text-center space-y-6 sm:space-y-8">
          <span class="material-symbols-outlined text-5xl sm:text-6xl">format_quote</span>
          <blockquote class="text-2xl sm:text-4xl lg:text-6xl font-black tracking-tight uppercase leading-tight italic">"WE ARE NOT BROWSING THE WEB. WE ARE BREACHING THE REALITY OF PURE INFORMATION."</blockquote>
          <div class="font-mono text-base sm:text-xl tracking-widest">— ARCHITECT_X7</div>
        </div>
      </section>

      <!-- Newsletter -->
      <section class="px-4 sm:px-8 py-16 sm:py-24 flex flex-col items-center">
        <div class="w-full max-w-2xl bg-[#fafafa] p-8 sm:p-12 border-r-8 border-[#FF51FA] chroma-bleed" style="clip-path: polygon(0 0,100% 0,95% 100%,5% 95%)">
          <h2 class="text-3xl sm:text-4xl font-black tracking-tighter text-[#131313] uppercase mb-4 sm:mb-6">STAY_CONNECTED</h2>
          <p class="text-[#131313]/60 font-mono text-sm mb-6 sm:mb-8">Enter your terminal address to receive high-frequency updates directly into your visual cortex.</p>
          <div class="flex flex-col sm:flex-row gap-0">
