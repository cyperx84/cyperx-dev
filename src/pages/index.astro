---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="💀 CyperX.dev" activeNav="home">

  <!-- Chaos sticker (tablet+ only) -->
  <div class="chaos-sticker sticker-filled hidden sm:block" style="position: absolute; top: 2%; left: 3%; z-index: 40;">NULL_REF</div>

  <!-- ===== TERMINAL HEADER ===== -->
  <div class="w-full max-w-4xl fractal-card p-3 sm:p-4 font-mono mb-4 sm:mb-8 lg:mb-12 chaos-rotate-n1 relative z-30 collage-pull-up">
    <div class="flex items-center gap-2 mb-3 sm:mb-4 border-b border-muted pb-2">
      <div class="w-2 h-2 sm:w-3 sm:h-3 rounded-full bg-accent-red flex-shrink-0"></div>
      <div class="w-2 h-2 sm:w-3 sm:h-3 rounded-full bg-primary flex-shrink-0"></div>
      <div class="w-2 h-2 sm:w-3 sm:h-3 rounded-full bg-accent-magenta flex-shrink-0"></div>
      <span class="ml-auto text-[9px] sm:text-[10px] text-muted">tty1 - 80x24</span>
    </div>
    <div class="space-y-1 sm:space-y-2 overflow-hidden">
      <p class="text-primary text-xs sm:text-sm">
        <span class="typewriter-text">root@shredder:~# cat manifesto.txt</span>
      </p>
      <div class="pl-2 sm:pl-4 text-white leading-relaxed space-y-1 sm:space-y-2">
        <p class="melting-text text-xs sm:text-sm">The screen is the only window left.</p>
        <p class="melting-text text-xs sm:text-sm">We are pixels floating in a liquid crystal abyss.</p>
        <p class="melting-text text-xs sm:text-sm">Distort. Destroy. Rebuild. Repeat.</p>
      </div>
      <p class="text-primary text-xs sm:text-sm"><span class="typewriter-text">root@shredder:~# _</span></p>
    </div>
  </div>

  <!-- ASCII Block decoration -->
  <div class="ascii-block w-full max-w-4xl text-[10px] sm:text-sm overflow-hidden">
    ░▒▓█ FRACTAL CHAOS — INITIALIZING... █▓▒░
    ▓▒░ SYS:CORRUPT — AESTHETIC:MAXIMUM — VOID:OPEN ░▒▓
  </div>

  <!-- Glitch bar divider -->
  <div class="glitch-bar-static w-full max-w-4xl"></div>

  <!-- ===== POST 1 ===== -->
  <article class="fractal-card p-1 w-full max-w-4xl cursor-crosshair group chaos-rotate-n2 collage-pull-up relative z-30
                  sm:lg:-ml-20 sm:lg:translate-x-10">
    <div class="chaos-sticker sticker-magenta hidden sm:block" style="position: absolute; top: -1rem; right: -1rem; z-index: 50;">CORRUPTION_LOG_01</div>

    <div class="dark:bg-surface bg-surface-light p-4 sm:p-6 lg:p-10 h-full w-full relative overflow-hidden">
      <div class="absolute inset-0 bg-[repeating-linear-gradient(45deg,transparent,transparent_2px,rgba(255,0,0,0.05)_2px,rgba(255,0,0,0.05)_4px)] pointer-events-none"></div>
      <div class="flex flex-col gap-4 sm:gap-6">
        <div class="flex items-center gap-2 sm:gap-4 justify-between border-b-2 border-primary pb-2 flex-wrap">
          <p class="text-accent-red font-mono text-[10px] sm:text-xs tracking-widest sm:tracking-[0.5em] animate-data-bleed typewriter-text">13:37:00:VOID [TIME_ERR]</p>
          <span class="bg-primary text-black px-2 sm:px-3 py-1 text-[9px] sm:text-[10px] font-black font-mono">FRAG_ID: CLAUDE_X</span>
        </div>
        <h2 class="text-2xl sm:text-chaos-2xl glitch-intense break-words">
          <span class="chromatic-text typewriter-text melting-text" data-text="NEURAL">NEURAL</span><br />
          <span class="text-xl sm:text-chaos-xl dark:text-gray-500 text-gray-400 block mt-1 sm:mt-2 chromatic-text typewriter-text melting-text" data-text="GHOST_IN_THE_CODE">GHOST_IN_THE_CODE</span>
        </h2>
        <div class="w-full h-48 sm:h-64 lg:h-96 bg-black border-4 border-primary relative overflow-hidden group-hover:scale-[0.98] transition-transform duration-75">
          <img
            alt="Glitch art"
            class="absolute inset-0 w-full h-full object-cover mix-blend-difference filter contrast-200 grayscale group-hover:grayscale-0 group-hover:hue-rotate-180 transition-all"
            src="https://lh3.googleusercontent.com/aida-public/AB6AXuBkTJEtl77r6TKcAvFsYEciARxqr3_WHd9ucY2vKJowaUaUd8JdtNP2MFFoIyD2HiQU-sPyuSQb9SRt4HjNo4m0EY7GSGrpJ09fKfwv5aLXtpJ5csyt8KB7KqxJDzhKsS5q6sdOS9ILES2yhPWkoQ3_4h_kmAQyk8UbibaF3wInXegKFQPm0YldxDeFlN-8tnts4bcerKnmNVXenFprb0K7Aq7P2ojsyzfFX5sOdXIyC9_RpVd2JhJj-4Hi_Cf2IaV2DbIscakhShK_"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black via-transparent to-transparent opacity-60"></div>
          <div class="absolute top-2 left-2 text-[9px] sm:text-[10px] font-mono text-primary bg-black px-2 typewriter-text">STATUS: MELTING</div>
        </div>
        <div class="dark:text-gray-300 text-gray-700 font-mono text-sm sm:text-base leading-tight border-l-4 sm:border-l-8 border-accent-magenta pl-3 sm:pl-6 py-2 group-hover:translate-x-1 sm:group-hover:translate-x-2 transition-transform">
          <span class="typewriter-text whitespace-normal melting-text">Manual override initiated. The AI is no longer hallucinating; it is Dreaming in 12-bit color. We found the source of the leak in the recursive skate-loops. It tastes like copper and neon.</span>
        </div>
      </div>
    </div>
  </article>

  <!-- Chaos divider -->
  <div class="chaos-divider w-full max-w-4xl"></div>

  <!-- Data dump decoration (hidden on mobile, too wide) -->
  <div class="data-dump w-full max-w-4xl hidden sm:block overflow-hidden text-[10px] sm:text-sm">
    SYS: 0xDEAD | MEM: OVERFLOW | PTR: NULL | STACK: CORRUPT | HEAP: SHREDDED | REALITY: OPTIONAL
  </div>

  <!-- ===== POST 2 ===== -->
  <article class="fractal-card p-1 w-full max-w-4xl group chaos-rotate-2 torn-top relative z-30
                  sm:lg:self-end sm:lg:-translate-x-20">
    <div class="dark:bg-surface bg-surface-light p-4 sm:p-6 lg:p-10 h-full w-full relative overflow-hidden">
      <div class="flex flex-col gap-4 sm:gap-6">
        <div class="flex items-center gap-2 sm:gap-4 justify-between border-b-2 border-accent-magenta pb-2 flex-wrap">
          <p class="text-primary font-mono text-[10px] sm:text-xs tracking-wider typewriter-text">ERROR_LOG_NULL [SYS_TIME]</p>
          <div class="flex gap-1">
            <span class="w-2 h-2 bg-accent-red animate-ping"></span>
            <span class="w-2 h-2 bg-primary animate-ping" style="animation-delay: 0.1s"></span>
          </div>
        </div>
        <h2 class="text-2xl sm:text-chaos-2xl glitch-intense chromatic-text typewriter-text melting-text break-words" data-text="PSILOCYBIN_SHELL">
          PSILOCYBIN_SHELL
        </h2>
        <p class="dark:text-gray-400 text-gray-600 font-mono text-sm sm:text-lg italic border-r-4 sm:border-r-8 border-primary pr-3 sm:pr-6 text-right">
          <span class="typewriter-text whitespace-normal melting-text">"The root terminal is a gateway to a forest of binary trees. Each leaf is a bit, each branch a logic gate. We are the fungus spreading through the silicon."</span>
        </p>
        <div class="mt-2 sm:mt-4 bg-accent-red text-white p-3 sm:p-6 font-mono text-xs sm:text-sm overflow-hidden relative transform -skew-y-1 sm:-skew-y-2">
          <div class="absolute top-0 left-0 w-full h-full bg-black/20 animate-noise-bg"></div>
          <div class="relative z-10 space-y-1">
            <p class="typewriter-text">&gt; stack trace: infinity</p><br />
            <p class="typewriter-text">&gt; heap overflow: psychic_leakage</p><br />
            <p class="typewriter-text">&gt; terminating ego... DONE.</p>
          </div>
        </div>
      </div>
    </div>
  </article>

  <!-- Corrupt block divider -->
  <div class="corrupt-block w-full max-w-4xl"></div>

  <!-- ASCII Block -->
  <div class="ascii-block w-full max-w-4xl chaos-rotate-n1 text-[10px] sm:text-sm overflow-hidden">
    ╔══════════════════════════════╗
    ║  REALITY_SYNC: FAILED        ║
    ║  FRACTAL_DEPTH: ∞  SYS: ERR  ║
    ╚══════════════════════════════╝
  </div>

  <!-- ===== POST 3 — VOID CARD ===== -->
  <article class="fractal-card p-1 w-full max-w-4xl group chaos-rotate-n3 collage-pull-up relative z-30
                  sm:lg:translate-x-32">
    <div class="chaos-sticker sticker-acid hidden sm:block" style="position: absolute; bottom: -1rem; left: 2rem; z-index: 50;">ENTROPY_MAX</div>
    <div class="dark:bg-surface bg-surface-light p-8 sm:p-12 h-full w-full flex flex-col items-center justify-center min-h-[200px] sm:min-h-[400px]">
      <h2 class="text-4xl sm:text-chaos-2xl glitch-intense text-transparent bg-clip-text bg-gradient-to-br from-primary via-accent-magenta to-accent-red animate-glitch-rotate italic typewriter-text melting-text">
        VOID
      </h2>
      <p class="font-mono text-[10px] sm:text-xs text-muted mt-4 sm:mt-8 tracking-[0.5em] sm:tracking-[1em] animate-pulse typewriter-text text-center">REPLICATING_EXISTENCE...</p>
    </div>
  </article>

  <!-- Final chaos divider -->
  <div class="chaos-divider w-full max-w-4xl"></div>

  <!-- Footer Overload -->
  <div class="w-full max-w-3xl text-center mt-8 sm:mt-20 relative px-4">
    <div class="absolute inset-0 blur-3xl bg-primary/20 animate-pulse -z-10"></div>
    <p class="text-2xl sm:text-chaos-2xl glitch-intense text-accent-red font-black tracking-tighter animate-data-bleed mb-4 sm:mb-8 typewriter-text melting-text break-words">
      [END_OF_SIMULATION]
    </p>
    <div class="flex flex-wrap justify-center gap-1 sm:gap-2 opacity-30 font-mono text-[7px] sm:text-[8px] max-w-xs sm:max-w-md mx-auto break-all">
      01001110 01001111 01010100 01001000 01001001 01001110 01000111 💀 01001110 01001111 01010100 01001000 01001001 01001110 01000111
    </div>
  </div>

  <!-- Floating 3D Hyper-Glitch — smaller on mobile -->
  <div class="fixed bottom-20 right-4 sm:bottom-24 sm:right-6 lg:bottom-8 lg:right-8 xl:bottom-16 xl:right-16 z-[300] pointer-events-none mix-blend-screen w-16 h-16 sm:w-24 sm:h-24 lg:w-40 lg:h-40 xl:w-64 xl:h-64">
    <div class="w-full h-full relative animate-glitch-rotate filter drop-shadow-[0_0_40px_#FF00FF]">
      <img
        alt="Fractalized Core"
        class="w-full h-full object-cover mix-blend-hard-light filter contrast-[3] hue-rotate-180 brightness-200"
        src="https://lh3.googleusercontent.com/aida-public/AB6AXuD0D7n7Rm2HHJKUa4C2cZN2tAY-TSZBSrAZkHax33lOTlrVBAWoGJGhFc57twIHVVv22mawdQnG7PbNQh5wkqTxiYCniFUDGqc0JxeoufuQOQQltk5oiVay5AOQsKBGFkuHpVTD9AOQdHzsz4viQ5AYsiGub9T_RmEomEnMUrYR2zW1sHx10gmQu6RQFvk8EzRMKUjgLxaW8wNWz46tcZcMN_Lek18o3QvQU7VfeRS-81-DmOlachY4ENUbfquMBgoLbPOe5EG9PH2-"
        style="clip-path: polygon(50% 0%, 100% 38%, 82% 100%, 18% 100%, 0% 38%);"
      />
      <div class="absolute inset-0 border-[3px] sm:border-[6px] border-primary animate-ping opacity-50"></div>
      <div class="absolute inset-0 border-2 border-accent-red animate-glitch-rotate" style="animation-direction: reverse;"></div>
      <div class="absolute -inset-2 sm:-inset-4 bg-accent-magenta/20 blur-xl animate-pulse"></div>
    </div>
  </div>

</BaseLayout>
