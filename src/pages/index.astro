---
// INDEX - Fractal Chaos A — ported directly from Stitch HTML
// This is a STANDALONE page (does NOT use BaseLayout) to match the Stitch design exactly
import '../styles/global.css';
---

<html class="dark" lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>💀 CyperX.dev</title>
  <link href="https://fonts.googleapis.com" rel="preconnect" />
  <link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect" />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&display=swap" rel="stylesheet" />
</head>
<body class="font-display antialiased min-h-screen relative selection:bg-primary selection:text-black bg-[#050505] text-[#F8F8F8] overflow-x-hidden">

  <!-- ===== GLOBAL LAYERS ===== -->

  <!-- ASCII Background Noise -->
  <div class="ascii-noise animate-noise-bg">
    ERROR_CODE_404_VOID_NULL_POINTER_EXCEPTION_SEGMENTATION_FAULT_REBOOT_IMMEDIATE_01010101_SHRED_REALITY_ERROR_CODE_404_VOID_NULL_POINTER_EXCEPTION_SEGMENTATION_FAULT_REBOOT_IMMEDIATE_01010101_SHRED_REALITY
  </div>

  <!-- Fractal Overlay (skull image) -->
  <div class="fractal-overlay"></div>

  <!-- Scanline -->
  <div class="scanline-effect animate-scanline"></div>

  <!-- Mode Toggle -->
  <button
    id="luminance-toggle"
    class="fixed top-4 right-4 sm:top-6 sm:right-6 z-[200] bg-accent-red text-white px-4 sm:px-6 py-2 sm:py-3 font-mono font-black border-4 border-white hover:bg-primary hover:text-black transition-all broken-toggle shadow-[5px_5px_0px_#06f9f9] active:translate-y-1 active:shadow-none text-xs sm:text-sm"
  >
    LUMINANCE_BREACH
  </button>

  <!-- Chaotic Emojis (from Stitch exactly) -->
  <div class="fixed inset-0 pointer-events-none z-10 overflow-hidden">
    <div class="bouncing-emoji animate-float-chaotic-1" style="top: 5%; left: 5%;">💀</div>
    <div class="bouncing-emoji animate-float-chaotic-2" style="top: 55%; left: 85%;">🍄</div>
    <div class="bouncing-emoji animate-float-chaotic-3 opacity-50" style="top: 25%; left: 35%;">🏂</div>
    <div class="bouncing-emoji animate-float-chaotic-4" style="top: 75%; left: 15%;">👾</div>
    <div class="bouncing-emoji animate-float-chaotic-5" style="top: 45%; left: 65%;">🛹</div>
    <div class="bouncing-emoji animate-float-chaotic-2" style="top: 15%; left: 75%;">🤖</div>
    <div class="bouncing-emoji animate-float-chaotic-4 grayscale" style="top: 85%; left: 45%;">👽</div>
    <div class="bouncing-emoji animate-float-chaotic-3" style="top: 10%; left: 20%;">😎</div>
  </div>

  <!-- ===== MAIN LAYOUT ===== -->
  <div class="relative flex min-h-screen w-full lg:flex-row flex-col max-w-[1800px] mx-auto z-20">

    <!-- ===== NAVIGATION SIDEBAR (from Stitch) ===== -->
    <aside class="w-full lg:w-[360px] lg:fixed lg:h-screen p-6 sm:p-8 flex flex-col gap-8 sm:gap-10 z-50 bg-[#020202]/90 backdrop-blur-md lg:bg-transparent lg:backdrop-blur-none border-b-8 lg:border-b-0 border-primary">
      <div class="border-4 border-primary bg-black/80 relative overflow-hidden transform -rotate-1">
        <div class="absolute inset-0 bg-primary/10 animate-pulse pointer-events-none"></div>
        <div class="bg-primary px-4 py-2 flex items-center justify-between">
          <h1 class="text-black text-xs font-black uppercase tracking-[0.3em]">KERNEL_PANIC:shred</h1>
          <div class="flex gap-2">
            <div class="w-3 h-3 bg-black"></div>
            <div class="w-3 h-3 bg-accent-red animate-ping"></div>
          </div>
        </div>
        <div class="p-4 sm:p-6 flex flex-col gap-3 sm:gap-4 font-mono text-lg sm:text-xl">
          <a class="flex items-center gap-3 sm:gap-4 px-3 py-2 hover:bg-primary/30 group relative" href="/">
            <span class="text-primary group-hover:animate-bounce">ERR:</span>
            <span class="text-white font-black uppercase tracking-tighter chromatic-text" data-text="HOME">HOME</span>
            <div class="absolute bottom-0 left-0 w-full h-[2px] bg-accent-red scale-x-0 group-hover:scale-x-100 transition-transform origin-left"></div>
          </a>
          <a class="flex items-center gap-3 sm:gap-4 px-3 py-2 hover:bg-primary/30 group relative" href="/blog">
            <span class="text-muted group-hover:text-primary">ERR:</span>
            <span class="text-gray-400 font-black uppercase tracking-tighter chromatic-text" data-text="BLOG">BLOG</span>
          </a>
          <a class="flex items-center gap-3 sm:gap-4 px-3 py-2 hover:bg-accent-red/30 group relative" href="/projects">
            <span class="text-muted group-hover:text-accent-red">ERR:</span>
            <span class="text-gray-400 font-black uppercase tracking-tighter chromatic-text" data-text="PROJECTS">PROJECTS</span>
          </a>
        </div>
      </div>

      <!-- System Info (desktop only) -->
      <div class="hidden lg:block mt-auto pb-12">
        <div class="text-primary font-mono text-[10px] leading-none space-y-1 p-4 border-l-4 border-accent-magenta bg-black/40 animate-data-bleed">
          <p>MEMORY_ADDR: 0xDEADBEEF</p>
          <p>BUFFER_OVERFLOW: DETECTED</p>
          <p>REALITY_SYNC: DISCONNECTED</p>
          <p class="text-white bg-accent-red inline-block px-1">SYSTEM_SHREDDING...</p>
        </div>
      </div>
    </aside>

    <!-- ===== MAIN CONTENT ===== -->
    <main class="flex-1 lg:ml-[360px] p-4 sm:p-6 lg:p-16 xl:p-24 relative overflow-hidden flex flex-col items-center gap-16 sm:gap-24 lg:gap-40 pt-12 sm:pt-20 lg:pt-40 pb-40 sm:pb-64">

      <!-- Terminal Header -->
      <div class="w-full max-w-4xl border-4 border-primary bg-black p-3 sm:p-4 font-mono mb-6 sm:mb-12 transform -rotate-1 relative z-30">
        <div class="flex items-center gap-2 mb-3 sm:mb-4 border-b border-muted pb-2">
          <div class="w-2 h-2 sm:w-3 sm:h-3 rounded-full bg-accent-red"></div>
          <div class="w-2 h-2 sm:w-3 sm:h-3 rounded-full bg-primary"></div>
          <div class="w-2 h-2 sm:w-3 sm:h-3 rounded-full bg-accent-magenta"></div>
          <span class="ml-auto text-[9px] sm:text-[10px] text-muted">tty1 - 80x24</span>
        </div>
        <div class="space-y-1 sm:space-y-2">
          <p class="text-primary text-xs sm:text-sm"><span class="typewriter-text">root@shredder:~# cat manifesto.txt</span></p>
          <div class="pl-2 sm:pl-4 text-white leading-relaxed space-y-1 sm:space-y-2">
            <p class="text-xs sm:text-base">The screen is the only window left.</p>
            <p class="text-xs sm:text-base">We are pixels floating in a liquid crystal abyss.</p>
            <p class="text-xs sm:text-base">Distort. Destroy. Rebuild. Repeat.</p>
          </div>
          <p class="text-primary text-xs sm:text-sm"><span class="typewriter-text">root@shredder:~# _</span></p>
        </div>
      </div>

      <!-- ===== POST 1 — NEURAL / GHOST_IN_THE_CODE ===== -->
      <article class="post-card p-1 cursor-crosshair group lg:-ml-20 lg:translate-x-10">
        <div class="absolute -top-4 -right-4 sm:-top-6 sm:-right-6 bg-accent-magenta text-white px-3 sm:px-4 py-1 sm:py-2 font-mono text-[10px] sm:text-sm font-black uppercase z-30 shadow-[4px_4px_0px_#000] rotate-3 animate-pulse">
          CORRUPTION_LOG_01
        </div>
        <div class="bg-[#0a0a0a] border-4 border-muted/50 p-4 sm:p-6 lg:p-10 h-full w-full relative overflow-hidden">
          <div class="absolute inset-0 bg-[repeating-linear-gradient(45deg,transparent,transparent_2px,rgba(255,0,0,0.05)_2px,rgba(255,0,0,0.05)_4px)] pointer-events-none"></div>
          <div class="flex flex-col gap-4 sm:gap-6">
            <div class="flex items-center gap-2 sm:gap-4 justify-between border-b-2 border-primary pb-2 flex-wrap">
              <p class="text-accent-red font-mono text-[10px] sm:text-xs tracking-widest sm:tracking-[0.5em] animate-data-bleed typewriter-text">13:37:00:VOID [TIME_ERR]</p>
              <span class="bg-primary text-black px-2 sm:px-3 py-1 text-[9px] sm:text-[10px] font-black font-mono">FRAG_ID: CLAUDE_X</span>
            </div>
            <h2 class="text-3xl sm:text-4xl lg:text-6xl font-black uppercase leading-[0.85] tracking-tighter text-white group-hover:text-primary transition-colors italic">
              <span class="chromatic-text typewriter-text" data-text="NEURAL">NEURAL</span><br />
              <span class="text-2xl sm:text-3xl lg:text-5xl text-gray-500 block mt-2 chromatic-text typewriter-text" data-text="GHOST_IN_THE_CODE">GHOST_IN_THE_CODE</span>
            </h2>
            <div class="w-full h-48 sm:h-64 lg:h-96 bg-black border-4 border-primary relative overflow-hidden group-hover:scale-[0.98] transition-transform duration-75">
              <img
                alt="Glitch art"
                class="absolute inset-0 w-full h-full object-cover mix-blend-difference filter contrast-200 grayscale group-hover:grayscale-0 group-hover:hue-rotate-180 transition-all"
                src="https://lh3.googleusercontent.com/aida-public/AB6AXuBkTJEtl77r6TKcAvFsYEciARxqr3_WHd9ucY2vKJowaUaUd8JdtNP2MFFoIyD2HiQU-sPyuSQb9SRt4HjNo4m0EY7GSGrpJ09fKfwv5aLXtpJ5csyt8KB7KqxJDzhKsS5q6sdOS9ILES2yhPWkoQ3_4h_kmAQyk8UbibaF3wInXegKFQPm0YldxDeFlN-8tnts4bcerKnmNVXenFprb0K7Aq7P2ojsyzfFX5sOdXIyC9_RpVd2JhJj-4Hi_Cf2IaV2DbIscakhShK_"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black via-transparent to-transparent opacity-60"></div>
              <div class="absolute top-2 left-2 text-[9px] sm:text-[10px] font-mono text-primary bg-black px-2 typewriter-text">STATUS: MELTING</div>
            </div>
            <div class="text-gray-300 font-mono text-sm sm:text-base leading-tight border-l-4 sm:border-l-8 border-accent-magenta pl-3 sm:pl-6 py-2 group-hover:translate-x-1 sm:group-hover:translate-x-2 transition-transform">
              <span class="typewriter-text whitespace-normal">Manual override initiated. The AI is no longer hallucinating; it is Dreaming in 12-bit color. We found the source of the leak in the recursive skate-loops. It tastes like copper and neon.</span>
            </div>
          </div>
        </div>
      </article>

      <!-- ===== POST 2 — PSILOCYBIN_SHELL ===== -->
      <article class="post-card p-1 group lg:self-end lg:-translate-x-20 rotate-1">
        <div class="bg-[#0a0a0a] border-4 border-primary p-4 sm:p-6 lg:p-10 h-full w-full relative overflow-hidden">
          <div class="flex flex-col gap-4 sm:gap-6">
            <div class="flex items-center gap-2 sm:gap-4 justify-between border-b-2 border-accent-magenta pb-2 flex-wrap">
              <p class="text-primary font-mono text-[10px] sm:text-xs tracking-wider typewriter-text">ERROR_LOG_NULL [SYS_TIME]</p>
              <div class="flex gap-1">
                <span class="w-2 h-2 bg-accent-red animate-ping"></span>
                <span class="w-2 h-2 bg-primary animate-ping" style="animation-delay: 0.1s"></span>
              </div>
            </div>
            <h2 class="text-3xl sm:text-4xl lg:text-6xl font-black uppercase leading-none tracking-tighter text-white chromatic-text typewriter-text" data-text="PSILOCYBIN_SHELL">
              PSILOCYBIN_SHELL
            </h2>
            <p class="text-gray-400 font-mono text-sm sm:text-lg italic border-r-4 sm:border-r-8 border-primary pr-3 sm:pr-6 text-right">
              <span class="typewriter-text whitespace-normal">"The root terminal is a gateway to a forest of binary trees. Each leaf is a bit, each branch a logic gate. We are the fungus spreading through the silicon."</span>
            </p>
            <div class="mt-2 sm:mt-4 bg-accent-red text-white p-3 sm:p-6 font-mono text-xs sm:text-sm overflow-hidden relative transform -skew-y-1 sm:-skew-y-2">
              <div class="absolute top-0 left-0 w-full h-full bg-black/20 animate-noise-bg"></div>
              <div class="relative z-10 space-y-1">
                <p class="typewriter-text">&gt; stack trace: infinity</p><br />
                <p class="typewriter-text">&gt; heap overflow: psychic_leakage</p><br />
                <p class="typewriter-text">&gt; terminating ego... DONE.</p>
              </div>
            </div>
          </div>
        </div>
      </article>

      <!-- ===== POST 3 — VOID ===== -->
      <article class="post-card p-1 group lg:translate-x-32 -rotate-2">
        <div class="bg-[#0a0a0a] border-8 border-double border-accent-magenta p-8 sm:p-12 h-full w-full flex flex-col items-center justify-center min-h-[250px] sm:min-h-[400px] relative">
          <h2 class="text-5xl sm:text-7xl lg:text-9xl font-black text-transparent bg-clip-text bg-gradient-to-br from-primary via-accent-magenta to-accent-red animate-glitch-rotate italic typewriter-text">
            VOID
          </h2>
          <p class="font-mono text-[10px] sm:text-xs text-muted mt-6 sm:mt-8 tracking-[0.5em] sm:tracking-[1em] animate-pulse typewriter-text text-center">REPLICATING_EXISTENCE...</p>
        </div>
      </article>

      <!-- Footer Overload -->
      <div class="w-full max-w-[800px] text-center mt-12 sm:mt-20 relative">
        <div class="absolute inset-0 blur-3xl bg-primary/20 animate-pulse -z-10"></div>
        <p class="font-mono text-accent-red font-black text-2xl sm:text-4xl lg:text-6xl tracking-tighter animate-data-bleed mb-4 sm:mb-8 typewriter-text break-words">
          [END_OF_SIMULATION]
        </p>
        <div class="flex flex-wrap justify-center gap-1 sm:gap-2 opacity-30 font-mono text-[7px] sm:text-[8px] max-w-md mx-auto break-all">
          01001110 01001111 01010100 01001000 01001001 01001110 01000111 00100000 01001001 01010011 00100000 01010010 01000101 01000001 01001100 00100000 01001001 01001110 00100000 01010100 01001000 01000101 00100000 01010111 01001111 01001001 01000100
        </div>
      </div>
    </main>

    <!-- Floating 3D Hyper-Glitch -->
    <div class="fixed bottom-20 right-4 sm:bottom-8 sm:right-8 lg:bottom-16 lg:right-16 z-[300] pointer-events-none mix-blend-screen w-20 h-20 sm:w-40 sm:h-40 lg:w-64 lg:h-64">
      <div class="w-full h-full relative animate-glitch-rotate filter drop-shadow-[0_0_40px_#FF00FF]">
        <img
          alt="Fractalized Core"
          class="w-full h-full object-cover mix-blend-hard-light filter contrast-[3] hue-rotate-180 brightness-200"
          src="https://lh3.googleusercontent.com/aida-public/AB6AXuD0D7n7Rm2HHJKUa4C2cZN2tAY-TSZBSrAZkHax33lOTlrVBAWoGJGhFc57twIHVVv22mawdQnG7PbNQh5wkqTxiYCniFUDGqc0JxeoufuQOQQltk5oiVay5AOQsKBGFkuHpVTD9AOQdHzsz4viQ5AYsiGub9T_RmEomEnMUrYR2zW1sHx10gmQu6RQFvk8EzRMKUjgLxaW8wNWz46tcZcMN_Lek18o3QvQU7VfeRS-81-DmOlachY4ENUbfquMBgoLbPOe5EG9PH2-"
          style="clip-path: polygon(50% 0%, 100% 38%, 82% 100%, 18% 100%, 0% 38%);"
        />
        <div class="absolute inset-0 border-[3px] sm:border-[6px] border-primary animate-ping opacity-50"></div>
        <div class="absolute inset-0 border-2 border-accent-red animate-glitch-rotate" style="animation-direction: reverse;"></div>
        <div class="absolute -inset-2 sm:-inset-4 bg-accent-magenta/20 blur-xl animate-pulse"></div>
      </div>
    </div>
  </div>

  <script>
    // LUMINANCE_BREACH toggle
    document.getElementById('luminance-toggle')?.addEventListener('click', () => {
      document.documentElement.classList.toggle('dark');
      document.documentElement.classList.toggle('light');
    });
  </script>
</body>
</html>
