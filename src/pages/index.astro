<script>
  // ── CHAOS SCROLL SYSTEM ──
  // Every element gets a unique entrance from a 26-entry pool.
  // Seed is deterministic so SSR/CSR stay consistent.

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // [initTransform, finalTransform, duration(s), easing]
  type E = [string, string, number, string];
  const POOL: E[] = [
    ['translateY(90px)',                                         'none',                           0.60, 'cubic-bezier(.17,.67,.4,1.1)'],
    ['translateX(-120px)',                                       'none',                           0.55, 'cubic-bezier(.25,.46,.45,.94)'],
    ['translateX(130px)',                                        'none',                           0.55, 'cubic-bezier(.25,.46,.45,.94)'],
    ['translateY(-100px)',                                       'none',                           0.52, 'ease-out'],
    ['translate(-100px,-80px)',                                  'none',                           0.65, 'cubic-bezier(.17,.67,.4,1.1)'],
    ['translate(100px,-80px)',                                   'none',                           0.65, 'cubic-bezier(.17,.67,.4,1.1)'],
    ['translate(-100px,80px)',                                   'none',                           0.65, 'ease-out'],
    ['translate(110px,70px)',                                    'none',                           0.65, 'ease-out'],
    ['scale(0.55)',                                              'none',                           0.52, 'cubic-bezier(.34,1.56,.64,1)'],
    ['scale(0.72) rotate(-12deg)',                               'none',                           0.62, 'cubic-bezier(.34,1.56,.64,1)'],
    ['perspective(700px) rotateX(32deg) translateY(55px)',       'perspective(700px) rotateX(0)',  0.72, 'cubic-bezier(.17,.67,.4,1.1)'],
    ['perspective(700px) rotateY(-42deg) translateX(65px)',      'perspective(700px) rotateY(0)',  0.72, 'cubic-bezier(.25,.46,.45,.94)'],
    ['perspective(700px) rotateY(42deg) translateX(-65px)',      'perspective(700px) rotateY(0)',  0.72, 'cubic-bezier(.25,.46,.45,.94)'],
    ['skewX(-28deg) translateX(-80px)',                          'skewX(0)',                       0.55, 'ease-out'],
    ['skewX(28deg) translateX(80px)',                            'skewX(0)',                       0.55, 'ease-out'],
    ['skewY(-20deg) translateY(-55px)',                          'skewY(0)',                       0.58, 'ease-out'],
    ['skewY(20deg) translateY(55px)',                            'skewY(0)',                       0.58, 'ease-out'],
    ['scale(1.45)',                                              'none',                           0.50, 'ease-out'],
    ['scale(0.45) translateY(130px)',                            'none',                           0.85, 'cubic-bezier(.34,1.56,.64,1)'],
    ['rotate(-18deg) translateX(-90px)',                         'rotate(0)',                      0.68, 'cubic-bezier(.34,1.56,.64,1)'],
    ['rotate(18deg) translateX(90px)',                           'rotate(0)',                      0.68, 'cubic-bezier(.34,1.56,.64,1)'],
    ['translateX(-170px) scale(0.8)',                            'none',                           0.95, 'cubic-bezier(.25,.46,.45,.94)'],
    ['translateX(170px) scale(0.8)',                             'none',                           0.95, 'cubic-bezier(.25,.46,.45,.94)'],
    ['translateY(-120px) scale(0.88)',                           'none',                           0.74, 'cubic-bezier(.17,.67,.4,1.1)'],
    ['perspective(900px) rotateX(-26deg) translateY(-70px)',     'perspective(900px) rotateX(0)',  0.70, 'ease-out'],
    ['scale(0.78) skewX(-15deg) translateX(-55px)',              'skewX(0)',                       0.70, 'cubic-bezier(.34,1.56,.64,1)'],
  ];

  // Deterministic pick — different for every seed value
  function pick(seed: number): E { return POOL[(seed * 7 + 11) % POOL.length]; }

  function animateIn(el: HTMLElement, seed: number) {
    if (prefersReducedMotion) return;
    const [init, final, dur] = pick(seed);
    el.style.opacity = '0';
    el.style.transform = init;
    el.style.transition = 'none';

    const obs = new IntersectionObserver(entries => {
      entries.forEach(e => {
        if (!e.isIntersecting) return;
        const t = e.target as HTMLElement;
        // rAF to ensure 'none' transition applied before starting
        requestAnimationFrame(() => requestAnimationFrame(() => {
          const [, fin, d, ease] = pick(parseInt(t.dataset.aSeed ?? '0'));
          t.style.transition = `opacity ${d}s ${ease}, transform ${d}s ${ease}`;
          t.style.opacity = '1';
          t.style.transform = fin;
          // clean up so hover/Tailwind transitions still work
          setTimeout(() => { t.style.transition = ''; t.style.transform = ''; }, d * 1000 + 80);
        }));
        obs.unobserve(t);
      });
    }, { threshold: 0.07, rootMargin: '0px 0px -30px 0px' });
    obs.observe(el);
  }

  let s = 0;

  // Project cards
  document.querySelectorAll<HTMLElement>('.project-card').forEach(el => { el.dataset.aSeed = String(s); animateIn(el, s++); });

  // Blog cards
  document.querySelectorAll<HTMLElement>('.blog-card').forEach(el => { el.dataset.aSeed = String(s); animateIn(el, s++); });

  // Stat cards + count-up
  document.querySelectorAll<HTMLElement>('.stat-card').forEach(el => {
    el.dataset.aSeed = String(s);
    animateIn(el, s++);
    // count-up fires separately after element is visible
    const numEl = el.querySelector<HTMLElement>('div:first-child');
    if (numEl) {
      const raw = numEl.textContent?.trim() ?? '';
      const n = parseInt(raw);
      if (!isNaN(n) && n > 0 && n < 20) {
        const obs2 = new IntersectionObserver(entries => {
          entries.forEach(e => {
            if (!e.isIntersecting) return;
            let cur = 0;
            const step = () => { cur++; numEl.textContent = String(cur); if (cur < n) setTimeout(step, 80); };
            setTimeout(step, 200);
            obs2.unobserve(e.target);
          });
        }, { threshold: 0.3 });
        obs2.observe(el);
      }
    }
  });

  // Section label rows (the "PROJECTS" / "LATEST POSTS" header rows)
  document.querySelectorAll<HTMLElement>('section > .\!px-4, section > .px-4').forEach(el => {
    // only top-level wrappers with label text, not card grids
    const header = el.querySelector<HTMLElement>(':scope > div.flex, :scope > .flex');
    if (header && !header.closest('.project-card') && !header.closest('.blog-card')) {
      header.dataset.aSeed = String(s);
      animateIn(header, s++);
    }
  });

  // Marquee strip
  const marquee = document.querySelector<HTMLElement>('.marquee-strip');
  if (marquee) { marquee.dataset.aSeed = String(s); animateIn(marquee, s++); }

  // ── Catch-all: animate every visible text block not already covered ──
  const alreadyAnimated = new Set(document.querySelectorAll('[data-a-seed]'));
  document.querySelectorAll<HTMLElement>('section > *, .variant-dark main > section, .variant-light main > section, .variant-extreme main > section').forEach(el => {
    if (alreadyAnimated.has(el)) return;
    // Skip grid containers (they hold already-animated children)
    if (el.querySelector('.project-card, .blog-card, .stat-card')) return;
    // Only animate meaningful blocks (headings, paragraphs, section headers)
    const tag = el.tagName;
    if (tag === 'SECTION' || tag === 'DIV' || tag === 'H2' || tag === 'P') {
      el.dataset.aSeed = String(s);
      animateIn(el, s++);
    }
  });
  // Hero text paragraphs + taglines
  document.querySelectorAll<HTMLElement>('section p, section h2, section .flex.items-baseline').forEach(el => {
    if (el.dataset.aSeed) return;
    if (el.closest('.project-card, .blog-card, .stat-card')) return;
    el.dataset.aSeed = String(s);
    animateIn(el, s++);
  });

  // ── Parallax images — unique rate + direction per image ──
  // [parallax_rate, vertical_bias] — some images also drift horizontally
  const PAR: Array<[number, number]> = [
    [0.12,  0], [0.24,  0], [0.08,  0],
    [0.20,  0], [0.30,  0], [0.15,  0],
  ];
  const jagWraps = Array.from(document.querySelectorAll<HTMLElement>('.jag-img-wrap'));
  function updateParallax() {
    jagWraps.forEach((wrap, idx) => {
      const [rate] = PAR[idx % PAR.length];
      const rect = wrap.getBoundingClientRect();
      const offset = (rect.top + rect.height / 2 - window.innerHeight / 2) * rate;
      const img = wrap.querySelector<HTMLElement>('img');
      if (img) img.style.transform = `translateY(${offset}px) scale(1.16)`;
    });
  }
  window.addEventListener('scroll', updateParallax, { passive: true });
  updateParallax();

  // ── Scroll velocity → jag stroke speed ──
  let lastScrollY = window.scrollY;
  function tickStrokes() {
    const vel = Math.abs(window.scrollY - lastScrollY);
    lastScrollY = window.scrollY;
    if (vel > 3) {
      const spd = Math.max(0.3, 5 - vel * 0.12).toFixed(2);
      document.querySelectorAll<SVGElement>('.jag-stroke-outer,.jag-stroke-inner,.card-jag-outer,.card-jag-inner')
        .forEach(el => { el.style.animationDuration = `${spd}s`; });
    }
    requestAnimationFrame(tickStrokes);
  }
  tickStrokes();

  // Section reveal class fallback
  document.querySelectorAll('[data-reveal-section]').forEach(section => {
    const obs = new IntersectionObserver(entries => {
      entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('is-visible'); obs.unobserve(e.target); } });
    }, { threshold: 0.05 });
    obs.observe(section);
  });

  // ── Extreme theme: boost animation intensity ──
  (function() {
    function isExtreme() {
      const root = document.documentElement;
      return root.dataset.theme === 'extreme' || root.classList.contains('theme-extreme') ||
             !!document.querySelector('.variant-extreme')?.offsetParent;
    }
    if (!isExtreme()) return;
    // Add extra CSS class to push extreme animations further
    document.body.classList.add('x-mode-active');
    // Speed up all jag stroke animations
    document.querySelectorAll<SVGElement>('.jag-stroke-outer,.jag-stroke-inner,.card-jag-outer,.card-jag-inner')
      .forEach(el => { el.style.animationDuration = '1.5s'; });
    // Random subtle positional drift on each card continuously
    const driftCards = Array.from(document.querySelectorAll<HTMLElement>('.variant-extreme .project-card, .variant-extreme .blog-card'));
    driftCards.forEach((card, i) => {
      const delay = i * 0.4;
      const dur = 3.5 + (i % 3) * 0.8;
      card.style.animation = (card.style.animation || '') + `, x-float-drift ${dur}s ${delay}s ease-in-out infinite`;
    });
  })();

  // ── Starfield canvas (extreme variant) ──
  const canvas = document.getElementById('starfield') as HTMLCanvasElement | null;
  if (canvas && document.querySelector('.variant-extreme')?.closest('body') !== null) {
    const ctx = canvas.getContext('2d');
    if (ctx) {
      let w = canvas.width = window.innerWidth;
      let h = canvas.height = window.innerHeight;
      window.addEventListener('resize', () => {
        w = canvas.width = window.innerWidth;
        h = canvas.height = window.innerHeight;
      });

      const stars = Array.from({ length: 200 }, () => ({
        x: Math.random() * w,
        y: Math.random() * h,
        r: Math.random() * 1.5 + 0.3,
        speed: Math.random() * 0.4 + 0.05,
        alpha: Math.random() * 0.6 + 0.1,
        color: Math.random() > 0.8 ? '#8eff71' : Math.random() > 0.5 ? '#ff51fa' : '#ffffff',
      }));

      function drawStars() {
        if (!ctx) return;
        ctx.clearRect(0, 0, w, h);
        stars.forEach(s => {
          ctx.beginPath();
          ctx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
          ctx.fillStyle = s.color;
          ctx.globalAlpha = s.alpha;
          ctx.fill();
          s.y += s.speed;
          if (s.y > h) { s.y = 0; s.x = Math.random() * w; }
        });
        ctx.globalAlpha = 1;
        requestAnimationFrame(drawStars);
      }
      // Only run starfield when extreme variant is active
      if (document.documentElement.dataset.theme === 'extreme' || document.documentElement.classList.contains('theme-extreme')) {
        drawStars();
      }
      // Listen for theme changes
      const themeObs = new MutationObserver(() => {
        const root = document.documentElement;
        if (root.dataset.theme === 'extreme' || root.classList.contains('theme-extreme')) {
          drawStars();
        }
      });
      themeObs.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme', 'class'] });
    }
  }
</script>
