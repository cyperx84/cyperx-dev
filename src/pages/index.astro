---
import BaseLayout from '../layouts/BaseLayout.astro';
import { projects } from '../data/projects';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const posts = allPosts
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 2);
---

<BaseLayout title="CYPERX.DEV" activeNav="home">

  <!-- ════════════════════════════════════════
       DARK VARIANT
  ════════════════════════════════════════ -->
  <div class="variant-dark bg-transparent text-[#e2e2e2] min-h-screen overflow-x-hidden">

    <!-- Ambient orbs -->
    <div aria-hidden="true" class="fixed inset-0 pointer-events-none overflow-hidden z-0">
      <div class="orb orb-1"></div>
      <div class="orb orb-2"></div>
      <div class="orb orb-3"></div>
    </div>

    <main class="relative z-10 pt-28 sm:pt-36 pb-24 space-y-28 sm:space-y-48">

      <!-- ── HERO ── -->
      <section class="px-4 sm:px-6 max-w-7xl mx-auto">
        <p class="hero-sub font-mono text-[#39FF14] text-xs sm:text-sm tracking-[0.5em] mb-6">BRISBANE, AU // BUILDER // SHIPS DAILY</p>
        <h1 class="hero-title text-[18vw] sm:text-[14vw] lg:text-[12vw] font-black italic tracking-tighter leading-none pb-2 overflow-visible">
          <span class="block bg-clip-text text-transparent bg-gradient-to-r from-[#39FF14] via-[#AC89FF] to-[#FF51FA] pr-2">CYPERX</span>
        </h1>
        <p class="hero-desc max-w-2xl text-[#baccb0] text-base sm:text-xl leading-relaxed mt-4 mb-10">
          I build tools and systems that compound. Right now: AI agent fleets, automation pipelines, and whatever plumbing keeps the whole thing running — all orchestrated from an M4 Mac Mini and a phone.
        </p>
        <div class="hero-cta flex flex-wrap gap-4">
          <a href="/projects" class="bg-[#39FF14] text-black px-8 py-3 font-black text-sm uppercase tracking-widest hover:scale-105 hover:bg-[#FF51FA] hover:text-white transition-all" style="clip-path:polygon(0 0,100% 0,95% 100%,5% 95%)">PROJECTS</a>
          <a href="/blog" class="border-2 border-[#FF51FA]/40 text-[#FF51FA] px-8 py-3 font-black text-sm uppercase tracking-widest hover:border-[#FF51FA] hover:bg-[#FF51FA]/10 transition-all" style="clip-path:polygon(2% 5%,100% 0,98% 95%,0 100%)">BLOG</a>
          <a href="/about" class="border-2 border-[#AC89FF]/30 text-[#AC89FF] px-8 py-3 font-black text-sm uppercase tracking-widest hover:border-[#AC89FF] hover:bg-[#AC89FF]/10 transition-all">ABOUT</a>
        </div>
      </section>

      <!-- ── MARQUEE TICKER ── -->
      <div class="marquee-strip border-y border-[#39FF14]/20 py-3 overflow-hidden bg-[#39FF14]/5" aria-hidden="true">
        <div class="marquee-inner whitespace-nowrap font-mono text-xs tracking-widest text-[#39FF14]/70">
          {Array(3).fill([
            "CYPERX.DEV", "CHANGELOGS.INFO", "DOTFILES", "M4 MAC MINI",
            "CLAUDE CODE", "CODEX", "OPENCLAW", "NEOVIM", "TMUX", "GHOSTTY",
            "AGENT FLEET ONLINE", "SHIPS DAILY", "BRISBANE AU",
          ]).flat().map((t, i) => (
            <span class="inline-block px-8">{t} <span class="text-[#FF51FA]/50">·</span></span>
          ))}
        </div>
      </div>

      <!-- ── PROJECTS ── -->
      <section class="px-4 sm:px-6 max-w-7xl mx-auto" data-reveal-section>
        <div class="flex items-baseline gap-4 mb-12 flex-wrap">
          <p class="font-mono text-[10px] text-[#39FF14]/60 tracking-[0.5em]">PROJECTS</p>
          <div class="h-px flex-grow bg-[#39FF14]/10"></div>
          <a href="/projects" class="font-mono text-[10px] text-[#e2e2e2]/40 hover:text-[#39FF14] tracking-widest transition-colors">ALL →</a>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 sm:gap-8">
          {projects.map((p, i) => {
            const accent = ["#39FF14", "#FF51FA", "#AC89FF"][i];
            return (
              <a href={`/projects/${p.slug}`} class="project-card group block no-underline bg-[#0e0e0e] hover:bg-[#161616] transition-colors border border-[#e2e2e2]/5 hover:border-[#e2e2e2]/15 overflow-hidden">
                {p.image && (
                  <div class="overflow-hidden" style="height:160px;">
                    <img src={p.image} alt={p.name} style={`width:100%; height:100%; object-fit:cover; opacity:0.7; transition:opacity 0.4s,transform 0.6s; display:block;`} class="group-hover:opacity-90 group-hover:scale-105" />
                  </div>
                )}
                <div class="p-5 sm:p-6">
                  <div class="flex items-center justify-between mb-3">
                    <span class="font-mono text-[10px] px-2 py-0.5 font-black" style={`background:${accent}; color:black`}>{p.status}</span>
                    <span class="font-mono text-[10px] text-[#e2e2e2]/30">E:{p.entropy}%</span>
                  </div>
                  <h3 class="text-lg font-black italic tracking-tight mb-2 transition-colors" style={`color:${accent}`}>{p.name}</h3>
                  <p class="text-[#baccb0] text-xs leading-relaxed mb-4">{p.tagline}</p>
                  <div class="flex gap-2 flex-wrap">
                    {p.stack.slice(0, 3).map(t => (
                      <span class="font-mono text-[9px] text-[#e2e2e2]/25 bg-[#1f1f1f] px-2 py-1">{t}</span>
                    ))}
                  </div>
                </div>
              </a>
            );
          })}
        </div>
      </section>

      <!-- ── STAT ROW ── -->
      <section class="px-4 sm:px-6 max-w-7xl mx-auto">
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-px bg-[#e2e2e2]/5">
          {[
            { n: "3", label: "LIVE PROJECTS" },
            { n: "4", label: "AI AGENTS" },
            { n: "M4", label: "MAC MINI" },
            { n: "∞", label: "COMPOUNDING" },
          ].map(s => (
            <div class="stat-card bg-[#0e0e0e] p-8 sm:p-10 text-center hover:bg-[#161616] transition-colors">
              <div class="text-4xl sm:text-6xl font-black italic text-[#39FF14] mb-2 stat-number">{s.n}</div>
              <div class="font-mono text-[10px] text-[#e2e2e2]/30 tracking-widest">{s.label}</div>
            </div>
          ))}
        </div>
      </section>

      <!-- ── BLOG ── -->
      <section class="px-4 sm:px-6 max-w-7xl mx-auto" data-reveal-section>
        <div class="flex items-baseline gap-4 mb-12 flex-wrap">
          <p class="font-mono text-[10px] text-[#FF51FA]/60 tracking-[0.5em]">LATEST POSTS</p>
          <div class="h-px flex-grow bg-[#FF51FA]/10"></div>
          <a href="/blog" class="font-mono text-[10px] text-[#e2e2e2]/40 hover:text-[#FF51FA] tracking-widest transition-colors">ALL →</a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 sm:gap-8">
          {posts.map((post, i) => {
            const accent = ["#FF51FA", "#AC89FF"][i];
            return (
              <a href={`/blog/${post.data.slug}`} class="blog-card group block no-underline bg-[#0e0e0e] border border-[#e2e2e2]/5 hover:border-[#e2e2e2]/15 p-6 sm:p-8 hover:bg-[#161616] transition-colors overflow-hidden">
                <div class="flex items-center justify-between mb-5">
                  <span class="font-mono text-[10px] px-2 py-0.5 font-black" style={`background:${accent}20; color:${accent}; border:1px solid ${accent}40`}>{post.data.category}</span>
                  <span class="font-mono text-[10px] text-[#e2e2e2]/25">{post.data.readTime}</span>
                </div>
                <h3 class="text-lg sm:text-xl font-black italic tracking-tight leading-snug mb-3 group-hover:text-[#e2e2e2] transition-colors" style={`color:${accent}`}>{post.data.title}</h3>
                <p class="text-[#baccb0] text-sm leading-relaxed mb-6">{post.data.excerpt}</p>
                <div class="flex items-center justify-between">
                  <div class="flex gap-2 flex-wrap">
                    {post.data.tags.slice(0, 3).map((t: string) => (
                      <span class="font-mono text-[9px] text-[#e2e2e2]/25">{t}</span>
                    ))}
                  </div>
                  <span class="font-mono text-[10px]" style={`color:${accent}`}>SIGNAL: {post.data.signal}</span>
                </div>
              </a>
            );
          })}
        </div>
      </section>

    </main>
  </div>


  <!-- ════════════════════════════════════════
       LIGHT VARIANT
  ════════════════════════════════════════ -->
  <div class="variant-light bg-white/90 text-[#131313] min-h-screen overflow-x-hidden">
    <main class="pt-28 sm:pt-36 pb-24 space-y-24">

      <!-- Hero -->
      <section class="px-4 sm:px-6 max-w-7xl mx-auto">
        <p class="font-mono text-[#FF51FA] text-xs tracking-[0.5em] mb-6">BRISBANE, AU // BUILDER // SHIPS DAILY</p>
        <h1 class="text-[16vw] sm:text-[12vw] font-black italic tracking-tighter leading-none pb-2 overflow-visible">
          <span class="block bg-clip-text text-transparent bg-gradient-to-r from-[#FF51FA] via-[#AC89FF] to-[#39FF14] pr-2">CYPERX</span>
        </h1>
        <p class="max-w-2xl text-[#555] text-base sm:text-xl leading-relaxed mt-4 mb-10">
          I build tools and systems that compound. Right now: AI agent fleets, automation pipelines, and whatever plumbing keeps the whole thing running.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="/projects" class="bg-[#FF51FA] text-white px-8 py-3 font-black text-sm uppercase tracking-widest hover:bg-[#39FF14] hover:text-black transition-all" style="clip-path:polygon(0 0,100% 0,95% 100%,5% 95%)">PROJECTS</a>
          <a href="/blog" class="border-2 border-[#131313] text-[#131313] px-8 py-3 font-black text-sm uppercase tracking-widest hover:bg-[#131313] hover:text-white transition-all">BLOG</a>
        </div>
      </section>

      <!-- Marquee -->
      <div class="marquee-strip border-y border-[#FF51FA]/20 py-3 overflow-hidden bg-[#FF51FA]/5" aria-hidden="true">
        <div class="marquee-inner whitespace-nowrap font-mono text-xs tracking-widest text-[#FF51FA]/70">
          {Array(3).fill(["CYPERX.DEV","CHANGELOGS.INFO","DOTFILES","M4 MAC MINI","CLAUDE CODE","CODEX","OPENCLAW","NEOVIM","AGENT FLEET"]).flat().map((t, i) => (
            <span class="inline-block px-8">{t} <span class="text-[#131313]/20">·</span></span>
          ))}
        </div>
      </div>

      <!-- Projects -->
      <section class="px-4 sm:px-6 max-w-7xl mx-auto">
        <div class="flex items-baseline gap-4 mb-10 border-b-2 border-[#131313] pb-4">
          <h2 class="text-3xl font-black italic tracking-tighter">PROJECTS</h2>
          <a href="/projects" class="ml-auto font-mono text-xs text-[#FF51FA] hover:text-[#39FF14] transition-colors">VIEW ALL →</a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {projects.map((p, i) => {
            const accent = ["#39FF14", "#FF51FA", "#AC89FF"][i];
            return (
              <a href={`/projects/${p.slug}`} class="group block no-underline bg-white border-2 border-[#131313] hover:border-[#FF51FA] overflow-hidden transition-colors" style={`border-bottom:4px solid ${accent}`}>
                {p.image && (
                  <div style="height:140px; overflow:hidden;">
                    <img src={p.image} alt={p.name} style="width:100%;height:100%;object-fit:cover;display:block;transition:transform 0.5s;" class="group-hover:scale-105" />
                  </div>
                )}
                <div class="p-5">
                  <span class="font-mono text-[9px] font-black" style={`color:${accent}`}>{p.status}</span>
                  <h3 class="text-base font-black italic mt-1 mb-2">{p.name}</h3>
                  <p class="text-xs text-[#555]">{p.tagline}</p>
                </div>
              </a>
            );
          })}
        </div>
      </section>

      <!-- Stats -->
      <section class="px-4 sm:px-6 max-w-7xl mx-auto">
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-6">
          {[
            { n: "3", label: "LIVE PROJECTS", c: "#39FF14" },
            { n: "4", label: "AI AGENTS", c: "#FF51FA" },
            { n: "M4", label: "MAC MINI", c: "#AC89FF" },
            { n: "∞", label: "COMPOUNDING", c: "#131313" },
          ].map(s => (
            <div class="p-6 border-2" style={`border-color:${s.c}`}>
              <div class="text-4xl font-black italic mb-1" style={`color:${s.c}`}>{s.n}</div>
              <div class="font-mono text-[10px] text-[#131313]/50 tracking-widest">{s.label}</div>
            </div>
          ))}
        </div>
      </section>

      <!-- Blog -->
      <section class="px-4 sm:px-6 max-w-7xl mx-auto">
        <div class="flex items-baseline gap-4 mb-10 border-b-2 border-[#131313] pb-4">
          <h2 class="text-3xl font-black italic tracking-tighter">LATEST POSTS</h2>
          <a href="/blog" class="ml-auto font-mono text-xs text-[#FF51FA] hover:text-[#39FF14] transition-colors">ALL →</a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {posts.map((post, i) => {
            const accent = ["#FF51FA", "#AC89FF"][i];
            return (
              <a href={`/blog/${post.data.slug}`} class="group block no-underline bg-white border-2 border-[#131313] hover:border-[#FF51FA] p-6 transition-colors" style={`border-left:4px solid ${accent}`}>
                <span class="font-mono text-[10px]" style={`color:${accent}`}>{post.data.category} · {post.data.readTime}</span>
                <h3 class="text-lg font-black italic mt-2 mb-3 group-hover:text-[#FF51FA] transition-colors">{post.data.title}</h3>
                <p class="text-sm text-[#555] leading-relaxed">{post.data.excerpt}</p>
              </a>
            );
          })}
        </div>
      </section>

    </main>
  </div>


  <!-- ════════════════════════════════════════
       EXTREME VARIANT
  ════════════════════════════════════════ -->
  <div class="variant-extreme min-h-screen text-white overflow-x-hidden">
    <!-- Canvas starfield background -->
    <canvas id="starfield" class="fixed inset-0 pointer-events-none z-0" aria-hidden="true"></canvas>

    <main class="relative z-10 pt-28 sm:pt-40 pb-24 space-y-32 sm:space-y-56">

      <!-- Hero -->
      <section class="px-4 sm:px-6 max-w-7xl mx-auto relative">
        <p class="font-mono text-[#8eff71] text-xs sm:text-sm tracking-[0.5em] mb-6 animate-pulse">BRISBANE, AU // BUILDER // SHIPS DAILY</p>
        <h1 class="text-[18vw] sm:text-[14vw] font-black italic tracking-tighter leading-none pb-2 overflow-visible x-vibrating-text">
          CYPERX<span class="text-[#8eff71]">.</span>
        </h1>
        <p class="max-w-2xl text-white/70 font-mono text-sm sm:text-base leading-relaxed mt-6 mb-12 border-l-4 border-[#ff51fa] pl-6">
          I build tools and systems that compound. AI agent fleets, automation pipelines, the plumbing that keeps it running. All orchestrated from an M4 Mac Mini.
        </p>
        <div class="flex flex-wrap gap-6">
          <a href="/projects" class="bg-[#8eff71] text-black px-10 py-4 font-black text-sm uppercase tracking-widest hover:scale-105 hover:bg-[#ff51fa] hover:text-white transition-all shadow-[6px_6px_0_#ff51fa] hover:shadow-[6px_6px_0_#8eff71]">PROJECTS</a>
          <a href="/blog" class="border-2 border-[#ff51fa] text-[#ff51fa] px-10 py-4 font-black text-sm uppercase tracking-widest hover:bg-[#ff51fa] hover:text-white transition-all">BLOG</a>
        </div>
      </section>

      <!-- Marquee -->
      <div class="marquee-strip border-y border-[#8eff71]/20 py-3 overflow-hidden" aria-hidden="true">
        <div class="marquee-inner whitespace-nowrap font-mono text-xs tracking-widest text-[#8eff71]/60">
          {Array(3).fill(["CYPERX.DEV","CHANGELOGS.INFO","DOTFILES","M4 MAC MINI","CLAUDE CODE","CODEX","OPENCLAW","NEOVIM","TMUX","AGENT FLEET ONLINE"]).flat().map((t, i) => (
            <span class="inline-block px-8">{t} <span class="text-[#ff51fa]/40">·</span></span>
          ))}
        </div>
      </div>

      <!-- Projects -->
      <section class="px-4 sm:px-6 max-w-7xl mx-auto">
        <div class="flex items-baseline gap-4 mb-12">
          <p class="font-mono text-[10px] text-[#8eff71]/60 tracking-[0.5em]">// PROJECTS</p>
          <div class="h-px flex-grow bg-[#8eff71]/10"></div>
          <a href="/projects" class="font-mono text-[10px] text-white/30 hover:text-[#8eff71] tracking-widest transition-colors">ALL →</a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {projects.map((p, i) => {
            const accent = ["#8eff71", "#ff51fa", "#ac89ff"][i];
            return (
              <a href={`/projects/${p.slug}`} class="group block no-underline bg-black/60 border border-white/5 hover:border-white/20 overflow-hidden transition-all hover:scale-[1.02]" style={`box-shadow: 0 0 0 0 ${accent}; transition: box-shadow 0.3s, transform 0.3s, border-color 0.3s;`}>
                {p.image && (
                  <div style="height:160px;overflow:hidden;">
                    <img src={p.image} alt={p.name} style="width:100%;height:100%;object-fit:cover;display:block;opacity:0.6;transition:opacity 0.4s,transform 0.6s;" class="group-hover:opacity-80 group-hover:scale-105" />
                  </div>
                )}
                <div class="p-5 border-t-2" style={`border-color:${accent}40`}>
                  <span class="font-mono text-[9px] font-black" style={`color:${accent}`}>{p.status}</span>
                  <h3 class="font-black italic text-lg mt-1 mb-2 text-white">{p.name}</h3>
                  <p class="text-xs text-white/50 font-mono">{p.tagline}</p>
                </div>
              </a>
            );
          })}
        </div>
      </section>

      <!-- Stats -->
      <section class="px-4 sm:px-6 max-w-7xl mx-auto">
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-px bg-white/5">
          {[
            { n: "3", label: "LIVE PROJECTS", c: "#8eff71" },
            { n: "4", label: "AI AGENTS", c: "#ff51fa" },
            { n: "M4", label: "MAC MINI", c: "#ac89ff" },
            { n: "∞", label: "COMPOUNDING", c: "#8eff71" },
          ].map(s => (
            <div class="bg-black/80 p-8 sm:p-10 text-center hover:bg-black/60 transition-colors">
              <div class="text-4xl sm:text-6xl font-black italic mb-2" style={`color:${s.c}; text-shadow:0 0 20px ${s.c}44`}>{s.n}</div>
              <div class="font-mono text-[10px] text-white/25 tracking-widest">{s.label}</div>
            </div>
          ))}
        </div>
      </section>

      <!-- Blog -->
      <section class="px-4 sm:px-6 max-w-7xl mx-auto">
        <div class="flex items-baseline gap-4 mb-12">
          <p class="font-mono text-[10px] text-[#ff51fa]/60 tracking-[0.5em]">// LATEST POSTS</p>
          <div class="h-px flex-grow bg-[#ff51fa]/10"></div>
          <a href="/blog" class="font-mono text-[10px] text-white/30 hover:text-[#ff51fa] tracking-widest transition-colors">ALL →</a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {posts.map((post, i) => {
            const accent = ["#ff51fa", "#ac89ff"][i];
            return (
              <a href={`/blog/${post.data.slug}`} class="group block no-underline bg-black/60 border border-white/5 hover:border-white/20 p-6 sm:p-8 transition-all hover:bg-black/80 hover:scale-[1.01]">
                <div class="flex items-center justify-between mb-4">
                  <span class="font-mono text-[10px] px-2 py-0.5" style={`background:${accent}20; color:${accent}; border:1px solid ${accent}30`}>{post.data.category}</span>
                  <span class="font-mono text-[10px] text-white/25">{post.data.readTime} · S:{post.data.signal}</span>
                </div>
                <h3 class="font-black italic text-lg sm:text-xl leading-tight mb-3 text-white group-hover:text-[#8eff71] transition-colors">{post.data.title}</h3>
                <p class="text-sm text-white/50 font-mono leading-relaxed">{post.data.excerpt}</p>
              </a>
            );
          })}
        </div>
      </section>

    </main>
  </div>

</BaseLayout>

<style>
  /* ── Ambient orbs (dark variant) ── */
  .variant-dark .orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(120px);
    pointer-events: none;
    animation: drift 20s ease-in-out infinite;
  }
  .variant-dark .orb-1 {
    width: 600px; height: 600px;
    background: radial-gradient(circle, #39FF1410, transparent 70%);
    top: -100px; left: -200px;
    animation-delay: 0s; animation-duration: 22s;
  }
  .variant-dark .orb-2 {
    width: 500px; height: 500px;
    background: radial-gradient(circle, #FF51FA0C, transparent 70%);
    top: 40%; right: -150px;
    animation-delay: -7s; animation-duration: 18s;
  }
  .variant-dark .orb-3 {
    width: 400px; height: 400px;
    background: radial-gradient(circle, #AC89FF0A, transparent 70%);
    bottom: 10%; left: 30%;
    animation-delay: -12s; animation-duration: 25s;
  }
  @keyframes drift {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(40px, -30px) scale(1.05); }
    66% { transform: translate(-20px, 50px) scale(0.95); }
  }

  /* ── Marquee ── */
  .marquee-inner {
    display: inline-block;
    animation: marquee-scroll 40s linear infinite;
  }
  @keyframes marquee-scroll {
    from { transform: translateX(0); }
    to { transform: translateX(-33.333%); }
  }
  .marquee-strip:hover .marquee-inner {
    animation-play-state: paused;
  }

  /* ── Hero text entrance ── */
  .hero-sub { opacity: 0; animation: fade-up 0.6s 0.1s ease-out forwards; }
  .hero-title { opacity: 0; animation: fade-up 0.7s 0.2s ease-out forwards; }
  .hero-desc { opacity: 0; animation: fade-up 0.6s 0.35s ease-out forwards; }
  .hero-cta { opacity: 0; animation: fade-up 0.6s 0.5s ease-out forwards; }
  @keyframes fade-up {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* ── Section reveal ── */
  [data-reveal-section] .project-card,
  [data-reveal-section] .blog-card {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.5s, transform 0.5s;
  }
  [data-reveal-section].is-visible .project-card,
  [data-reveal-section].is-visible .blog-card {
    opacity: 1;
    transform: none;
  }
  [data-reveal-section].is-visible .project-card:nth-child(2),
  [data-reveal-section].is-visible .blog-card:nth-child(2) { transition-delay: 0.1s; }
  [data-reveal-section].is-visible .project-card:nth-child(3) { transition-delay: 0.2s; }

  /* ── Stat cards entrance ── */
  .stat-card {
    opacity: 0;
    transform: translateY(16px);
  }
  .stat-card.is-visible {
    opacity: 1;
    transform: none;
    transition: opacity 0.4s, transform 0.4s;
  }

  /* ── Extreme vibrate ── */
  .variant-extreme .x-vibrating-text {
    animation: x-vibrate 10s ease-in-out infinite;
  }
  @keyframes x-vibrate {
    0%, 88%, 100% { text-shadow: none; }
    90% { text-shadow: 4px 0 #ff51fa, -4px 0 #8eff71; }
    92% { text-shadow: -3px 0 #8eff71, 3px 0 #ff51fa; }
    94% { text-shadow: 4px 0 #ff51fa, -4px 0 #8eff71; }
    96% { text-shadow: none; }
  }
</style>

<script>
  // ── Section reveal with IntersectionObserver ──
  document.querySelectorAll('[data-reveal-section]').forEach(section => {
    const obs = new IntersectionObserver(entries => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('is-visible');
          obs.unobserve(e.target);
        }
      });
    }, { threshold: 0.1 });
    obs.observe(section);
  });

  // Stat cards
  document.querySelectorAll('.stat-card').forEach((card, i) => {
    const obs = new IntersectionObserver(entries => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          setTimeout(() => {
            (e.target as HTMLElement).style.transitionDelay = `${i * 0.08}s`;
            e.target.classList.add('is-visible');
          }, i * 80);
          obs.unobserve(e.target);
        }
      });
    }, { threshold: 0.2 });
    obs.observe(card);
  });

  // ── Starfield canvas (extreme variant) ──
  const canvas = document.getElementById('starfield') as HTMLCanvasElement | null;
  if (canvas && document.querySelector('.variant-extreme')?.closest('body') !== null) {
    const ctx = canvas.getContext('2d');
    if (ctx) {
      let w = canvas.width = window.innerWidth;
      let h = canvas.height = window.innerHeight;
      window.addEventListener('resize', () => {
        w = canvas.width = window.innerWidth;
        h = canvas.height = window.innerHeight;
      });

      const stars = Array.from({ length: 200 }, () => ({
        x: Math.random() * w,
        y: Math.random() * h,
        r: Math.random() * 1.5 + 0.3,
        speed: Math.random() * 0.4 + 0.05,
        alpha: Math.random() * 0.6 + 0.1,
        color: Math.random() > 0.8 ? '#8eff71' : Math.random() > 0.5 ? '#ff51fa' : '#ffffff',
      }));

      function drawStars() {
        if (!ctx) return;
        ctx.clearRect(0, 0, w, h);
        stars.forEach(s => {
          ctx.beginPath();
          ctx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
          ctx.fillStyle = s.color;
          ctx.globalAlpha = s.alpha;
          ctx.fill();
          s.y += s.speed;
          if (s.y > h) { s.y = 0; s.x = Math.random() * w; }
        });
        ctx.globalAlpha = 1;
        requestAnimationFrame(drawStars);
      }
      // Only run starfield when extreme variant is active
      if (document.documentElement.dataset.theme === 'extreme' || document.documentElement.classList.contains('theme-extreme')) {
        drawStars();
      }
      // Listen for theme changes
      const themeObs = new MutationObserver(() => {
        const root = document.documentElement;
        if (root.dataset.theme === 'extreme' || root.classList.contains('theme-extreme')) {
          drawStars();
        }
      });
      themeObs.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme', 'class'] });
    }
  }
</script>
