    color: #000 !important;
    border-color: #8eff71 !important;
    box-shadow: 0 0 24px rgba(142, 255, 113, 0.9);
  }
  .blog-post-card.is-hidden { display: none !important; }
</style>

<script is:inline>
  (function () {
    function applyFilter(tag) {
      var cards = document.querySelectorAll('.blog-post-card');
      cards.forEach(function (card) {
        var tags = (card.getAttribute('data-post-tags') || '').split(',').map(function (t) { return t.trim(); }).filter(Boolean);
        if (!tag || tags.indexOf(tag) !== -1) card.classList.remove('is-hidden');
        else card.classList.add('is-hidden');
      });
      var pills = document.querySelectorAll('.blog-tag-pill');
      pills.forEach(function (pill) {
        var pillTag = pill.getAttribute('data-filter-tag') || '';
        pill.setAttribute('aria-pressed', pillTag === (tag || '') ? 'true' : 'false');
      });
    }
    function setTag(tag, opts) {
      opts = opts || {};
      var url = new URL(window.location.href);
      if (tag) url.searchParams.set('tag', tag);
      else url.searchParams.delete('tag');
      if (!opts.skipHistory) history.replaceState(null, '', url.toString());
      applyFilter(tag);
    }
    function currentTag() {
      var pressed = document.querySelector('.blog-tag-pill[aria-pressed="true"]');
      return pressed ? (pressed.getAttribute('data-filter-tag') || '') : '';
    }
    document.addEventListener('click', function (e) {
      var el = e.target.closest('[data-filter-tag]');
      if (!el) return;
      e.preventDefault();
      e.stopPropagation();
      var tag = el.getAttribute('data-filter-tag') || '';
      // Toggle off if clicking the already-active tag
      if (tag && currentTag() === tag) tag = '';
      setTag(tag);
      var bar = document.querySelector('[data-filter-bar]');
      if (bar) bar.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    });
    document.addEventListener('keydown', function (e) {
      if (e.key !== 'Enter' && e.key !== ' ') return;
      var el = e.target.closest('[data-filter-tag][role="button"]');
      if (!el) return;
      e.preventDefault();
      el.click();
    });
    var initial = new URL(window.location.href).searchParams.get('tag') || '';
    applyFilter(initial);
  })();
</script>
</BaseLayout>
