---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="💀 Blog — CyperX.dev" activeNav="blog">
  <div class="w-full max-w-4xl py-8 sm:py-16">
    <div class="fractal-card p-6 sm:p-10 relative">
      <div class="chaos-sticker sticker-cyan absolute -top-4 -right-4 rotate-3 hidden sm:block">LOADING_POSTS</div>
      <h1 class="font-black uppercase tracking-tighter text-4xl sm:text-6xl lg:text-8xl text-primary mb-4 sm:mb-6" style="font-family: 'Rubik Glitch', cursive;">
        BLOG
      </h1>
      <div class="glitch-bar-static mb-6 sm:mb-8"></div>
      <div class="font-mono text-sm sm:text-base space-y-3 text-gray-400">
        <p><span class="text-primary">root@cyperx:~#</span> ls -la posts/</p>
        <p class="pl-4">total 0</p>
        <p class="pl-4 text-yellow-400">drwxr-xr-x  &nbsp;coming_soon</p>
        <p class="pl-4 text-yellow-400">drwxr-xr-x  &nbsp;brain_dumps</p>
        <p class="pl-4 text-yellow-400">drwxr-xr-x  &nbsp;build_logs</p>
        <p><span class="text-primary">root@cyperx:~#</span> <span class="animate-pulse text-white">_</span></p>
      </div>
      <div class="corrupt-block mt-8 sm:mt-12"></div>
      <p class="font-mono text-xs text-muted mt-4 tracking-widest animate-pulse">POSTS_INCOMING :: STANDBY</p>
    </div>
  </div>
</BaseLayout>
