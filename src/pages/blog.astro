  /* ── Mobile overrides (<640px) ── */
  @media (max-width: 639px) {
    /* Reduce x-drift amplitude on mobile to prevent horizontal micro-overflow */
    @keyframes x-drift {
      0%   { transform: translate(0,0) rotate(0deg) scale(1); }
      33%  { transform: translate(3px,-2px) rotate(0.3deg) scale(1.01); }
      66%  { transform: translate(-2px,3px) rotate(-0.3deg) scale(0.99); }
      100% { transform: translate(0,0) rotate(0deg) scale(1); }
    }

    /* Light variant: soften clip-paths on cards to prevent content clipping */
    .variant-light .x-shard-sidebar {
      clip-path: polygon(3% 0%, 100% 0%, 97% 100%, 0% 100%);
    }
    .variant-light .x-shard-1 {
      clip-path: polygon(0% 4%, 100% 0%, 96% 100%, 2% 95%);
    }
    .variant-light .x-shard-2 {
      clip-path: polygon(3% 0%, 100% 4%, 97% 100%, 0% 96%);
    }
    .variant-light .x-shard-3 {
      clip-path: polygon(1% 1%, 99% 0%, 100% 99%, 3% 100%);
    }
    .variant-light .x-shard-4 {
