---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="CYPERX.DEV // BLOG" activeNav="blog">

  <!-- ════════ DARK — blog-shard-feed ════════ -->
  <div class="variant-dark bg-[#131313] text-[#e2e2e2] min-h-screen">
    <div class="fixed inset-0 z-[100] crt-overlay opacity-20 pointer-events-none"></div>
    <div class="fixed inset-0 pointer-events-none z-0">
      <div class="absolute top-1/4 -left-20 w-96 h-96 fractal-bloom opacity-30"></div>
      <div class="absolute bottom-1/4 -right-20 w-96 h-96 fractal-bloom opacity-20"></div>
    </div>

    <header class="fixed top-0 w-full flex justify-between items-center px-4 sm:px-8 py-4 sm:py-6 z-50 bg-[#131313]/80 backdrop-blur-xl nav-header">
      <div class="text-2xl sm:text-3xl font-black text-[#39FF14] [text-shadow:2px_0_#FF51FA,-2px_0_#AC89FF] animate-pulse uppercase tracking-tighter italic">CYPERX.DEV</div>
      <nav class="hidden md:flex gap-8 lg:gap-10 uppercase tracking-tighter italic">
        <a class="text-[#e2e2e2] hover:text-[#FF51FA] transition-all duration-75" href="/">HOME</a>
        <a class="text-[#39FF14] border-b-2 border-[#39FF14] pb-1 hover:text-[#FF51FA] transition-all duration-75" href="/blog">BLOG</a>
        <a class="text-[#e2e2e2] hover:text-[#FF51FA] transition-all duration-75" href="/projects">PROJECTS</a>
      </nav>
      <button class="bg-[#39FF14] text-black px-4 sm:px-6 py-2 font-black italic text-xs sm:text-sm" style="clip-path:polygon(10% 0,100% 0,90% 100%,0 100%)">TRIPP_MODE</button>
    </header>

    <main class="relative pt-28 sm:pt-32 pb-16 sm:pb-24 px-4 sm:px-6 lg:px-24 min-h-screen">
      <!-- Hero -->
      <section class="mb-16 sm:mb-24 relative">
        <div class="font-mono text-xs text-[#39FF14] mb-4 tracking-[0.5em] uppercase">[ STATUS: INTERCEPTING_SIGNAL_STREAM ]</div>
        <h1 class="text-4xl sm:text-6xl lg:text-8xl font-black tracking-tighter italic uppercase glitch-text leading-none">SYSTEM<br/>ENTROPY<br/>LOGS</h1>
        <div class="mt-6 sm:mt-8 max-w-xl text-base sm:text-lg text-[#e2e2e2]/80 border-l-4 border-[#FF51FA] pl-6 italic">Raw data sharded from the core. These are the fragments of a dying architecture, rendered for your optical intake. No filters. No safety.</div>
      </section>

      <!-- Blog Feed -->
      <div class="grid grid-cols-1 md:grid-cols-12 gap-8 sm:gap-12 lg:gap-y-32">
        <!-- Featured shard -->
        <article class="md:col-span-8 group relative">
          <div class="absolute -inset-1 bg-[#39FF14]/20 blur-xl group-hover:bg-[#39FF14]/40 transition-colors"></div>
          <div class="relative bg-[#2a2a2a] shard-clip-1 melt-effect border-l-8 border-[#39FF14] p-6 sm:p-8 lg:p-12">
            <div class="flex flex-col md:flex-row gap-6 sm:gap-8">
              <div class="w-full md:w-1/2 aspect-video overflow-hidden relative">
                <img class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-500 scale-110 group-hover:scale-100" src="https://lh3.googleusercontent.com/aida-public/AB6AXuApzEjhKLLfzadUq_evKE5oJfTQGtg_Lz2jMczC3Jx6GydACaRM6ZL3AZCPFv6_fYDnBI2gyBBh83YvHXQsyzJOr9NdtyJw0-frK18ljtLTmoKPimd5IKDDDHD6KekU5l7zRO4RTCHCjNMKNzgwaHLqQY_V1GcIh5vM-woQIU16SyVVo1MJL3_KOgqcgAnko4YhX3iO1Y_UtHgma8So47mjfrT9XTEMEMmB2xTL40D8OnGh5tbnL48ny-K-ZEYtfnHMJdKQUfe_X4c" alt="Blog post" loading="lazy" />
                <div class="absolute inset-0 bg-[#39FF14]/10 mix-blend-overlay"></div>
              </div>
              <div class="w-full md:w-1/2 flex flex-col justify-between">
                <div>
                  <div class="font-mono text-[10px] text-[#FF51FA] mb-2">SIGNAL_STRENGTH: 88% // 2024.08.12</div>
                  <h2 class="text-2xl sm:text-3xl lg:text-5xl font-black uppercase leading-none mb-4 sm:mb-6 group-hover:text-[#39FF14] transition-colors">THE_LIQUID_INFRASTRUCTURE_MYTH</h2>
                  <p class="text-[#e2e2e2]/70 mb-4 sm:mb-6 text-sm sm:text-base">Decentralized protocols aren't enough. We need architectures that melt when the pressure rises and reform in the void.</p>
                </div>
                <div class="flex items-center justify-between font-mono text-[10px] border-t border-[#e2e2e2]/20 pt-4">
                  <span>ENTROPY: 0.44</span>
                  <span class="text-[#39FF14]">READ_FRAGMENT_&gt;&gt;</span>
                </div>
              </div>
            </div>
          </div>
        </article>

        <!-- Small shard -->
        <article class="md:col-span-4 group">
          <div class="bg-[#0e0e0e] shard-clip-2 p-6 sm:p-8 border-r-4 border-[#FF51FA] h-full flex flex-col justify-between">
            <div>
              <div class="font-mono text-[10px] text-[#e2e2e2]/50 mb-4">LOG_ENTRY_409</div>
              <h3 class="text-xl sm:text-2xl font-bold uppercase mb-4 italic leading-tight">NEURAL_GHOSTS_IN_THE_CACHE</h3>
              <p class="text-sm text-[#e2e2e2]/50">What remains when you flush the memory? The artifacts of past sessions still vibrate in the low-level registers.</p>
            </div>
            <div class="mt-8 flex flex-col gap-2 font-mono text-[10px]">
              <div class="flex justify-between"><span>SYSTEM_HEALTH</span><span class="text-red-400">DEGRADED</span></div>
              <div class="w-full bg-[#353535] h-1"><div class="bg-red-400 w-1/3 h-full animate-pulse"></div></div>
            </div>
          </div>
        </article>

        <!-- Middle split -->
        <article class="md:col-start-2 md:col-span-5 group">
          <div class="bg-[#393939] shard-clip-3 p-6 sm:p-10 relative overflow-hidden">
            <div class="absolute top-0 right-0 p-4 opacity-10"><span class="material-symbols-outlined text-6xl">leak_add</span></div>
            <div class="font-mono text-[10px] bg-[#39FF14] text-black inline-block px-2 mb-4 sm:mb-6">UNSTABLE_DATA</div>
            <h3 class="text-2xl sm:text-3xl font-black uppercase mb-4 sm:mb-6 leading-none">VOID_ROUTING: BEYOND_TCP</h3>
            <p class="text-[#e2e2e2] mb-6 sm:mb-8 italic text-sm sm:text-base">Packet loss is a feature, not a bug. If the data isn't missing fragments, was it ever even real?</p>
            <button class="w-full py-3 sm:py-4 border border-[#39FF14] text-[#39FF14] uppercase font-black hover:bg-[#39FF14] hover:text-black transition-all text-sm">SYNC_WITH_VOID</button>
          </div>
        </article>

        <!-- Landscape -->
        <article class="md:col-span-6 group">
          <div class="bg-[#2a2a2a] shard-clip-1 p-6 sm:p-8 flex gap-4 sm:gap-6 items-start border-b-4 border-[#AC89FF]">
            <div class="w-16 sm:w-24 h-16 sm:h-24 flex-shrink-0 bg-[#353535] flex items-center justify-center">
              <span class="material-symbols-outlined text-[#39FF14] text-2xl sm:text-4xl animate-pulse">memory</span>
            </div>
            <div>
              <div class="font-mono text-[10px] text-[#AC89FF] mb-1">STABLE_DIFFUSION_VOICE</div>
              <h3 class="text-xl sm:text-2xl font-bold uppercase mb-2 sm:mb-3">AI_SENSORY_OVERLOAD</h3>
              <p class="text-sm text-[#e2e2e2]/50">Exploring the limits of synthetic perception in high-entropy environments.</p>
              <div class="mt-3 sm:mt-4 flex gap-2 sm:gap-4">
                <span class="px-2 py-1 bg-[#1f1f1f] text-[8px] font-mono">#SYNTH</span>
                <span class="px-2 py-1 bg-[#1f1f1f] text-[8px] font-mono">#SIGNAL</span>
              </div>
            </div>
          </div>
        </article>

        <!-- Tower shard -->
        <article class="md:col-span-3 group">
          <div class="bg-[#0e0e0e] shard-clip-2 p-4 sm:p-6 border-t-8 border-[#c600c6] h-full flex flex-col gap-6 sm:gap-8">
            <div class="h-40 sm:h-64 bg-[#1f1f1f] relative">
              <img class="w-full h-full object-cover opacity-50 group-hover:opacity-100 transition-opacity" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBROVdxHOc1mziCO1MtK2GrSuSCX8SbrCFYEfNa7vMjSCBWyk2PsiQR2yjn-w-zR8wYEgJMjA3rcHMmEN7MZmrSRQyrHREVVKziGVWSk3mbgWX57V12J-6hj_xzKO03HoyqURrs7fcFYeq5usPa0tjAy20ZKlp_tY3QmD7xpiv8DNAV24nyzXxHQXDnsyF269l5Z6eQF2gea8OcacLkPwa3qDB38ie7WhfPE-mbTWqnyumqjn34oqk3T_7OhTzLgOSYPR8OK-BuZVc" alt="" loading="lazy" />
            </div>
            <div>
              <h3 class="text-lg sm:text-xl font-black uppercase mb-3 sm:mb-4 italic">HARDWARE_SHAMANISM</h3>
              <p class="text-xs font-mono text-[#e2e2e2]/60 leading-relaxed">Treating silicon like sacred bone. The ritual of the overclock.</p>
            </div>
            <div class="mt-auto pt-6 sm:pt-8 border-t border-white/5 font-mono text-[10px] text-[#FF51FA]">READ_TIME: 44_CYCLES</div>
          </div>
        </article>

        <!-- Grid filler -->
        <article class="md:col-span-8 group">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="bg-[#2a2a2a] p-4 sm:p-6 shard-clip-1 hover:skew-y-1 transition-transform">
              <div class="font-mono text-[9px] mb-2 opacity-50 uppercase">Fragment_881</div>
              <h4 class="font-bold uppercase text-sm sm:text-base">CRYPTO_BREACH_LOGS</h4>
            </div>
            <div class="bg-[#2a2a2a] p-4 sm:p-6 shard-clip-3 hover:-skew-y-1 transition-transform">
              <div class="font-mono text-[9px] mb-2 opacity-50 uppercase">Fragment_223</div>
              <h4 class="font-bold uppercase text-sm sm:text-base">THE_GHOST_PROTOCOL</h4>
            </div>
            <div class="sm:col-span-2 bg-[#39FF14] p-1 font-black italic uppercase text-center text-black text-sm">VIEW_OLDER_SIGNAL_INTERCEPTS_...</div>
          </div>
        </article>
      </div>
    </main>

    <footer class="w-full py-10 sm:py-12 px-6 sm:px-10 flex flex-col md:flex-row justify-between items-end gap-4 bg-[#0e0e0e] site-footer">
      <div class="flex flex-col gap-2">
        <div class="text-[#39FF14] font-bold text-xl uppercase tracking-tighter italic">CYPERX.DEV</div>
        <div class="font-mono text-[10px] uppercase tracking-widest text-[#AC89FF]">SYSTEM ENTROPY: 99.9% | STABLE BEYOND VOID</div>
      </div>
      <div class="flex gap-6 sm:gap-8 font-mono text-[10px] uppercase tracking-widest text-[#e2e2e2]/60">
        {['TERMINAL','REACH_OUT','LEGAL_VOID'].map(l => <a class="hover:text-[#39FF14] hover:line-through hover:blur-[1px] transition-all" href="#">{l}</a>)}
      </div>
    </footer>
  </div>


  <!-- ════════ LIGHT — blog-bleached-shards ════════ -->
  <div class="variant-light bg-white text-[#131313] min-h-screen">
    <div class="fixed inset-0 z-[100] light-scanline opacity-20 pointer-events-none"></div>

    <header class="fixed top-0 w-full flex justify-between items-center px-4 sm:px-8 py-4 sm:py-6 z-50 bg-white/80 backdrop-blur-xl nav-header">
      <div class="text-2xl sm:text-3xl font-black text-[#39FF14] [text-shadow:2px_0_#FF51FA,-2px_0_#AC89FF] animate-pulse uppercase tracking-tighter italic">CYPERX.DEV</div>
      <nav class="hidden md:flex gap-8 lg:gap-10 uppercase tracking-tighter italic">
        <a class="text-[#131313] hover:text-[#FF51FA] transition-all" href="/">HOME</a>
        <a class="text-[#39FF14] border-b-2 border-[#39FF14] pb-1 hover:text-[#FF51FA] transition-all" href="/blog">BLOG</a>
        <a class="text-[#131313] hover:text-[#FF51FA] transition-all" href="/projects">PROJECTS</a>
      </nav>
      <button class="bg-[#39FF14] text-black px-4 sm:px-6 py-2 font-black italic text-xs sm:text-sm" style="clip-path:polygon(10% 0,100% 0,90% 100%,0 100%)">TRIPP_MODE</button>
    </header>

    <main class="pt-28 sm:pt-32 pb-16 sm:pb-24 px-4 sm:px-8 lg:px-20 max-w-screen-2xl mx-auto min-h-screen">
      <section class="mb-16 sm:mb-24">
        <div class="flex items-center gap-4 mb-4 flex-wrap">
          <span class="font-mono text-xs tracking-[0.5em] text-[#131313] bg-[#f0f0f0] px-3 py-1">SYSTEM_STATUS: BLEACHED</span>
          <div class="h-[2px] flex-grow bg-gradient-to-r from-[#39FF14] to-transparent"></div>
        </div>
        <h1 class="text-4xl sm:text-6xl lg:text-8xl font-black uppercase tracking-tighter italic leading-none glitch-text">BLEACHED<br/>SHARDS</h1>
        <p class="mt-6 sm:mt-8 max-w-xl text-base sm:text-xl text-[#131313]/70 border-l-4 border-[#39FF14] pl-6">Signal intercepted. Data has been over-exposed. Reading between the fragments.</p>
      </section>

      <div class="grid grid-cols-1 md:grid-cols-12 gap-6 sm:gap-8 lg:gap-12">
        <!-- Large light card -->
        <article class="md:col-span-8 group relative bg-[#f0f0f0] shard-path-1 p-1 hover:scale-[1.01] transition-transform">
          <div class="bg-white h-full p-6 sm:p-8 flex flex-col md:flex-row gap-6 sm:gap-8">
            <div class="w-full md:w-1/2 aspect-video overflow-hidden shard-card-1 relative bg-[#131313]">
              <img class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-500" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBfrb9kxpwOQmoXnv-TklDn7U-0DMieU2XzZ2nvrADZ_YCfryxccZHMswn5s8HGfu_6rM2Vgmi3tzlHEZehG_W_ojPlqgbpuuhFytV-bJxyDGelWjdCUouRXccLYJBLxXR9FKWEaXSL2s5b_0sJKhyLNM-oqkELDbfdsr_3lE-aZyWbCuU9Vhh0MQJ_8WFx6kqeR6i-Iogv_7jQw4-rqjWYjAHJtUwQuuf5rovooA3HZjDVfZBJHPHCQM4KEFG_Qc7RwdY6bnCAe18" alt="" loading="lazy" />
            </div>
            <div class="w-full md:w-1/2 flex flex-col justify-between">
              <div>
                <span class="bg-[#FF51FA] text-white text-xs px-2 py-1 font-mono">BLEACHED_LOG_001</span>
                <h2 class="text-2xl sm:text-4xl font-black uppercase mt-4 mb-3 sm:mb-4 group-hover:text-[#39FF14] transition-colors leading-none">LIGHT_INFRASTRUCTURE_COLLAPSE</h2>
                <p class="text-[#131313]/70 text-sm sm:text-base">Over-exposed data streams. The signal is too pure. Reality is burning off its metadata.</p>
              </div>
              <div class="flex items-center justify-between font-mono text-[10px] border-t border-[#131313]/20 pt-4 mt-6 sm:mt-0">
                <span>CLARITY: 99%</span>
                <span class="text-[#39FF14]">READ_FRAGMENT &gt;&gt;</span>
              </div>
            </div>
          </div>
        </article>

        <article class="md:col-span-4 group bg-[#39FF14] shard-path-2 p-1">
          <div class="bg-white h-full p-6 sm:p-8 flex flex-col gap-4 sm:gap-6">
            <span class="bg-[#131313] text-white text-xs px-2 py-1 font-mono w-fit">OVEREXPOSED</span>
            <h3 class="text-xl sm:text-2xl font-black uppercase italic">GHOST_IN_WHITE</h3>
            <p class="text-sm text-[#131313]/70 flex-grow">When the signal is too clear, even ghosts cast shadows. Pure data needs noise to be real.</p>
            <button class="text-[#39FF14] font-black text-xs uppercase tracking-widest border-b border-[#39FF14] pb-1 w-fit">ACCESS_RECORD</button>
          </div>
        </article>

        <article class="md:col-span-5 group bg-[#f8f8f8] shard-path-3 p-6 sm:p-8">
          <span class="bg-[#39FF14] text-black text-xs px-2 py-1 font-mono inline-block mb-4 sm:mb-6">UNFILTERED</span>
          <h3 class="text-2xl sm:text-3xl font-black uppercase mb-3 sm:mb-4 leading-none">VOID_ROUTING: BLEACHED_TCP</h3>
          <p class="text-[#131313]/80 italic mb-6 sm:mb-8 text-sm sm:text-base">In the light, packet loss becomes transparency. What's missing is exactly what we needed to see.</p>
          <button class="w-full py-3 sm:py-4 bg-[#131313] text-white font-black uppercase hover:bg-[#39FF14] hover:text-black transition-all text-sm">SYNC_WITH_LIGHT</button>
        </article>

        <article class="md:col-span-7 group bg-[#ebebeb] shard-path-1 p-6 sm:p-8 flex gap-4 sm:gap-6 items-center">
          <div class="w-16 sm:w-24 h-16 sm:h-24 flex-shrink-0 bg-white flex items-center justify-center chroma-bleed">
            <span class="material-symbols-outlined text-[#39FF14] text-2xl sm:text-4xl animate-pulse">memory</span>
          </div>
          <div>
            <div class="font-mono text-[10px] text-[#AC89FF] mb-1">BLEACHED_SIGNAL</div>
            <h3 class="text-lg sm:text-2xl font-bold uppercase mb-2">SYNTHETIC_LIGHT_PROTOCOL</h3>
            <p class="text-sm text-[#131313]/60">Artificial illumination in the void. Creating light where none should exist.</p>
            <div class="mt-3 flex gap-2"><span class="px-2 py-1 bg-white text-[8px] font-mono border border-[#39FF14]">#PURE</span><span class="px-2 py-1 bg-white text-[8px] font-mono border border-[#FF51FA]">#SIGNAL</span></div>
          </div>
        </article>

        <div class="md:col-span-12 grid grid-cols-1 sm:grid-cols-3 gap-4">
          {[['Fragment_881','CRYPTO_BREACH_BLEACHED'],['Fragment_223','GHOST_LIGHT_PROTOCOL'],['Fragment_554','NEURAL_OVEREXPOSURE']].map(([id, title]) => (
            <div class="bg-[#f0f0f0] p-4 sm:p-6 shard-path-1 hover:bg-white hover:shadow-lg transition-all">
              <div class="font-mono text-[9px] mb-2 text-[#131313]/40 uppercase">{id}</div>
              <h4 class="font-bold uppercase text-sm">{title}</h4>
            </div>
          ))}
        </div>

        <div class="md:col-span-12">
          <div class="bg-[#39FF14] p-1 font-black italic uppercase text-center text-black text-sm cursor-pointer hover:bg-[#FF51FA] hover:text-white transition-colors">LOAD_MORE_FRAGMENTS...</div>
        </div>
      </div>
    </main>

    <footer class="w-full py-10 sm:py-12 px-6 sm:px-10 flex flex-col md:flex-row justify-between items-end gap-4 bg-[#0e0e0e] site-footer">
      <div class="text-[#39FF14] font-bold text-xl uppercase tracking-tighter italic">CYPERX.DEV</div>
      <div class="flex gap-6 sm:gap-8 font-mono text-[10px] uppercase tracking-widest text-[#e2e2e2]/60">
        {['TERMINAL','REACH_OUT','LEGAL_VOID'].map(l => <a class="hover:text-[#39FF14] hover:line-through transition-all" href="#">{l}</a>)}
      </div>
    </footer>
  </div>


  <!-- ════════ EXTREME — blog-shard-breach-dark-extreme ════════ -->
  <div class="variant-extreme min-h-screen" style="background:#050505; color:#fff;">
    <div class="noise-overlay"></div>
    <div class="fixed inset-0 z-[100] crt-scanlines opacity-40 pointer-events-none"></div>
    <div class="fractal-bg" style="background-image: radial-gradient(circle at 30% 70%, #3d003d 0%, #000 70%)"></div>

    <header class="fixed top-0 w-full z-[110] bg-black/80 backdrop-blur-3xl border-b-4 border-[#8eff71] flex justify-between items-center px-4 sm:px-10 py-4">
      <div class="text-2xl sm:text-4xl font-black tracking-tighter text-[#8eff71] italic glitch-text-animated">FRACTAL_VOID</div>
      <nav class="hidden md:flex items-center gap-4">
        <a class="bg-[#8eff71] text-black px-4 py-1 font-black uppercase text-xs hover:skew-x-12 transition-transform" href="/">HOME</a>
        <a class="bg-[#ff51fa] text-white px-4 py-1 font-black uppercase text-xs border-b-4 border-white" href="/blog">BLOG</a>
        <a class="bg-white text-black px-4 py-1 font-black uppercase text-xs hover:-skew-x-12 transition-transform" href="/projects">PROJECTS</a>
      </nav>
      <button class="bg-red-600 text-white px-4 sm:px-6 py-2 font-black uppercase tracking-widest text-xs animate-bounce vibrate">DANGER_ZONE</button>
    </header>

    <main class="relative pt-28 sm:pt-40 pb-20 px-4 sm:px-8 min-h-screen">
      <!-- Hero -->
      <section class="mb-16 sm:mb-24 relative z-10">
        <div class="flex items-center gap-4 text-[#ff51fa] font-mono text-xs sm:text-sm tracking-widest mb-4 flex-wrap">
          <span class="inline-block w-16 sm:w-24 h-1 bg-[#ff51fa]"></span>
          SIGNAL_BREACH_DETECTED
        </div>
        <h1 class="text-5xl sm:text-7xl lg:text-[10vw] leading-[0.8] font-black tracking-tighter glitch-text-animated uppercase italic text-white">
          SHARD<br/><span class="text-[#8eff71]">BREACH</span>
        </h1>
        <div class="mt-6 sm:mt-8 p-4 sm:p-6 bg-[#ff51fa] text-black inline-block font-black text-base sm:text-xl -skew-x-6">REALITY_BUFFER: COMPROMISED</div>
      </section>

      <!-- Extreme blog cards -->
      <div class="relative flex flex-wrap justify-center gap-4 sm:gap-8">
        <!-- Main chaos shard -->
        <div class="w-full lg:w-2/3 group shard-hover transition-all duration-75 relative z-20">
          <div class="bg-[#8eff71] jagged-mess p-2 vibrate">
            <div class="relative bg-black h-[300px] sm:h-[500px] overflow-hidden jagged-mess">
