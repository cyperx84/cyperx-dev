---
import BaseLayout from '../layouts/BaseLayout.astro';
import { posts } from '../data/posts';

const featured = posts[0];
const rest = posts.slice(1);
---
<BaseLayout title="CYPERX.DEV // BLOG" activeNav="blog">

  <!-- ════════════════════════════════════════
       DARK VARIANT
  ════════════════════════════════════════ -->
  <div class="variant-dark bg-[#131313] text-[#e2e2e2] min-h-screen">
    <main class="relative pt-28 sm:pt-32 pb-16 sm:pb-24 px-4 sm:px-6 lg:px-12 max-w-7xl mx-auto min-h-screen">
      <!-- Hero -->
      <section class="mb-16 sm:mb-24 relative">
        <div class="font-mono text-xs text-[#39FF14] mb-4 tracking-[0.5em] uppercase" data-typewriter="30">[ STATUS: INTERCEPTING_SIGNAL_STREAM ]</div>
        <h1 class="text-4xl sm:text-6xl lg:text-8xl font-black tracking-tighter italic uppercase glitch-text leading-none" data-reveal>SYSTEM<br/>ENTROPY<br/>LOGS</h1>
        <div class="mt-6 sm:mt-8 max-w-xl text-base sm:text-lg text-[#e2e2e2]/80 border-l-4 border-[#FF51FA] pl-6 italic" data-reveal>Raw transmissions from the build process. No filters. No polish. Just signal.</div>
      </section>

      <!-- Featured Post -->
      <article class="mb-16 sm:mb-24 group relative">
        <div class="absolute -inset-1 bg-[#39FF14]/20 blur-xl group-hover:bg-[#39FF14]/40 transition-colors"></div>
        <a href={`/blog/${featured.slug}`} class="block relative bg-[#2a2a2a] x-shard-melt-intense overflow-hidden x-glitch-hover border-l-8 border-[#39FF14] p-6 sm:p-8 lg:p-12">
          <div class="x-shard-inner-fractal"></div>
          <div class="flex flex-col md:flex-row gap-6 sm:gap-8 relative z-10">
            <div class="w-full md:w-1/2">
              <div class="font-mono text-[10px] text-[#FF51FA] mb-2">SIGNAL_STRENGTH: {featured.signal}% // {featured.date}</div>
              <h2 class="text-2xl sm:text-3xl lg:text-5xl font-black uppercase leading-none mb-4 sm:mb-6 group-hover:text-[#39FF14] transition-colors">{featured.title.replace(/ /g, '_').toUpperCase()}</h2>
              <p class="text-[#baccb0] mb-4 sm:mb-6 text-sm sm:text-base">{featured.excerpt}</p>
              <div class="flex flex-wrap gap-2 mb-6">
                {featured.tags.map(tag => (
                  <span class="px-2 py-1 bg-[#1f1f1f] text-[8px] font-mono text-[#39FF14]">#{tag}</span>
                ))}
              </div>
            </div>
            <div class="w-full md:w-1/2 flex flex-col justify-between">
              <div class="aspect-video bg-[#1f1f1f] border border-[#39FF14]/20 flex items-center justify-center mb-4">
                <span class="material-symbols-outlined text-[#39FF14] text-6xl opacity-30">terminal</span>
              </div>
              <div class="flex items-center justify-between font-mono text-[10px] border-t border-[#e2e2e2]/20 pt-4">
                <span>ENTROPY: 0.{featured.signal} // {featured.readTime.toUpperCase()}</span>
                <span class="text-[#39FF14]">READ_FRAGMENT_&gt;&gt;</span>
              </div>
            </div>
          </div>
        </a>
      </article>

      <!-- Post Grid -->
      <div class="grid grid-cols-1 md:grid-cols-12 gap-8 sm:gap-12">
        {rest.map((post, i) => {
          const spans = [
            "md:col-span-4",
            "md:col-span-8",
            "md:col-span-6",
            "md:col-span-6",
            "md:col-span-5",
          ];
          const borders = [
            "border-r-4 border-[#FF51FA]",
            "border-b-4 border-[#AC89FF]",
            "border-l-4 border-[#39FF14]",
            "border-t-4 border-[#FF51FA]",
            "border-l-4 border-[#AC89FF]",
          ];
          const xShards = ["x-shard-sidebar", "x-shard-3", "x-shard-4", "x-shard-sidebar", "x-shard-3"];
          const colors = ["#FF51FA", "#39FF14", "#AC89FF", "#FF51FA", "#39FF14"];
          return (
            <article class={`${spans[i]} group`} data-reveal>
              <a href={`/blog/${post.slug}`} class={`block bg-[#0e0e0e] ${xShards[i]} p-6 sm:p-8 ${borders[i]} overflow-hidden relative x-glitch-hover h-full flex flex-col justify-between hover:bg-[#1f1f1f] transition-all duration-500`}>
                <div class="x-shard-inner-fractal"></div>
                <div class="relative z-10">
                  <div class="flex items-center justify-between mb-4">
                    <span class="font-mono text-[10px] text-[#e2e2e2]/50">{post.category}</span>
                    <span class="font-mono text-[10px]" style={`color:${colors[i]}`}>{post.date}</span>
                  </div>
                  <h3 class={`text-xl sm:text-2xl font-black uppercase mb-4 italic leading-tight group-hover:transition-colors`} style={`--hover-color:${colors[i]}`}>
                    {post.title.replace(/ /g, '_').toUpperCase()}
                  </h3>
                  <p class="text-sm text-[#e2e2e2]/60 mb-4">{post.excerpt}</p>
                  <div class="flex flex-wrap gap-2">
                    {post.tags.map(tag => (
                      <span class="px-2 py-1 bg-[#1f1f1f] text-[8px] font-mono text-[#e2e2e2]/40">#{tag}</span>
                    ))}
                  </div>
                </div>
                <div class="mt-6 sm:mt-8 flex items-center justify-between font-mono text-[10px] border-t border-[#e2e2e2]/10 pt-4">
                  <span>{post.readTime.toUpperCase()}</span>
                  <span style={`color:${colors[i]}`}>READ_&gt;&gt;</span>
                </div>
                </div>
              </a>
            </article>
          );
        })}
      </div>
    </main>
  </div>


  <!-- ════════════════════════════════════════
       LIGHT VARIANT
  ════════════════════════════════════════ -->
  <div class="variant-light bg-white text-[#131313] min-h-screen overflow-x-hidden">
    <main class="pt-28 sm:pt-32 pb-16 sm:pb-24 px-4 sm:px-6 lg:px-12 max-w-7xl mx-auto">
      <!-- Hero Section -->
      <section class="relative mb-16 sm:mb-24">
        <div class="absolute -top-10 -left-10 w-64 h-64 bg-[#FF51FA]/10 blur-3xl rounded-full"></div>
        <h1 class="text-5xl sm:text-7xl lg:text-9xl font-black uppercase tracking-tighter leading-none mb-4 glitch-text" data-reveal>
          SIGNAL<br/>DECAY_
        </h1>
        <div class="flex items-center gap-4 font-mono text-xs tracking-widest text-[#FF51FA] font-bold">
          <span>STATUS: BROADCASTING</span>
          <span class="w-12 h-[1px] bg-[#FF51FA]"></span>
          <span>{posts.length} SIGNALS LOGGED</span>
        </div>
      </section>

      <!-- Featured -->
      <article class="mb-16 group">
        <div class="bg-[#ebebeb] p-1 transition-all group-hover:bg-[#39FF14] duration-500 x-glitch-hover overflow-hidden relative x-shard-melt-intense" style="">
          <div class="bg-white p-6 sm:p-8 lg:p-12 relative overflow-hidden" style="clip-path:polygon(10% 0, 100% 5%, 90% 100%, 0 85%)">
            <div class="x-shard-inner-fractal opacity-5"></div>
            <div class="absolute top-0 right-0 p-4 font-mono text-[10px] text-[#AC89FF]">#001 // {featured.category}</div>
            <h2 class="text-3xl sm:text-4xl lg:text-6xl font-black uppercase mb-6 leading-tight">{featured.title}</h2>
            <p class="text-lg sm:text-xl lg:text-2xl font-medium leading-relaxed mb-8 max-w-2xl">{featured.excerpt}</p>
            <div class="flex items-center justify-between flex-wrap gap-4">
              <div class="flex flex-wrap gap-2">
                {featured.tags.map(tag => (
                  <span class="bg-[#f0f0f0] text-[10px] font-mono px-2 py-1 text-[#131313]/60">#{tag}</span>
                ))}
              </div>
              <div class="flex items-center gap-4">
                <span class="font-mono text-xs text-[#131313]/40">{featured.date} · {featured.readTime}</span>
                <a class="inline-flex items-center gap-2 font-black uppercase tracking-widest text-[#39FF14] group-hover:text-[#FF51FA]" href={`/blog/${featured.slug}`}>
                  READ <span class="material-symbols-outlined">arrow_forward</span>
                </a>
              </div>
            </div>
          </div>
        </div>
      </article>

      <!-- Post Grid -->
      <div class="grid grid-cols-1 md:grid-cols-12 gap-6">
        {rest.map((post, i) => {
          const spans = ["md:col-span-5", "md:col-span-7", "md:col-span-7", "md:col-span-5", "md:col-span-6"];
          const clipPaths = [
            "polygon(5% 5%, 90% 0, 100% 95%, 0% 100%)",
            "polygon(0 15%, 95% 0, 100% 85%, 5% 100%)",
            "polygon(10% 0, 100% 5%, 90% 100%, 0 85%)",
            "polygon(5% 5%, 90% 0, 100% 95%, 0% 100%)",
            "polygon(0 15%, 95% 0, 100% 85%, 5% 100%)",
          ];
          const borderColors = ["#FF51FA", "#AC89FF", "#39FF14", "#FF51FA", "#AC89FF"];
          const xShards = ["x-shard-sidebar", "x-shard-3", "x-shard-4", "x-shard-sidebar", "x-shard-3"];
          return (
            <article class={`${spans[i]} group`} data-reveal style={`animation: x-drift ${7 + i}s ease-in-out infinite`}>
              <a href={`/blog/${post.slug}`} class={`block p-1 transition-all duration-500 hover:skew-y-1 x-glitch-hover overflow-hidden relative`} style={`background:${borderColors[i]}; clip-path:${clipPaths[i]}`}>
                <div class="bg-white p-6 relative overflow-hidden" style={`clip-path:${clipPaths[i]}`}>
                  <div class="x-shard-inner-fractal opacity-5"></div>
                  <div class="relative z-10">
                    <div class="mb-3 flex justify-between items-start">
                      <span class="text-white text-[10px] font-mono px-2 py-1" style={`background:${borderColors[i]}`}>{post.category}</span>
                      <span class="font-mono text-[10px] opacity-40">{post.date}</span>
                    </div>
                    <h3 class="text-xl sm:text-2xl font-black uppercase mb-3">{post.title}</h3>
                    <p class="text-sm mb-4 opacity-70">{post.excerpt}</p>
                    <div class="flex items-center justify-between">
                      <div class="flex flex-wrap gap-1">
                        {post.tags.slice(0, 2).map(tag => (
                          <span class="bg-[#f0f0f0] text-[9px] font-mono px-2 py-1">#{tag}</span>
                        ))}
                      </div>
                      <span class="font-mono text-[10px] opacity-40">{post.readTime}</span>
                    </div>
                  </div>
                </div>
              </a>
            </article>
          );
        })}
      </div>

      <!-- Terminal -->
      <section class="mt-16 p-6 sm:p-8 bg-[#131313] text-white max-w-2xl" style="clip-path:polygon(10% 0, 100% 5%, 90% 100%, 0 85%)">
        <div class="flex items-center gap-2 mb-4">
          <div class="w-3 h-3 bg-[#39FF14]"></div>
          <span class="font-mono text-xs uppercase tracking-tighter">SIGNAL_ARCHIVE</span>
        </div>
        <div class="font-mono text-sm text-[#39FF14]/80 space-y-1">
          <p>&gt; {posts.length} SIGNALS INTERCEPTED</p>
          <p>&gt; ARCHIVE STATUS: STABLE</p>
          <p>&gt; OLDER TRANSMISSIONS AVAILABLE</p>
          <p class="animate-pulse">&gt; _</p>
        </div>
      </section>
    </main>
  </div>


  <!-- ════════════════════════════════════════
       EXTREME VARIANT
  ════════════════════════════════════════ -->
  <div class="variant-extreme bg-[#050505] text-white min-h-screen overflow-x-hidden" style="cursor:crosshair">
    <main class="relative pt-28 sm:pt-32 pb-16 sm:pb-24 px-4 sm:px-6 lg:px-12 max-w-7xl mx-auto min-h-screen">
      <div class="fixed inset-0 x-fractal-bg -z-10"></div>

      <!-- Header -->
      <header class="mb-20 sm:mb-32 space-y-8 relative">
        <div class="absolute -top-12 -left-12 w-64 h-64 bg-[#8eff71]/20 blur-[120px] rounded-full animate-pulse"></div>
        <h1 class="text-5xl sm:text-7xl lg:text-[10rem] font-black tracking-tighter x-vibrating-text uppercase leading-none" data-reveal>
          DATA<br/>LOGS_0x0
        </h1>
        <div class="flex flex-wrap items-center gap-4 sm:gap-8 text-[#8eff71] font-mono text-sm sm:text-lg">
          <span class="animate-ping h-3 w-3 rounded-full bg-[#8eff71]"></span>
          <span class="tracking-[0.3em] sm:tracking-[0.5em] font-black text-[#ff51fa]">SYSTEM_INFILTRATION_CRITICAL</span>
          <span class="opacity-40 italic">// {posts.length} LOGS DECRYPTED</span>
        </div>
      </header>

      <!-- Featured -->
      <article class="mb-16 sm:mb-24 group relative">
        <div class="absolute -inset-8 bg-gradient-to-br from-[#8eff71] via-[#ff51fa] to-[#ac89ff] blur-[100px] opacity-20 group-hover:opacity-80 transition-opacity duration-1000"></div>
        <div class="relative bg-[#191919] border-4 border-[#8eff71]/50 x-shard-melt-intense shadow-[0_0_60px_rgba(142,255,113,0.3)] overflow-hidden x-glitch-hover">
          <div class="x-shard-inner-fractal"></div>
          <div class="p-6 sm:p-12 relative z-10 space-y-6 sm:space-y-8">
            <div class="flex items-center gap-4 font-mono text-xs">
              <span class="bg-[#8eff71] text-black px-3 py-1 font-black">{featured.category}</span>
              <span class="text-[#ff51fa]">{featured.date}</span>
              <span class="text-[#8eff71]/60">{featured.readTime}</span>
            </div>
            <h2 class="text-3xl sm:text-5xl lg:text-7xl font-black text-white uppercase tracking-tighter x-vibrating-text group-hover:text-[#8eff71]">
              {featured.title.replace(/ /g, '_').toUpperCase()}
            </h2>
            <p class="text-white text-lg sm:text-2xl font-bold leading-tight max-w-3xl italic tracking-tight">{featured.excerpt}</p>
            <div class="flex flex-wrap items-center gap-6 sm:gap-12">
              <a href={`/blog/${featured.slug}`} class="bg-[#8eff71] text-[#0d6100] px-8 sm:px-16 py-4 sm:py-6 font-black text-base sm:text-xl uppercase tracking-tighter hover:bg-white hover:text-black transition-all shadow-[0_0_30px_rgba(142,255,113,0.8)]">
                DECRYPT_VOID
              </a>
              <span class="text-[#ff51fa] font-mono text-xs sm:text-sm animate-pulse">SIGNAL: {featured.signal}%</span>
            </div>
          </div>
        </div>
      </article>

      <!-- Grid -->
      <div class="grid grid-cols-1 md:grid-cols-12 gap-8 sm:gap-12 items-start">
        {rest.map((post, i) => {
          const spans = ["md:col-span-4", "md:col-span-8", "md:col-span-6", "md:col-span-6", "md:col-span-5"];
          const borderColors = ["#ff51fa", "#8eff71", "#ac89ff", "#ff51fa", "#8eff71"];
          const xShards = ["x-shard-sidebar", "x-shard-3", "x-shard-4", "x-shard-sidebar", "x-shard-3"];
          return (
            <article class={`${spans[i]} group`} data-reveal>
              <a href={`/blog/${post.slug}`} class={`block bg-[#111] p-6 sm:p-8 border-4 overflow-hidden relative ${xShards[i]} x-glitch-hover hover:scale-[1.02] transition-all duration-500`} style={`border-color:${borderColors[i]}50; box-shadow:0 0 40px ${borderColors[i]}33`}>
                <div class="x-shard-inner-fractal"></div>
                <div class="relative z-10">
                  <div class="flex items-center justify-between mb-4">
                    <span class="font-mono text-[10px] font-black tracking-[0.3em] uppercase" style={`color:${borderColors[i]}`}>{post.category}</span>
                    <span class="font-mono text-[10px] text-white/40">{post.date}</span>
                  </div>
                  <h3 class="text-xl sm:text-2xl font-black text-white mb-4 uppercase tracking-tighter group-hover:transition-colors" style={`--glow:${borderColors[i]}`}>
                    {post.title.replace(/ /g, '_').toUpperCase()}
                  </h3>
                  <p class="text-sm text-[#ababab] leading-tight font-medium italic mb-4">{post.excerpt}</p>
                  <div class="flex flex-wrap gap-2 mb-4">
                    {post.tags.map(tag => (
                      <span class="px-2 py-1 bg-black/50 text-[8px] font-mono" style={`color:${borderColors[i]}99`}>#{tag}</span>
                    ))}
                  </div>
                  <div class="flex items-center justify-between font-mono text-[10px] border-t border-white/10 pt-4">
                    <span class="text-white/40">{post.readTime}</span>
                    <span class="font-black uppercase tracking-[0.3em]" style={`color:${borderColors[i]}`}>DECRYPT_&gt;&gt;</span>
                  </div>
                </div>
              </a>
            </article>
          );
        })}
      </div>

      <!-- Pagination -->
      <div class="mt-24 sm:mt-48 flex justify-center gap-4 sm:gap-6">
        <button class="w-16 sm:w-20 h-16 sm:h-20 border-4 border-[#8eff71] bg-[#8eff71] text-black font-black text-xl sm:text-2xl">01</button>
        <button class="w-16 sm:w-20 h-16 sm:h-20 border-4 border-[#ff51fa]/30 text-[#ff51fa]/40 hover:text-white hover:border-white transition-all font-black text-xl sm:text-2xl">02</button>
        <div class="w-16 sm:w-20 h-16 sm:h-20 flex items-center justify-center text-[#8eff71]/20 tracking-[1em] font-black">...</div>
      </div>
    </main>
  </div>

</BaseLayout>

<style is:global>
  @keyframes x-drift {
    0%   { transform: translate(0,0) rotate(0deg) scale(1); }
    33%  { transform: translate(15px,-10px) rotate(1deg) scale(1.02); }
    66%  { transform: translate(-10px,15px) rotate(-1deg) scale(0.98); }
    100% { transform: translate(0,0) rotate(0deg) scale(1); }
  }
  @keyframes x-glitch-anim {
    0%   { clip-path: inset(40% 0 61% 0); transform: translate(-5px); }
    20%  { clip-path: inset(92% 0 1% 0);  transform: translate(5px); }
    40%  { clip-path: inset(43% 0 1% 0);  transform: translate(-5px); }
    60%  { clip-path: inset(25% 0 58% 0); transform: translate(5px); }
    80%  { clip-path: inset(54% 0 7% 0);  transform: translate(-5px); }
    100% { clip-path: inset(58% 0 43% 0); transform: translate(5px); }
  }
  @keyframes x-fractal-shift {
    0%   { background-position: 0% 0%;     filter: hue-rotate(0deg); }
    100% { background-position: 100% 100%; filter: hue-rotate(360deg); }
  }
  .x-shard-1 { clip-path: polygon(0% 15%, 100% 0%, 85% 100%, 5% 85%); animation: x-drift 7s ease-in-out infinite; }
  .x-shard-2 { clip-path: polygon(10% 0%, 100% 25%, 90% 100%, 0% 75%); animation: x-drift 8s ease-in-out infinite reverse; }
  .x-shard-3 { clip-path: polygon(5% 5%, 95% 0%, 100% 95%, 15% 100%); animation: x-drift 6s ease-in-out infinite 1s; }
  .x-shard-4 { clip-path: polygon(0% 0%, 88% 12%, 100% 88%, 12% 100%); animation: x-drift 9s ease-in-out infinite 0.5s; }
  .x-shard-melt-intense { clip-path: polygon(2% 2%, 98% 5%, 95% 45%, 100% 48%, 92% 85%, 75% 82%, 65% 100%, 45% 88%, 25% 95%, 10% 75%, 0% 85%, 5% 50%); animation: x-drift 10s ease-in-out infinite; }
  .x-shard-sidebar { clip-path: polygon(15% 0%, 100% 0%, 85% 100%, 0% 100%); }
  .x-vibrating-text { animation: psychedelic-melt 6s ease-in-out infinite; text-shadow: 3px 0 #ff51fa, -3px 0 #8eff71; }
  .x-fractal-bg {
    background-image: url(https://lh3.googleusercontent.com/aida-public/AB6AXuCCF-Wu0arOTEDRI7pEIgN9zoNVdLKE4WsdOdqmG-mtDHqHKeMqx_pBPtjbjQ4HLpooT9zBpJxFZIdyqmNhwaR3F5bS0VU9SZlVRdaD5SIIexczbDXVJLbC3fYM2lj-LBSQE8z_t1hhuH-YwO4BAU9o7bwkQAjqbW5Q1Lla1YTPzZjwno57NJKB4OVSqJNG42o5Uyn6rRNAztZgkm42__gqzmM9KOWda7YxxqhQfjXKC-JYyYqX7MWlCNskOFkjixU_RUmSdE3msqg);
    background-size: 200%; animation: x-fractal-shift 20s linear infinite;
    opacity: 0.2; mix-blend-mode: screen; position: fixed; top: 0; left: 0; width: 100%; height: 100%;
  }
  .x-shard-inner-fractal {
    position: absolute; inset: 0;
    background-image: url(https://lh3.googleusercontent.com/aida-public/AB6AXuCCF-Wu0arOTEDRI7pEIgN9zoNVdLKE4WsdOdqmG-mtDHqHKeMqx_pBPtjbjQ4HLpooT9zBpJxFZIdyqmNhwaR3F5bS0VU9SZlVRdaD5SIIexczbDXVJLbC3fYM2lj-LBSQE8z_t1hhuH-YwO4BAU9o7bwkQAjqbW5Q1Lla1YTPzZjwno57NJKB4OVSqJNG42o5Uyn6rRNAztZgkm42__gqzmM9KOWda7YxxqhQfjXKC-JYyYqX7MWlCNskOFkjixU_RUmSdE3msqg);
    background-size: cover; mix-blend-mode: overlay; opacity: 0.3; animation: x-fractal-shift 10s alternate infinite; pointer-events: none;
  }
  .x-glitch-hover { position: relative; }
  .x-glitch-hover:hover::after {
    content: ""; position: absolute; inset: 0; background: inherit;
    animation: x-glitch-anim 0.3s infinite; z-index: 20; mix-blend-mode: hard-light; opacity: 0.8;
  }
</style>
</BaseLayout>
