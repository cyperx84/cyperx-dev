---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="CYPERX.DEV // PROJECTS" activeNav="projects">

  <!-- ════════════════════════════════════════
       DARK VARIANT — projects-neural-labs
  ════════════════════════════════════════ -->
  <div class="variant-dark bg-[#131313] text-[#e2e2e2] min-h-screen">
    <div class="fixed inset-0 z-[100] pointer-events-none opacity-20" style="background:linear-gradient(to bottom,rgba(255,255,255,0) 50%,rgba(0,0,0,.1) 50%),linear-gradient(90deg,rgba(255,0,0,.03),rgba(0,255,0,.01),rgba(0,0,255,.03));background-size:100% 4px,3px 100%;"></div>

    <!-- Header -->
    <nav class="fixed top-0 w-full flex justify-between items-center px-4 sm:px-8 py-4 sm:py-6 bg-[#131313]/80 backdrop-blur-xl z-50 nav-header">
      <div class="text-2xl sm:text-3xl font-black text-[#39FF14] [text-shadow:2px_0_#FF51FA,-2px_0_#AC89FF] font-['Space_Grotesk'] uppercase tracking-tighter italic animate-pulse">CYPERX.DEV</div>
      <div class="hidden md:flex gap-8 lg:gap-12 font-['Space_Grotesk'] uppercase tracking-tighter italic">
        <a class="text-[#e2e2e2] hover:text-[#FF51FA] hover:skew-x-12 transition-all duration-75" href="/">HOME</a>
        <a class="text-[#e2e2e2] hover:text-[#FF51FA] hover:skew-x-12 transition-all duration-75" href="/blog">BLOG</a>
        <a class="text-[#39FF14] border-b-2 border-[#39FF14] pb-1 hover:text-[#FF51FA] hover:skew-x-12 transition-all duration-75" href="/projects">PROJECTS</a>
      </div>
      <button class="bg-[#39FF14] text-black px-4 sm:px-6 py-2 font-black italic tracking-tighter text-xs sm:text-sm" style="clip-path:polygon(10% 0,100% 0,90% 100%,0 100%)">TRIPP_MODE</button>
    </nav>

    <main class="pt-28 sm:pt-32 pb-16 sm:pb-24 px-4 sm:px-6 lg:px-20 max-w-screen-2xl mx-auto">
      <!-- Hero -->
      <header class="mb-20 sm:mb-32">
        <div class="flex items-center gap-4 mb-6 flex-wrap">
          <span class="font-mono text-[#39FF14] text-xs sm:text-sm tracking-widest bg-[#353535] px-3 py-1">SYSTEM_STATUS: ACTIVE</span>
          <div class="h-[2px] flex-grow bg-gradient-to-r from-[#39FF14] to-transparent"></div>
        </div>
        <h1 class="text-4xl sm:text-6xl lg:text-9xl font-black uppercase tracking-tighter italic leading-none mb-6 sm:mb-8">
          Neural<br/>
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#39FF14] via-[#FF51FA] to-[#e5d7ff]">Experiments</span>
        </h1>
        <p class="max-w-2xl text-base sm:text-xl text-[#baccb0] leading-relaxed">
          Breaching the interface between biological consciousness and synthetic architecture. These shards represent 0.01% of the terminal entropy logged in the void.
        </p>
      </header>

      <!-- Project Grid -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-y-20 sm:gap-y-32 gap-x-8 lg:gap-x-16 relative">

        <!-- Project 01 -->
        <div class="group relative flex flex-col items-start">
          <div class="absolute -top-12 -left-8 font-mono text-7xl sm:text-9xl text-[#353535] opacity-20 font-black z-0">01</div>
          <div class="relative w-full aspect-[4/3] bg-[#2a2a2a] overflow-hidden shard-clip-1 transition-all duration-500 hover:scale-[1.02] hover:-rotate-1 z-10">
            <img alt="Fractal digital patterns" class="w-full h-full object-cover grayscale contrast-125 group-hover:grayscale-0 transition-all duration-700 blur-[2px] group-hover:blur-0" src="https://lh3.googleusercontent.com/aida-public/AB6AXuAMLs646RYBEcNq9KsYvkSSFOOOso6g35yHIpDU_O9oZKRKlUM3OhobOBvbRRywDUn57adyRlqcUTbss0qk6qD_bP1hzVSSyz92D0rbCg9KQsJxFnTYMQF1lul7FNcWVug1Stt06omRl0ql5X9gSZ0RwMF0uIcgPulnICGf5UmCnEnsOgPPN6Atd7s_3y8UGwXj7B-4OuXSjJscYz-qJ-zMo3qFQWhVkXvsTRya3GFsB_J5Y_H6ln8AqCAQnD1cTTwN-g4rdwgPhVc" loading="lazy" />
            <div class="absolute inset-0 bg-gradient-to-t from-[#131313] to-transparent opacity-60"></div>
            <div class="absolute top-4 sm:top-6 right-4 sm:right-6 font-mono text-[#39FF14] bg-[#131313]/80 backdrop-blur px-3 sm:px-4 py-1 sm:py-2 border border-[#39FF14]/20 text-xs sm:text-sm">LATENCY: 4ms</div>
          </div>
          <div class="mt-6 sm:mt-8 px-2 sm:px-4 z-20">
            <h3 class="text-2xl sm:text-4xl font-black italic tracking-tighter mb-3 sm:mb-4 group-hover:text-[#39FF14] transition-colors">PROJECT_VOID_WALKER</h3>
            <p class="font-mono text-xs sm:text-sm text-[#FF51FA] mb-4 sm:mb-6 tracking-tight">STATUS: DECRYPTING_ARRAY...</p>
            <p class="text-[#baccb0] mb-6 sm:mb-8 max-w-md text-sm sm:text-base">A generative architecture that maps user biometric feedback into real-time procedural voxel landscapes.</p>
            <button class="bg-[#39FF14] text-black px-6 sm:px-8 py-3 sm:py-4 font-black italic tracking-tighter liquid-shadow hover:bg-[#FF51FA] transition-all hover:translate-x-2" style="clip-path:polygon(5% 0,100% 0,95% 100%,0 100%)">INITIATE_BREACH</button>
          </div>
        </div>

        <!-- Project 02 -->
        <div class="group relative flex flex-col items-end text-right lg:mt-48">
          <div class="absolute -top-12 -right-8 font-mono text-7xl sm:text-9xl text-[#353535] opacity-20 font-black z-0">02</div>
          <div class="relative w-full aspect-[4/3] bg-[#2a2a2a] overflow-hidden shard-clip-2 transition-all duration-500 hover:scale-[1.02] hover:rotate-1 z-10">
            <img alt="Cybernetic data clusters" class="w-full h-full object-cover grayscale contrast-125 group-hover:grayscale-0 transition-all duration-700 blur-[2px] group-hover:blur-0" src="https://lh3.googleusercontent.com/aida-public/AB6AXuD3xKb8JnprxqKBS0Fz4AU2GO9qS3lH7liyTzaZoC9jLd-G0JVrQieKrIZ7q70Z8p9fEtiltX15B-sI8e71VeD1VegJp5fPkItiG11-sw8k8bcXMxRBNHtoetMAYomWEme0OoWklqPbegIrSDkxT6CMsaKzuHV0_4e8d9OpjYjOoIr-PadAPVhUj5zuHqb8y7wBLJIklTmEWZwcB4uu1LLc9gXeQFY06NiwEe-F32lF-MuFXQeFGhx8cRuGTOUD8ZVKjsGpG1K5oEo" loading="lazy" />
            <div class="absolute inset-0 bg-gradient-to-t from-[#131313] to-transparent opacity-60"></div>
            <div class="absolute top-4 sm:top-6 left-4 sm:left-6 font-mono text-[#FF51FA] bg-[#131313]/80 backdrop-blur px-3 sm:px-4 py-1 sm:py-2 border border-[#FF51FA]/20 text-xs sm:text-sm">ENTROPY: 94%</div>
          </div>
          <div class="mt-6 sm:mt-8 px-2 sm:px-4 z-20">
            <h3 class="text-2xl sm:text-4xl font-black italic tracking-tighter mb-3 sm:mb-4 group-hover:text-[#FF51FA] transition-colors">SYNTHETIC_ECHO</h3>
            <p class="font-mono text-xs sm:text-sm text-[#39FF14] mb-4 sm:mb-6 tracking-tight">RECURSION_LEVEL: 0x09</p>
            <p class="text-[#baccb0] mb-6 sm:mb-8 max-w-md ml-auto text-sm sm:text-base">Deep-learning audio synthesizers that capture ambient electronic smog and convert it into melodic ghost-data.</p>
            <button class="bg-[#FF51FA] text-white px-6 sm:px-8 py-3 sm:py-4 font-black italic tracking-tighter hover:bg-[#39FF14] hover:text-black transition-all hover:-translate-x-2" style="clip-path:polygon(5% 0,100% 0,95% 100%,0 100%);box-shadow:0 0 20px rgba(255,81,250,0.4)">ACCESS_TERMINAL</button>
          </div>
        </div>

        <!-- Project 03 -->
        <div class="group relative flex flex-col items-start lg:-mt-24">
          <div class="absolute -top-12 -left-8 font-mono text-7xl sm:text-9xl text-[#353535] opacity-20 font-black z-0">03</div>
          <div class="relative w-full aspect-video bg-[#2a2a2a] overflow-hidden shard-clip-3 transition-all duration-500 hover:scale-[1.02] hover:skew-y-1 z-10">
            <img alt="Iridescent liquid metal" class="w-full h-full object-cover grayscale contrast-125 group-hover:grayscale-0 transition-all duration-700 blur-[2px] group-hover:blur-0" src="https://lh3.googleusercontent.com/aida-public/AB6AXuAdBfEfKLYQNmmKw2HK37tgSCu9kgVugHN4zmM19TJZ6wLcSqkfZ3-hqkOq4H6-fQwQM5lKCSxU-_pBbPPbtE6AXhmSQMX7JrqMDRMfhyLk6W9akMGyRKWXEf89OgOlOXFASLYy3rVSXdLG1jTVTbwfA4vKCR7YgDoysAw1h_I2IvEfVJXDmiSLzEd7yKjHDpwble0S3rP6gS1PnO9OjfgwRgXOXKjEN63iqh3ulwBEzRJb-RzL8px9UN0N6ESDpL_Bb6Iqd-cO094" loading="lazy" />
            <div class="absolute inset-0 bg-gradient-to-t from-[#131313] to-transparent opacity-60"></div>
          </div>
          <div class="mt-6 sm:mt-8 px-2 sm:px-4 z-20">
            <h3 class="text-2xl sm:text-4xl font-black italic tracking-tighter mb-3 sm:mb-4 group-hover:text-[#d1bcff] transition-colors">LIQUID_DREAMS_v2</h3>
            <p class="font-mono text-xs sm:text-sm text-[#baccb0] mb-4 sm:mb-6 tracking-tight">ENCRYPTION: QUANTUM_64</p>
            <p class="text-[#baccb0] mb-6 sm:mb-8 max-w-md text-sm sm:text-base">A browser-based shader experiment utilizing WebGL to simulate the flow of data within a non-Euclidean digital ocean.</p>
            <button class="bg-[#393939] text-[#e2e2e2] px-6 sm:px-8 py-3 sm:py-4 font-black italic tracking-tighter border border-[#39FF14]/40 hover:bg-[#39FF14] hover:text-black transition-all" style="clip-path:polygon(5% 0,100% 0,95% 100%,0 100%)">RUN_SCRIPT</button>
          </div>
        </div>

        <!-- Project 04 — Bento Shard -->
        <div class="group relative flex flex-col items-center justify-center lg:mt-24 p-8 sm:p-12 bg-[#0e0e0e] border border-[#39FF14]/10 overflow-hidden" style="clip-path:polygon(0% 10%,100% 0%,90% 100%,10% 90%)">
          <div class="absolute inset-0 opacity-10 pointer-events-none">
            <img alt="Network grid" class="w-full h-full object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDEqs2_hnURmltmYXuRuiP5LSWgCjVRyGrw4Mi2LOcE-leNdceKhkMr4b7X4ZsFuscW4CuMlIb2tDJrpAHRCfNVsw1h6pScP7jJcvR07IgtY3KBuq7AeNnJO9Ck7E051ZQTPY76EsPthfmp82xdYoq8llVlPFIuIDa08K1WIhXzI0bk9U7jQ1fDA3iWezKh8wCRjbNQQ38GEOOy_3wYOo68a7UZBf2a-fLWddgv08TvdfpBCxQk0Kf8ySftQ6Npij9u5EcAG0Y82HU" loading="lazy" />
          </div>
          <div class="relative z-10 text-center">
            <span class="material-symbols-outlined text-5xl sm:text-6xl text-[#39FF14] mb-4 sm:mb-6 animate-pulse block">radar</span>
            <h3 class="text-2xl sm:text-3xl font-black italic tracking-tighter mb-3 sm:mb-4">MORE_FRAGMENTED_DATA</h3>
            <p class="font-mono text-xs uppercase tracking-widest text-[#baccb0] mb-6 sm:mb-8">Loading upcoming experiments...</p>
            <div class="flex gap-4 justify-center">
              <div class="w-2 h-6 sm:h-8 bg-[#39FF14] animate-bounce"></div>
              <div class="w-2 h-6 sm:h-8 bg-[#FF51FA] animate-bounce" style="animation-delay:0.2s"></div>
              <div class="w-2 h-6 sm:h-8 bg-[#AC89FF] animate-bounce" style="animation-delay:0.4s"></div>
            </div>
          </div>
        </div>

      </div>
    </main>

    <!-- Footer -->
    <footer class="w-full py-10 sm:py-12 px-6 sm:px-10 flex flex-col md:flex-row justify-between items-end gap-4 bg-[#0e0e0e] site-footer">
      <div class="flex flex-col gap-2">
        <div class="text-[#39FF14] font-bold text-xl font-['Space_Grotesk'] tracking-tighter italic">CYPERX.DEV</div>
        <div class="font-mono text-[10px] uppercase tracking-widest text-[#AC89FF]">SYSTEM ENTROPY: 99.9% | STABLE BEYOND VOID</div>
      </div>
      <div class="flex gap-6 sm:gap-8 font-mono text-[10px] uppercase tracking-widest">
        {['TERMINAL','REACH_OUT','LEGAL_VOID'].map(l => <a class="text-[#e2e2e2]/60 hover:text-[#39FF14] hover:line-through transition-all hover:blur-[1px]" href="#">{l}</a>)}
      </div>
      <div class="font-mono text-[10px] text-[#e2e2e2]/40">© 2024 / NO RIGHTS RESERVED / COPYLEFT</div>
    </footer>

    <!-- Fixed accents -->
    <div class="fixed bottom-8 left-8 z-[60] flex-col gap-2 pointer-events-none hidden lg:flex">
      <div class="h-12 w-1 bg-[#39FF14]"></div>
      <div class="font-mono text-[10px] text-[#39FF14] tracking-widest" style="writing-mode:vertical-rl">CONNECTED_TO_NODE_7</div>
    </div>
    <div class="fixed top-1/2 right-4 -translate-y-1/2 z-[60] hidden lg:flex flex-col gap-8 pointer-events-none opacity-40">
      <span class="font-mono text-xs">P_01</span>
      <span class="font-mono text-xs text-[#39FF14]">P_02</span>
      <span class="font-mono text-xs">P_03</span>
      <span class="font-mono text-xs">P_04</span>
    </div>

    <!-- Mobile nav -->
    <div class="md:hidden fixed bottom-0 left-0 right-0 bg-[#131313]/90 backdrop-blur-lg border-t border-[#39FF14]/20 flex justify-around items-center py-3 z-50">
      {[['home','HOME','/'],['terminal','BLOG','/blog'],['shield','PROJECTS','/projects']].map(([icon, label, href]) => (
        <a href={href} class="flex flex-col items-center text-[#39FF14]">
          <span class="material-symbols-outlined text-xl">{icon}</span>
          <span class="text-[10px] font-mono mt-1">{label}</span>
        </a>
      ))}
    </div>
  </div>


  <!-- ════════════════════════════════════════
       LIGHT VARIANT — projects-white-void
  ════════════════════════════════════════ -->
  <div class="variant-light min-h-screen" style="background:#efffe3; color:#0e0e0e;">
    <div class="fixed inset-0 z-[100] pointer-events-none" style="background:repeating-linear-gradient(0deg,rgba(0,0,0,0.05) 0px,rgba(0,0,0,0.05) 1px,transparent 1px,transparent 2px);"></div>

    <!-- Header -->
    <header class="fixed top-0 w-full flex justify-between items-center px-4 sm:px-8 py-4 sm:py-6 bg-[#131313]/80 backdrop-blur-xl z-50 nav-header">
      <div class="text-2xl sm:text-3xl font-black text-[#39FF14] [text-shadow:2px_0_#FF51FA,-2px_0_#AC89FF] animate-pulse font-['Space_Grotesk'] uppercase tracking-tighter italic">CYPERX.DEV</div>
      <nav class="hidden md:flex gap-6 sm:gap-8 items-center">
        <a class="font-['Space_Grotesk'] uppercase tracking-tighter italic text-[#e2e2e2] hover:text-[#FF51FA] hover:skew-x-12 transition-all duration-75" href="/">HOME</a>
        <a class="font-['Space_Grotesk'] uppercase tracking-tighter italic text-[#e2e2e2] hover:text-[#FF51FA] hover:skew-x-12 transition-all duration-75" href="/blog">BLOG</a>
        <a class="font-['Space_Grotesk'] uppercase tracking-tighter italic text-[#39FF14] border-b-2 border-[#39FF14] pb-1 hover:text-[#FF51FA] hover:skew-x-12 transition-all duration-75" href="/projects">PROJECTS</a>
      </nav>
      <button class="bg-[#39FF14] text-black px-4 sm:px-6 py-2 font-black italic text-xs sm:text-sm over-expose transition-all" style="clip-path:polygon(10% 0,100% 0,90% 100%,0 100%)">TRIPP_MODE</button>
    </header>

    <main class="pt-28 sm:pt-32 pb-16 sm:pb-24 px-4 sm:px-6 lg:px-12 max-w-7xl mx-auto min-h-screen">
      <!-- Hero -->
      <section class="mb-20 sm:mb-32 relative">
        <div class="absolute -top-20 -left-20 w-96 h-96 bg-[#FF51FA]/10 blur-[120px] rounded-full"></div>
        <div class="relative z-10">
          <span class="font-mono text-xs tracking-[0.5em] text-[#353535] mb-4 block">STABLE_BRANCH // V.04</span>
          <h1 class="text-5xl sm:text-7xl lg:text-[10rem] font-black leading-none tracking-tighter text-[#FF51FA] glitch-text italic uppercase">
            EXPERIMENTAL_<br/>SHARDS
          </h1>
          <div class="mt-6 sm:mt-8 max-w-2xl text-base sm:text-xl font-bold uppercase italic text-[#353535] leading-tight">
            DECONSTRUCTING THE MONOLITH. A COLLECTION OF BEYOND-VOID INTERFACES AND LIQUID ARCHITECTURES.
          </div>
        </div>
      </section>

      <!-- Projects Bento Grid -->
      <div class="grid grid-cols-1 md:grid-cols-12 gap-4 sm:gap-6 items-start">

        <!-- Featured Card 1 -->
        <div class="md:col-span-8 group relative bg-white shard-path-1 p-1 over-expose transition-all">
          <div class="absolute inset-0 border-2 border-[#39FF14] opacity-20 group-hover:opacity-100 transition-opacity"></div>
          <div class="bg-white p-6 sm:p-8 min-h-[350px] sm:min-h-[500px] flex flex-col justify-end">
            <div class="relative w-full aspect-video bg-[#0e0e0e] mb-6 sm:mb-8 overflow-hidden" style="clip-path:polygon(0 0,100% 2%,98% 100%,2% 98%)">
              <img class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-500 scale-110 group-hover:scale-100" src="https://lh3.googleusercontent.com/aida-public/AB6AXuAWknMGUHAVfM44TSJNPSCtsWD8x4MKQiwv8bF9DZrIjT-DGF2l0iGzsHJkk1AjcGlv1df8OsSCDGhLIiSQErRX-HIeWtMNoRG3mGz_jiIoxKmhXrOjSXyka8zmxEbbTnEhMQGpersrc-iBRcMhZFM6YSN5RnvBdCbhJKh3unsFWvX7WIA4k-wZJbbPpQAuG_RjcewjpO_36jJ7ohpZeMx_TnKGSl-8anuIcArPYxlnasvay2zFk_gUsMXHId0wvg9GyHtkVqc4ES4" alt="Neon fluid patterns" loading="lazy" />
            </div>
            <div class="flex justify-between items-end flex-wrap gap-4">
              <div>
                <h3 class="text-2xl sm:text-4xl font-black text-[#0e0e0e] uppercase italic leading-none">VOID_WALKER_UI</h3>
                <p class="mt-3 sm:mt-4 font-mono text-xs text-[#353535] max-w-md uppercase tracking-wider">High-frequency sensory immersion dashboard for orbital maintenance systems.</p>
              </div>
              <span class="material-symbols-outlined text-4xl sm:text-5xl text-[#39FF14]" style="font-variation-settings:'FILL' 1">arrow_outward</span>
            </div>
          </div>
        </div>

        <!-- Side Card 1 -->
        <div class="md:col-span-4 group relative bg-white shard-path-2 p-1 over-expose transition-all">
          <div class="bg-white p-4 sm:p-6 h-full flex flex-col">
            <div class="aspect-square bg-[#FF51FA]/20 mb-4 sm:mb-6 overflow-hidden" style="clip-path:polygon(5% 5%,95% 0,100% 90%,0 100%)">
              <img class="w-full h-full object-cover contrast-150" src="https://lh3.googleusercontent.com/aida-public/AB6AXuA8H_8W-PHVsc5sUDUqDlaP11xpSXEeTsYyCuG3x5qycsROfY1fSdY_9RdiE5DJGfM0EWg-5lg-rhCQ7m8los3jaVhby22sXvGqkK1rITuf9X-e5dFsxlSKQNO34a7iJkXyHd0crHVMXtW_HPqnmCWu7WOroknkcp4weU9JzzrT8LVu1HuPUzox8Jm_WsZQy5Ec9WJ62tKeUYEmt9LvHlbRyn4_n8mgwW7Z6aODAAr7ACq4-H2UljERBmV7cEXSJm8FB5ZiIsQ9EPk" alt="Digital distortion" loading="lazy" />
            </div>
            <h3 class="text-xl sm:text-2xl font-black text-[#0e0e0e] uppercase italic">SHARD_001</h3>
            <p class="mt-2 font-mono text-[10px] text-[#353535] uppercase">DECENTRALIZED_VISUAL_NODE</p>
          </div>
        </div>

        <!-- Side Card 2 -->
        <div class="md:col-span-4 group relative bg-white shard-path-3 p-1 over-expose transition-all">
          <div class="bg-white p-4 sm:p-6 h-full flex flex-col">
            <div class="flex-grow flex items-center justify-center py-8 sm:py-12">
              <span class="material-symbols-outlined text-6xl sm:text-8xl text-[#FF51FA] animate-pulse">database</span>
            </div>
            <h3 class="text-xl sm:text-2xl font-black text-[#0e0e0e] uppercase italic">DATA_MELT</h3>
            <p class="mt-2 font-mono text-[10px] text-[#353535] uppercase">VOLATILE_STORAGE_LOGS</p>
          </div>
        </div>

        <!-- Featured Card 2 -->
        <div class="md:col-span-8 group relative bg-white shard-path-1 p-1 over-expose transition-all">
          <div class="bg-white p-6 sm:p-8 min-h-[300px] sm:min-h-[400px] flex flex-col md:flex-row gap-6 sm:gap-8">
            <div class="w-full md:w-1/2 aspect-square bg-[#0e0e0e] overflow-hidden" style="clip-path:polygon(0 0,100% 5%,95% 100%,5% 95%)">
              <img class="w-full h-full object-cover grayscale contrast-125" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBVeAjRoF7P9BYE2OIvPNQup6AHSbF3-DzwykhnWvoW7wgWJe1yIoGl_rXjusJt9fWWkYTCbzGY6e18Cb_2UPX8U0Nl4-98qz21U7mqBb5BToAAatc0y21LdtEZzfUeho65LN7MYH5JqczVcjWNWUt4MkE9rVbdHaOjj3WqUYfATWFYNbWRgtdsFCUg7TlIU0kBGHawMav6swux9LyqjcdOrvejFRV9MWoFy9_lEw_Rs7m3zGgBFH8uARSGSxSDfRXKvrCfPH6eFwg" alt="Glass shards" loading="lazy" />
            </div>
            <div class="w-full md:w-1/2 flex flex-col justify-between">
              <div>
                <span class="bg-[#39FF14] text-black px-2 py-1 font-mono text-[10px]">ACTIVE_RESEARCH</span>
