---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const projects = await getCollection('projects');
---

<BaseLayout title="PROJECTS" activeNav="projects">
  <div class="flex flex-col items-center gap-16 pt-20 lg:pt-32 pb-64">

    <div class="w-full max-w-4xl">
      <h1 class="font-heading text-[60px] md:text-[90px] leading-[0.75] text-white uppercase glitch-shadow-intense break-words mb-4 melting-text">
        SYS<span class="text-primary">_MODULES</span>
      </h1>
      <p class="font-mono text-muted text-sm tracking-[0.5em] mb-16 animate-pulse">ls -la /sys/modules/projects/</p>
    </div>

    <div class="w-full max-w-4xl flex flex-col gap-8">
      {projects.map((project) => (
        <div class="border-4 border-primary bg-surface p-8 lg:p-12 relative group hover:border-accent-red transition-all cursor-crosshair overflow-hidden reveal-element active">
          <div class="absolute inset-0 bg-primary/5 group-hover:bg-accent-red/5 transition-colors pointer-events-none"></div>
          <div class="absolute inset-0 bg-[repeating-linear-gradient(45deg,transparent,transparent_2px,rgba(0,255,255,0.02)_2px,rgba(0,255,255,0.02)_4px)] pointer-events-none"></div>

          <div class="flex flex-col gap-6 relative z-10">
            <div class="flex items-center justify-between border-b-2 border-primary/40 pb-4">
              <h2 class="text-3xl lg:text-5xl font-black uppercase tracking-tighter text-white glitch-text group-hover:text-primary transition-colors">{project.data.title}</h2>
              <span class:list={[
                "text-xs font-mono font-black px-4 py-2 uppercase",
                project.data.status === 'ACTIVE' && "bg-primary text-black",
                project.data.status === 'EXPERIMENTAL' && "bg-accent-magenta text-white animate-pulse",
                project.data.status === 'ARCHIVED' && "bg-muted text-white",
              ]}>[{project.data.status}]</span>
            </div>

            <p class="text-gray-400 font-mono text-lg leading-relaxed">{project.data.description}</p>

            <div class="flex flex-wrap gap-3">
              {project.data.tags.map((tag: string) => (
                <span class="text-[10px] font-mono text-primary border border-primary/30 px-3 py-1">[{tag}]</span>
              ))}
            </div>

            <div class="flex gap-6 mt-4 font-code text-sm">
              {project.data.github && (
                <a href={project.data.github} class="text-primary border-b-2 border-primary hover:text-accent-red hover:border-accent-red transition-colors uppercase font-bold">[&gt; GITHUB]</a>
              )}
              {project.data.url && (
                <a href={project.data.url} class="text-accent-magenta border-b-2 border-accent-magenta hover:text-primary hover:border-primary transition-colors uppercase font-bold">[&gt; LIVE_DEPLOY]</a>
              )}
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- System Status Footer -->
    <div class="w-full max-w-4xl text-center mt-16">
      <div class="font-mono text-[10px] text-muted space-y-1 opacity-50">
        <p>MODULES_LOADED: {projects.length}</p>
        <p>SYSTEM_INTEGRITY: COMPROMISED</p>
        <p>ENTROPY_LEVEL: MAXIMUM</p>
      </div>
    </div>
  </div>
</BaseLayout>
