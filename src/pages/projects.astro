---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="💀 Projects — CyperX.dev" activeNav="projects">
  <div class="w-full max-w-4xl py-8 sm:py-16">
    <div class="fractal-card p-6 sm:p-10 relative">
      <div class="chaos-sticker sticker-magenta absolute -top-4 -right-4 -rotate-2 hidden sm:block">ACTIVE_BUILDS</div>
      <h1 class="font-black uppercase tracking-tighter text-4xl sm:text-6xl lg:text-8xl text-primary mb-4 sm:mb-6" style="font-family: 'Rubik Glitch', cursive;">
        PROJECTS
      </h1>
      <div class="glitch-bar-static mb-6 sm:mb-8"></div>
      <div class="font-mono text-sm sm:text-base space-y-3 text-gray-400">
        <p><span class="text-primary">root@cyperx:~#</span> ps aux | grep builds</p>
        <p class="pl-4 text-[#00FFFF]">🔧 &nbsp;OpenClaw &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;— agent fleet, always running</p>
        <p class="pl-4 text-[#FF003C]">💀 &nbsp;cyperx.dev &nbsp;&nbsp;— this glitch right here</p>
        <p class="pl-4 text-[#FF00FF]">🍄 &nbsp;deep-research — autonomous research engine</p>
        <p class="pl-4 text-yellow-400">⚡ &nbsp;more_builds &nbsp;— [REDACTED]</p>
        <p><span class="text-primary">root@cyperx:~#</span> <span class="animate-pulse text-white">_</span></p>
      </div>
      <div class="corrupt-block mt-8 sm:mt-12"></div>
      <p class="font-mono text-xs text-muted mt-4 tracking-widest animate-pulse">MORE_PROJECTS_INCOMING :: STANDBY</p>
    </div>
  </div>
</BaseLayout>
