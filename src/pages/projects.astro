---
import BaseLayout from '../layouts/BaseLayout.astro';
import { projects } from '../data/projects';

const featured = projects[0];
const rest = projects.slice(1);
---
<BaseLayout title="CYPERX.DEV // PROJECTS" activeNav="projects">

  <!-- ════════════════════════════════════════
       DARK VARIANT
  ════════════════════════════════════════ -->
  <div class="variant-dark bg-[#131313] text-[#e2e2e2] min-h-screen">
    <main class="pt-28 sm:pt-32 pb-16 sm:pb-24 px-4 sm:px-6 lg:px-12 max-w-7xl mx-auto">
      <!-- Hero -->
      <header class="mb-20 sm:mb-32">
        <div class="flex items-center gap-4 mb-6 flex-wrap">
          <span class="font-mono text-[#39FF14] text-xs sm:text-sm tracking-widest bg-[#353535] px-3 py-1">SYSTEM_STATUS: ACTIVE</span>
          <div class="h-[2px] flex-grow bg-gradient-to-r from-[#39FF14] to-transparent"></div>
        </div>
        <h1 class="text-4xl sm:text-6xl lg:text-9xl font-black uppercase tracking-tighter italic leading-none mb-6 sm:mb-8" data-reveal>
          Neural<br/>
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#39FF14] via-[#FF51FA] to-[#e5d7ff]">Experiments</span>
        </h1>
        <p class="max-w-2xl text-base sm:text-xl text-[#baccb0] leading-relaxed" data-reveal>
          Things I'm building. Some shipped, some in progress, some held together with duct tape and vibes. All real.
        </p>
      </header>

      <!-- Featured Project -->
      <div class="mb-20 sm:mb-32 group relative">
        <div class="absolute -top-12 -left-8 font-mono text-7xl sm:text-9xl text-[#353535] opacity-20 font-black z-0">00</div>
        <a href={`/projects/${featured.slug}`} class="block relative bg-[#2a2a2a] shard-clip-1 melt-effect animated-border border-l-8 border-[#39FF14] p-6 sm:p-8 lg:p-12 z-10">
          <div class="flex flex-col md:flex-row gap-6 sm:gap-8">
            <div class="w-full md:w-2/3">
              <div class="flex items-center gap-3 mb-4">
                <span class="font-mono text-xs px-2 py-1 font-black" style={`background:${featured.statusColor}; color:black`}>{featured.status}</span>
                <span class="font-mono text-[10px] text-[#FF51FA]">ENTROPY: {featured.entropy}%</span>
              </div>
              <h2 class="text-2xl sm:text-4xl lg:text-5xl font-black uppercase leading-none mb-4 sm:mb-6 group-hover:text-[#39FF14] transition-colors italic tracking-tighter">{featured.name.replace(/ /g, '_').toUpperCase()}</h2>
              <p class="text-[#39FF14] font-mono text-sm mb-4 italic">{featured.tagline}</p>
              <p class="text-[#baccb0] mb-6 sm:mb-8 text-sm sm:text-base max-w-2xl">{featured.description}</p>
              <div class="flex flex-wrap gap-2 mb-6">
                {featured.stack.map(tech => (
                  <span class="px-3 py-1 bg-[#1f1f1f] border border-[#39FF14]/20 text-[10px] font-mono text-[#39FF14]">{tech}</span>
                ))}
              </div>
              <div class="flex gap-4">
                {featured.links.github && (
                  <span class="bg-[#39FF14] text-black px-6 sm:px-8 py-3 font-black italic tracking-tighter" style="clip-path:polygon(5% 0,100% 0,95% 100%,0 100%)">VIEW_SOURCE</span>
                )}
                {featured.links.live && (
                  <span class="bg-[#FF51FA] text-white px-6 sm:px-8 py-3 font-black italic tracking-tighter" style="clip-path:polygon(5% 0,100% 0,95% 100%,0 100%)">OPEN_LIVE</span>
                )}
              </div>
            </div>
            <div class="w-full md:w-1/3 flex items-center justify-center">
              <div class="w-full aspect-square bg-[#1f1f1f] border border-[#39FF14]/10 flex items-center justify-center">
                <span class="material-symbols-outlined text-[#39FF14] text-8xl opacity-20">hub</span>
              </div>
            </div>
          </div>
        </a>
      </div>

      <!-- Project Grid -->
      <div class="grid grid-cols-1 md:grid-cols-12 gap-8 sm:gap-12">
        {rest.map((project, i) => {
          const spans = ["md:col-span-4", "md:col-span-8", "md:col-span-6", "md:col-span-6", "md:col-span-5"];
          const clips = ["shard-clip-2", "shard-clip-3", "shard-clip-1", "shard-clip-2", "shard-clip-1"];
          const borders = [
            "border-r-4 border-[#FF51FA]",
            "border-l-4 border-[#AC89FF]",
            "border-b-4 border-[#39FF14]",
            "border-t-4 border-[#FF51FA]",
            "border-l-4 border-[#39FF14]",
          ];
          const colors = ["#FF51FA", "#AC89FF", "#39FF14", "#FF51FA", "#39FF14"];
          return (
            <article class={`${spans[i]} group`} data-reveal>
              <a href={`/projects/${project.slug}`} class={`block bg-[#0e0e0e] ${clips[i]} ${borders[i]} p-6 sm:p-8 h-full flex flex-col justify-between hover:bg-[#1f1f1f] transition-colors no-underline`}>
                <div>
                  <div class="flex items-center justify-between mb-4">
                    <span class="font-mono text-xs px-2 py-1 font-black" style={`background:${project.statusColor}; color:black`}>{project.status}</span>
                    <span class="font-mono text-[10px]" style={`color:${colors[i]}`}>E:{project.entropy}%</span>
                  </div>
                  <h3 class="text-xl sm:text-2xl font-black italic tracking-tighter mb-3 group-hover:text-[#39FF14] transition-colors">{project.name.replace(/ /g, '_').toUpperCase()}</h3>
                  <p class="font-mono text-xs text-[#FF51FA] mb-4 italic">{project.tagline}</p>
                  <p class="text-[#baccb0] mb-4 text-sm">{project.description}</p>
                  <div class="flex flex-wrap gap-2">
                    {project.stack.map(tech => (
                      <span class="px-2 py-1 bg-[#1f1f1f] text-[8px] font-mono text-[#e2e2e2]/40">{tech}</span>
                    ))}
                  </div>
                </div>
                <div class="mt-6 sm:mt-8 flex items-center gap-4 font-mono text-[10px] border-t border-[#e2e2e2]/10 pt-4">
                  <span>ENTROPY: {project.entropy}%</span>
                  {project.links.github && <span style={`color:${colors[i]}`}>SOURCE_&gt;&gt;</span>}
                  {project.links.live && <span style={`color:${colors[i]}`}>LIVE_&gt;&gt;</span>}
                </div>
              </a>
            </article>
          );
        })}
      </div>

      <!-- Coming Soon -->
      <div class="mt-20 sm:mt-32 p-8 sm:p-12 bg-[#0e0e0e] border border-[#39FF14]/10 text-center" style="clip-path:polygon(0% 10%,100% 0%,90% 100%,10% 90%)">
        <span class="material-symbols-outlined text-5xl sm:text-6xl text-[#39FF14] mb-4 animate-pulse block">radar</span>
        <h3 class="text-2xl sm:text-3xl font-black italic tracking-tighter mb-3">MORE_INCOMING</h3>
        <p class="font-mono text-xs uppercase tracking-widest text-[#baccb0]">Loading next batch of experiments...</p>
      </div>
    </main>
  </div>


  <!-- ════════════════════════════════════════
       LIGHT VARIANT
  ════════════════════════════════════════ -->
  <div class="variant-light min-h-screen bg-white text-[#131313]">
    <main class="pt-28 sm:pt-32 pb-16 sm:pb-24 px-4 sm:px-6 lg:px-12 max-w-7xl mx-auto min-h-screen">
      <!-- Hero -->
      <section class="mb-20 sm:mb-32 relative">
        <div class="absolute -top-20 -left-20 w-96 h-96 bg-[#FF51FA]/10 blur-[120px] rounded-full"></div>
        <div class="relative z-10">
          <span class="font-mono text-xs tracking-[0.5em] text-[#353535] mb-4 block">STABLE_BRANCH // {projects.length} PROJECTS</span>
          <h1 class="text-5xl sm:text-7xl lg:text-[10rem] font-black leading-none tracking-tighter text-[#FF51FA] glitch-text italic uppercase" data-reveal>
            BUILD_<br/>LOG
          </h1>
          <div class="mt-6 sm:mt-8 max-w-2xl text-base sm:text-xl font-bold uppercase italic text-[#353535] leading-tight">
            REAL PROJECTS. REAL CODE. MOSTLY WORKING.
          </div>
        </div>
      </section>

      <!-- Featured Project -->
      <div class="mb-20 sm:mb-32 group relative">
        <div class="absolute -top-12 -left-8 font-mono text-7xl sm:text-9xl text-[#131313]/5 font-black z-0">00</div>
        <a href={`/projects/${featured.slug}`} class="block relative bg-[#eeeeee] shard-clip-1 animated-border border-l-8 border-[#39FF14] p-6 sm:p-8 lg:p-12 z-10 no-underline">
          <div class="flex flex-col md:flex-row gap-6 sm:gap-8">
            <div class="w-full md:w-2/3">
              <div class="flex items-center gap-3 mb-4">
                <span class="text-white font-mono text-xs px-2 py-1 font-black" style={`background:${featured.statusColor}`}>{featured.status}</span>
                <span class="font-mono text-[10px] text-[#FF51FA]">ENTROPY: {featured.entropy}%</span>
              </div>
              <h2 class="text-2xl sm:text-4xl lg:text-5xl font-black uppercase leading-none mb-4 sm:mb-6 group-hover:text-[#39FF14] transition-colors italic tracking-tighter text-[#131313]">{featured.name.replace(/ /g, '_').toUpperCase()}</h2>
              <p class="text-[#39FF14] font-mono text-sm mb-4 italic">{featured.tagline}</p>
              <p class="text-[#353535] mb-6 sm:mb-8 text-sm sm:text-base max-w-2xl">{featured.description}</p>
              <div class="flex flex-wrap gap-2 mb-6">
                {featured.stack.map(tech => (
                  <span class="px-3 py-1 bg-[#ebebeb] border border-[#39FF14]/20 text-[10px] font-mono text-[#131313]/60">{tech}</span>
                ))}
              </div>
              <div class="flex gap-4">
                {featured.links.github && (
                  <span class="bg-[#39FF14] text-black px-6 sm:px-8 py-3 font-black italic tracking-tighter" style="clip-path:polygon(5% 0,100% 0,95% 100%,0 100%)">VIEW_SOURCE</span>
                )}
                {featured.links.live && (
                  <span class="bg-[#FF51FA] text-white px-6 sm:px-8 py-3 font-black italic tracking-tighter" style="clip-path:polygon(5% 0,100% 0,95% 100%,0 100%)">OPEN_LIVE</span>
                )}
              </div>
            </div>
            <div class="w-full md:w-1/3 flex items-center justify-center">
              <div class="w-full aspect-square bg-[#ebebeb] border border-[#39FF14]/10 flex items-center justify-center">
                <span class="material-symbols-outlined text-[#39FF14] text-8xl opacity-20">hub</span>
              </div>
            </div>
          </div>
        </a>
      </div>

      <!-- Project Grid -->
      <div class="grid grid-cols-1 md:grid-cols-12 gap-6">
        {rest.map((project, i) => {
          const spans = ["md:col-span-5", "md:col-span-7", "md:col-span-7", "md:col-span-5", "md:col-span-6"];
          const clipPaths = [
            "polygon(5% 5%, 90% 0, 100% 95%, 0% 100%)",
            "polygon(0 15%, 95% 0, 100% 85%, 5% 100%)",
            "polygon(10% 0, 100% 5%, 90% 100%, 0 85%)",
            "polygon(5% 5%, 90% 0, 100% 95%, 0% 100%)",
            "polygon(0 15%, 95% 0, 100% 85%, 5% 100%)",
          ];
          const borderColors = ["#FF51FA", "#AC89FF", "#39FF14", "#FF51FA", "#AC89FF"];
          return (
            <article class={`${spans[i]} group`} data-reveal>
              <a href={`/projects/${project.slug}`} class="block p-1 transition-all duration-75 hover:skew-y-1 no-underline" style={`background:${borderColors[i]}; clip-path:${clipPaths[i]}`}>
                <div class="bg-white p-6" style={`clip-path:${clipPaths[i]}`}>
                  <div class="mb-3 flex justify-between items-start">
                    <span class="text-white text-[10px] font-mono px-2 py-1 font-black" style={`background:${project.statusColor}`}>{project.status}</span>
                    <span class="font-mono text-[10px] opacity-40">E:{project.entropy}%</span>
                  </div>
                  <h3 class="text-xl sm:text-2xl font-black uppercase mb-3 text-[#131313]">{project.name.replace(/ /g, '_').toUpperCase()}</h3>
                  <p class="font-mono text-xs text-[#FF51FA] mb-3 italic">{project.tagline}</p>
                  <p class="text-sm mb-4 opacity-70">{project.description}</p>
                  <div class="flex flex-wrap gap-2 mb-4">
                    {project.stack.slice(0, 4).map(tech => (
                      <span class="bg-[#f0f0f0] text-[9px] font-mono px-2 py-1">#{tech}</span>
                    ))}
                  </div>
                  <div class="flex items-center justify-between">
                    {project.links.github && <span class="font-mono text-[10px]" style={`color:${borderColors[i]}`}>SOURCE_&gt;&gt;</span>}
                    {project.links.live && <span class="font-mono text-[10px]" style={`color:${borderColors[i]}`}>LIVE_&gt;&gt;</span>}
                  </div>
                </div>
              </a>
            </article>
          );
        })}
      </div>

      <!-- Coming Soon -->
      <div class="mt-20 sm:mt-32 p-8 sm:p-12 bg-[#eeeeee] border border-[#39FF14]/10 text-center" style="clip-path:polygon(0% 10%,100% 0%,90% 100%,10% 90%)">
        <span class="material-symbols-outlined text-5xl sm:text-6xl text-[#39FF14] mb-4 animate-pulse block">radar</span>
        <h3 class="text-2xl sm:text-3xl font-black italic tracking-tighter mb-3 text-[#131313]">MORE_INCOMING</h3>
        <p class="font-mono text-xs uppercase tracking-widest text-[#353535]">Loading next batch of experiments...</p>
      </div>
    </main>
  </div>


  <!-- ════════════════════════════════════════
       EXTREME VARIANT
  ════════════════════════════════════════ -->
  <div class="variant-extreme min-h-screen bg-black text-white">
    <main class="relative min-h-screen pt-28 sm:pt-40 pb-16 sm:pb-24 px-4 sm:px-6 lg:px-12 max-w-7xl mx-auto">
      <div class="fixed inset-0 x-fractal-bg -z-10"></div>

      <!-- Header -->
      <div class="mb-20 sm:mb-32 relative z-10">
        <div class="flex items-center gap-4 text-[#ff51fa] font-mono text-xs sm:text-sm tracking-widest mb-4 flex-wrap">
          <span class="inline-block w-16 sm:w-24 h-[4px] bg-[#ff51fa]"></span>
          STATUS: {projects.filter(p => p.status === 'ACTIVE').length} ACTIVE // {projects.length} TOTAL
        </div>
        <h1 class="text-[10vw] sm:text-[12vw] leading-[0.8] font-black tracking-tighter glitch-text-extreme uppercase italic text-white mix-blend-difference">
          TOXIC<br/><span class="text-[#8eff71]">BUILDS</span>
        </h1>
        <div class="mt-6 sm:mt-8 p-3 sm:p-4 bg-[#8eff71] text-black inline-block font-black text-base sm:text-xl -skew-x-12">DEPLOYING TO THE VOID</div>
      </div>

      <!-- Featured -->
      <a href={`/projects/${featured.slug}`} class="block mb-16 sm:mb-24 group relative z-20 no-underline">
        <div class="absolute -inset-8 bg-gradient-to-br from-[#8eff71] via-[#ff51fa] to-[#ac89ff] blur-[100px] opacity-20 group-hover:opacity-80 transition-opacity duration-1000"></div>
        <div class="relative bg-[#191919] border-4 border-[#8eff71]/50 x-shard-melt-intense shadow-[0_0_60px_rgba(142,255,113,0.3)] overflow-hidden x-glitch-hover animated-border">
          <div class="x-shard-inner-fractal"></div>
          <div class="p-6 sm:p-12 relative z-10 space-y-6 sm:space-y-8">
            <div class="flex items-center gap-4 font-mono text-xs">
              <span class="bg-[#8eff71] text-black px-3 py-1 font-black">{featured.status}</span>
              <span class="text-[#ff51fa]">ENTROPY: {featured.entropy}%</span>
            </div>
            <h2 class="text-3xl sm:text-5xl lg:text-7xl font-black text-white uppercase tracking-tighter x-vibrating-text group-hover:text-[#8eff71]">
              {featured.name.replace(/ /g, '_').toUpperCase()}
            </h2>
            <p class="text-[#8eff71] font-mono text-sm italic">{featured.tagline}</p>
            <p class="text-white text-lg sm:text-2xl font-bold leading-tight max-w-3xl italic tracking-tight">{featured.description}</p>
            <div class="flex flex-wrap gap-3">
              {featured.stack.map(tech => (
                <span class="px-3 py-1 bg-black/50 border border-[#8eff71]/30 text-[10px] font-mono text-[#8eff71]">{tech}</span>
              ))}
            </div>
            <div class="flex flex-wrap items-center gap-6">
              {featured.links.github && (
                <span class="bg-[#8eff71] text-[#0d6100] px-8 sm:px-12 py-4 sm:py-6 font-black text-base sm:text-xl uppercase tracking-tighter shadow-[0_0_30px_rgba(142,255,113,0.8)]">
                  VIEW_SOURCE
                </span>
              )}
            </div>
          </div>
        </div>
      </a>

      <!-- Project Grid -->
      <div class="grid grid-cols-1 md:grid-cols-12 gap-8 sm:gap-12 items-start relative z-10">
        {rest.map((project, i) => {
          const spans = ["md:col-span-4", "md:col-span-8", "md:col-span-6", "md:col-span-6", "md:col-span-5"];
          const borderColors = ["#ff51fa", "#8eff71", "#ac89ff", "#ff51fa", "#8eff71"];
          const xShards = ["x-shard-sidebar", "x-shard-3", "x-shard-4", "x-shard-sidebar", "x-shard-3"];
          return (
            <article class={`${spans[i]} group`} data-reveal>
              <a href={`/projects/${project.slug}`} class={`block bg-[#111] p-6 sm:p-8 border-4 overflow-hidden relative ${xShards[i]} x-glitch-hover hover:scale-[1.02] transition-all duration-500 no-underline`} style={`border-color:${borderColors[i]}50; box-shadow:0 0 40px ${borderColors[i]}33`}>
                <div class="x-shard-inner-fractal"></div>
                <div class="relative z-10">
                  <div class="flex items-center justify-between mb-4">
                    <span class="font-mono text-[10px] px-2 py-1 font-black" style={`background:${project.statusColor}; color:black`}>{project.status}</span>
                    <span class="font-mono text-[10px] text-white/40">E:{project.entropy}%</span>
                  </div>
                  <h3 class="text-xl sm:text-2xl font-black text-white mb-2 uppercase tracking-tighter">
                    {project.name.replace(/ /g, '_').toUpperCase()}
                  </h3>
                  <p class="font-mono text-xs mb-4 italic" style={`color:${borderColors[i]}`}>{project.tagline}</p>
                  <p class="text-sm text-[#ababab] leading-tight font-medium italic mb-4">{project.description}</p>
                  <div class="flex flex-wrap gap-2 mb-4">
                    {project.stack.map(tech => (
                      <span class="px-2 py-1 bg-black/50 text-[8px] font-mono" style={`color:${borderColors[i]}99`}>{tech}</span>
                    ))}
                  </div>
                  <div class="flex items-center gap-4 font-mono text-[10px] border-t border-white/10 pt-4">
                    {project.links.github && <span class="font-black uppercase tracking-[0.3em]" style={`color:${borderColors[i]}`}>SOURCE_&gt;&gt;</span>}
                    {project.links.live && <span class="font-black uppercase tracking-[0.3em]" style={`color:${borderColors[i]}`}>LIVE_&gt;&gt;</span>}
                  </div>
                </div>
              </a>
            </article>
          );
        })}
      </div>

      <!-- System Alert -->
      <div class="mt-32 sm:mt-60 p-8 sm:p-12 bg-[#8eff71] text-black flex flex-col md:flex-row items-center justify-between gap-6 sm:gap-8 border-[10px] sm:border-[20px] border-black relative z-10" style="clip-path:polygon(2% 2%, 98% 5%, 95% 45%, 100% 48%, 92% 85%, 75% 82%, 65% 100%, 45% 88%, 25% 95%, 10% 75%, 0% 85%, 5% 50%)">
        <div class="flex items-center gap-6 sm:gap-10 flex-wrap">
          <span class="material-symbols-outlined text-[80px] sm:text-[120px] animate-pulse">construction</span>
          <div>
            <h3 class="text-3xl sm:text-5xl font-black uppercase italic leading-none">ALWAYS_BUILDING</h3>
            <p class="text-base sm:text-xl font-black bg-black text-[#8eff71] px-4 inline-block mt-3 sm:mt-4">MORE PROJECTS IN THE VOID</p>
          </div>
        </div>
      </div>
    </main>
  </div>
</BaseLayout>
