---
import BaseLayout from '../layouts/BaseLayout.astro';

const about = {
  name: "Chris",
  handle: "@cyperx",
  location: "Brisbane, AU",
  role: "Builder & Systems Thinker",
  bio: "I build tools, agents, and systems that compound over time. Most of what I ship is infrastructure — things that make the next thing easier to build. My stack is AI agents on Apple Silicon, Obsidian as an operating system, and whatever language gets the job done fastest.",
  principles: [
    "Ship daily, refine weekly",
    "Build for models 6 months out",
    "If it doesn't compound, don't build it",
    "Agents are teammates, not tools",
  ],
  stack: [
    { label: "HARDWARE", value: "M4 Mac Mini / Apple Silicon" },
    { label: "AGENTS", value: "Claude Code / Codex / Gemini / OpenCode" },
    { label: "INFRA", value: "OpenClaw Gateway / Discord / Tailscale" },
    { label: "KNOWLEDGE", value: "Obsidian / QMD / Flywheel" },
    { label: "LANGUAGES", value: "TypeScript / Go / Rust / Python" },
    { label: "EDITOR", value: "Neovim + Ghostty + tmux" },
  ],
  links: [
    { label: "GITHUB", href: "https://github.com/cyperx84", svg: '<svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>' },
    { label: "X", href: "https://x.com/cyper_x_", svg: '<svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>' },
  ],
};
---

<BaseLayout title="About — CyperX.dev" activeNav="about">

  <!-- ════════════════════════════════════════
       DARK VARIANT
  ════════════════════════════════════════ -->
  <div class="variant-dark bg-transparent text-[#e2e2e2] min-h-screen">
    <main class="relative pt-28 sm:pt-36 pb-20 px-4 sm:px-6 max-w-5xl mx-auto">

      <!-- Hero -->
      <section class="mb-16 sm:mb-24 text-center">
        <p class="font-mono text-[#39FF14] text-xs sm:text-sm tracking-[0.5em] mb-4" data-typewriter="40">// ABOUT</p>
        <h1 class="text-5xl sm:text-7xl lg:text-8xl font-black italic tracking-tighter leading-none mb-6" data-reveal>
          <span class="bg-clip-text text-transparent bg-gradient-to-r from-[#39FF14] via-[#AC89FF] to-[#FF51FA]">CYPERX</span><span class="text-[#e2e2e2] opacity-80">.DEV</span>
        </h1>
        <p class="text-[#baccb0] text-sm sm:text-base font-mono max-w-xl mx-auto">{about.role} · {about.location}</p>
      </section>

      <!-- Terminal-Style About -->
      <section class="mb-16 sm:mb-24" data-reveal>
        <div class="p-1" style="background:#39FF14; clip-path: polygon(0 0, 100% 0, 95% 100%, 5% 95%)">
          <div class="bg-[#0a0a0a] overflow-hidden" style="clip-path: polygon(0 0, 100% 0, 95% 100%, 5% 95%)">
            <div class="flex items-center gap-2 px-4 py-2 border-b border-[#39FF14]/10 bg-[#0a0a0a]">
              <span class="w-3 h-3 rounded-full bg-[#FF5F56]"></span>
              <span class="w-3 h-3 rounded-full bg-[#FFBD2E]"></span>
              <span class="w-3 h-3 rounded-full bg-[#27C93F]"></span>
              <span class="font-mono text-[10px] text-[#39FF14]/50 ml-2">cyperx@m4 ~</span>
            </div>
            <div class="p-6 sm:p-10 font-mono text-sm sm:text-base space-y-4">
              <p><span class="text-[#39FF14]">$</span> whoami</p>
              <p class="text-2xl sm:text-3xl font-black italic text-white">{about.name}</p>
              <p class="text-[#FF51FA]">{about.handle}</p>
              <p class="text-[#e2e2e2]/60 text-sm">{about.location} · {about.role}</p>
              <div class="border-t border-[#39FF14]/10 my-4 pt-4">
                <p><span class="text-[#39FF14]">$</span> cat bio.txt</p>
                <p class="text-[#e2e2e2]/80 leading-relaxed mt-2">{about.bio}</p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Principles + Stack Grid -->
      <section class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-16 sm:mb-24">
        <!-- Principles -->
        <div class="p-1" style="background:#FF51FA; clip-path: polygon(2% 5%, 100% 0, 98% 95%, 0 100%)" data-reveal>
          <div class="bg-[#0a0a0a] p-6 sm:p-8" style="clip-path: polygon(2% 5%, 100% 0, 98% 95%, 0 100%)">
            <h2 class="text-2xl sm:text-3xl font-black italic text-[#FF51FA] mb-6 tracking-tight">PRINCIPLES</h2>
            <div class="space-y-4">
              {about.principles.map((p, i) => (
                <div class="flex items-start gap-4">
                  <span class="text-[#39FF14] font-black text-xl font-mono leading-none mt-1">{String(i + 1).padStart(2, '0')}</span>
                  <p class="text-[#e2e2e2] font-mono text-sm">{p}</p>
                </div>
              ))}
            </div>
          </div>
        </div>

        <!-- Stack -->
        <div class="p-1" style="background:#AC89FF; clip-path: polygon(0 0, 100% 0, 95% 100%, 5% 95%)" data-reveal>
          <div class="bg-[#0a0a0a] p-6 sm:p-8" style="clip-path: polygon(0 0, 100% 0, 95% 100%, 5% 95%)">
            <h2 class="text-2xl sm:text-3xl font-black italic text-[#AC89FF] mb-6 tracking-tight">STACK</h2>
            <div class="space-y-3">
              {about.stack.map((s) => (
                <div class="flex flex-col sm:flex-row sm:items-center gap-1 sm:gap-4">
                  <span class="text-[#AC89FF] font-mono text-xs tracking-[0.3em] font-bold min-w-[100px]">{s.label}</span>
                  <span class="text-[#e2e2e2]/70 font-mono text-sm">{s.value}</span>
                </div>
              ))}
            </div>
          </div>
        </div>
      </section>

      <!-- Links -->
      <section class="flex flex-wrap justify-center gap-4 mb-16" data-reveal>
        {about.links.map((l) => (
          <a href={l.href} target="_blank" rel="noopener" class="flex items-center gap-2 bg-[#39FF14] text-black px-6 py-3 font-black text-sm uppercase tracking-widest hover:scale-105 transition-transform no-underline" style="clip-path: polygon(0 0, 100% 0, 95% 100%, 5% 95%)">
            <Fragment set:html={l.svg} />
            {l.label}
          </a>
        ))}
      </section>

    </main>
  </div>

  <!-- ════════════════════════════════════════
       LIGHT VARIANT
  ════════════════════════════════════════ -->
  <div class="variant-light bg-white/90 text-[#131313] min-h-screen">
    <main class="relative pt-28 sm:pt-36 pb-20 px-4 sm:px-6 max-w-5xl mx-auto">

      <!-- Hero -->
      <section class="mb-16 sm:mb-24 text-center">
        <p class="font-mono text-[#FF51FA] text-xs sm:text-sm tracking-[0.5em] mb-4" data-typewriter="40">// ABOUT</p>
        <h1 class="text-5xl sm:text-7xl lg:text-8xl font-black italic tracking-tighter leading-none mb-6" data-reveal>
          <span class="bg-clip-text text-transparent bg-gradient-to-r from-[#FF51FA] via-[#AC89FF] to-[#39FF14]">CYPERX</span><span class="text-[#131313] opacity-80">.DEV</span>
        </h1>
        <p class="text-[#555] text-sm sm:text-base font-mono max-w-xl mx-auto">{about.role} · {about.location}</p>
      </section>

      <!-- Editorial About -->
      <section class="mb-16 sm:mb-24" data-reveal>
        <div class="p-1" style="background:#FF51FA; clip-path: polygon(0 0, 100% 0, 95% 100%, 5% 95%)">
          <div class="bg-white p-8 sm:p-12" style="clip-path: polygon(0 0, 100% 0, 95% 100%, 5% 95%)">
            <div class="grid grid-cols-1 md:grid-cols-[1fr_2fr] gap-8 sm:gap-12">
              <!-- Left: Identity -->
              <div class="space-y-2 border-r-0 md:border-r border-[#FF51FA]/10 md:pr-8">
                <p class="text-3xl sm:text-4xl font-black italic">{about.name}</p>
                <p class="text-[#FF51FA] font-mono text-sm">{about.handle}</p>
                <p class="text-[#888] text-sm">{about.location}</p>
                <p class="text-[#888] text-sm">{about.role}</p>
              </div>
              <!-- Right: Bio -->
              <div>
                <p class="text-[#333] leading-relaxed text-base sm:text-lg">{about.bio}</p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Principles + Stack Grid -->
      <section class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-16 sm:mb-24">
        <!-- Principles -->
        <div class="p-1" style="background:#AC89FF; clip-path: polygon(2% 5%, 100% 0, 98% 95%, 0 100%)" data-reveal>
          <div class="bg-white p-6 sm:p-8" style="clip-path: polygon(2% 5%, 100% 0, 98% 95%, 0 100%)">
            <h2 class="text-2xl sm:text-3xl font-black italic text-[#AC89FF] mb-6 tracking-tight">PRINCIPLES</h2>
            <div class="space-y-4">
              {about.principles.map((p, i) => (
                <div class="flex items-start gap-4">
                  <span class="text-[#FF51FA] font-black text-xl font-mono leading-none mt-1">{String(i + 1).padStart(2, '0')}</span>
                  <p class="text-[#333] font-mono text-sm">{p}</p>
                </div>
              ))}
            </div>
          </div>
        </div>

        <!-- Stack -->
        <div class="p-1" style="background:#39FF14; clip-path: polygon(0 0, 100% 0, 95% 100%, 5% 95%)" data-reveal>
          <div class="bg-white p-6 sm:p-8" style="clip-path: polygon(0 0, 100% 0, 95% 100%, 5% 95%)">
            <h2 class="text-2xl sm:text-3xl font-black italic text-[#39FF14] mb-6 tracking-tight">STACK</h2>
            <div class="space-y-3">
              {about.stack.map((s) => (
                <div class="flex flex-col sm:flex-row sm:items-center gap-1 sm:gap-4">
                  <span class="text-[#AC89FF] font-mono text-xs tracking-[0.3em] font-bold min-w-[100px]">{s.label}</span>
                  <span class="text-[#555] font-mono text-sm">{s.value}</span>
                </div>
              ))}
            </div>
          </div>
        </div>
      </section>

      <!-- Links -->
      <section class="flex flex-wrap justify-center gap-4 mb-16" data-reveal>
        {about.links.map((l) => (
          <a href={l.href} target="_blank" rel="noopener" class="flex items-center gap-2 bg-[#FF51FA] text-white px-6 py-3 font-black text-sm uppercase tracking-widest hover:scale-105 transition-transform no-underline" style="clip-path: polygon(2% 5%, 100% 0, 98% 95%, 0 100%)">
            <Fragment set:html={l.svg} />
            {l.label}
          </a>
        ))}
      </section>

    </main>
  </div>

  <!-- ════════════════════════════════════════
       EXTREME VARIANT
  ════════════════════════════════════════ -->
  <div class="variant-extreme bg-transparent text-white min-h-screen">
    <main class="relative pt-28 sm:pt-36 pb-20 px-4 sm:px-6 max-w-5xl mx-auto">

      <!-- Hero -->
      <section class="mb-16 sm:mb-24 text-center">
        <p class="font-mono text-[#8eff71] text-xs sm:text-sm tracking-[0.5em] mb-4" data-typewriter="40">// ABOUT</p>
        <h1 class="text-5xl sm:text-7xl lg:text-8xl font-black italic tracking-tighter leading-none mb-6 glitch-text-extreme" data-reveal>
          CYPERX<span class="text-[#8eff71]">.DEV</span>
        </h1>
        <p class="text-white/60 text-sm sm:text-base font-mono max-w-xl mx-auto">{about.role} · {about.location}</p>
      </section>

      <!-- Glitched About -->
      <section class="mb-16 sm:mb-24" data-reveal>
        <div class="acid-mask-1 glitch-border-vibrate bg-black/80 p-6 sm:p-10">
          <div class="font-mono text-lg sm:text-xl space-y-2 mb-6">
            <p><span class="text-[#8eff71] font-black">$</span> whoami</p>
            <p class="text-3xl sm:text-4xl font-black italic text-white">{about.name}</p>
            <p class="text-[#ff51fa] text-lg">{about.handle}</p>
            <p class="text-white/50 text-sm">{about.location} · {about.role}</p>
          </div>
          <div class="border-t-4 border-[#ff51fa] pt-6">
            <p class="text-white/80 font-mono text-sm sm:text-base leading-relaxed">{about.bio}</p>
          </div>
        </div>
      </section>

      <!-- Principles + Stack Grid -->
      <section class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-16 sm:mb-24">
        <!-- Principles -->
        <div class="acid-mask-2 glitch-border-vibrate bg-black/80 p-6 sm:p-8" data-reveal>
          <h2 class="text-2xl sm:text-3xl font-black italic text-[#ff51fa] mb-6 uppercase">PRINCIPLES</h2>
          <div class="space-y-4">
            {about.principles.map((p, i) => (
              <div class="flex items-start gap-4">
                <span class="text-[#8eff71] font-black text-2xl sm:text-3xl font-mono leading-none">{String(i + 1).padStart(2, '0')}</span>
                <p class="text-white font-mono text-sm sm:text-base uppercase tracking-wider font-bold">{p}</p>
              </div>
            ))}
          </div>
        </div>

        <!-- Stack -->
        <div class="acid-mask-3 glitch-border-vibrate bg-black/80 p-6 sm:p-8" data-reveal>
          <h2 class="text-2xl sm:text-3xl font-black italic text-[#ac89ff] mb-6 uppercase">STACK</h2>
          <div class="space-y-3">
            {about.stack.map((s) => (
              <div class="flex flex-col sm:flex-row sm:items-center gap-1 sm:gap-4">
                <span class="text-[#ac89ff] font-mono text-xs tracking-[0.3em] font-bold min-w-[100px]">{s.label}</span>
                <span class="text-white/70 font-mono text-sm">{s.value}</span>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- Links -->
      <section class="flex flex-wrap justify-center gap-4 mb-16" data-reveal>
        {about.links.map((l) => (
          <a href={l.href} target="_blank" rel="noopener" class="flex items-center gap-2 bg-[#8eff71] text-black px-5 py-3 font-black text-sm uppercase tracking-widest hover:bg-[#ff51fa] hover:text-white transition-all hover:scale-110 no-underline shadow-[4px_4px_0_#ff51fa] hover:shadow-[4px_4px_0_#8eff71]">
            <Fragment set:html={l.svg} />
            {l.label}
          </a>
        ))}
      </section>

    </main>
  </div>

</BaseLayout>
