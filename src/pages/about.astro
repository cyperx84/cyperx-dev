---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About — CyperX.dev" activeNav="about">
  <main class="relative z-10 min-h-screen">

    <!-- Hero — transparent so Three.js shows through -->
    <section class="relative flex items-center justify-center min-h-[60vh] sm:min-h-[70vh] px-4">
      <div class="text-center max-w-3xl mx-auto">
        <p class="font-mono text-[#39FF14] text-xs sm:text-sm tracking-[0.5em] mb-4 theme-light:text-[#FF51FA] theme-extreme:text-[#8eff71]">// ABOUT</p>
        <h1 class="text-5xl sm:text-7xl lg:text-9xl font-black italic tracking-tighter leading-none mb-6">
          <span class="bg-clip-text text-transparent bg-gradient-to-r from-[#39FF14] via-[#AC89FF] to-[#FF51FA]">CYPERX</span>
        </h1>
        <p class="text-[#baccb0] text-base sm:text-lg max-w-xl mx-auto font-mono">
          Content coming soon.
        </p>
      </div>
    </section>

    <!-- Spacer section — Three.js visible -->
    <section class="min-h-[40vh]"></section>

  </main>
</BaseLayout>
