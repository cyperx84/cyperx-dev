---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="MANIFESTO - Glitch Art Maximalist" activeNav="manifesto">

  <div class="terminal-container w-full max-w-5xl border-[3px] border-primary bg-[#050505] shadow-[0_0_30px_rgba(6,249,249,0.15)] relative rounded-sm overflow-visible transition-colors duration-300 reveal-element active">
    <!-- Subtle Skull Watermark inside Terminal -->
    <div class="absolute inset-0 flex items-center justify-center opacity-[0.03] pointer-events-none select-none z-0">
      <span class="text-[20rem]">💀</span>
    </div>

    <div class="terminal-ascii-border">
      &lt;sk&gt;💀&lt;/sk&gt; ............................................................................................................ &lt;sk&gt;💀&lt;/sk&gt;<br />
      :&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;:<br />
      :&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;:<br />
      &lt;sk&gt;💀&lt;/sk&gt; ............................................................................................................ &lt;sk&gt;💀&lt;/sk&gt;
    </div>

    <div class="absolute inset-0 glitch-bg pointer-events-none mix-blend-screen opacity-60 z-10"></div>
    <span class="absolute -bottom-8 -right-8 text-6xl mix-blend-exclusion z-30 hover:scale-110 hover:-rotate-12 transition-transform cursor-pointer drop-shadow-[0_0_15px_rgba(255,0,255,0.8)]">💀🦞🤙😎</span>
    <span class="absolute -top-6 -left-6 text-5xl mix-blend-difference z-30 opacity-90 drop-shadow-[0_0_10px_rgba(6,249,249,0.8)]">👾🦞🤙</span>

    <div class="terminal-header bg-[#FF003C] px-6 py-3 flex items-center border-b-[3px] border-primary relative z-20 transition-colors duration-300">
      <h2 class="text-white text-xl font-bold leading-tight tracking-widest uppercase">root@shredder:~</h2>
      <div class="ml-auto flex gap-3">
        <div class="size-4 rounded-sm bg-[#050505] border border-primary"></div>
        <div class="size-4 rounded-sm bg-[#050505] border border-primary"></div>
        <div class="size-4 rounded-sm bg-primary border border-primary"></div>
      </div>
    </div>

    <div class="terminal-body p-6 md:p-10 space-y-8 relative z-20 min-h-[500px] transition-colors duration-300">
      <!-- Command 0: whoami -->
      <div class="reveal-element">
        <div class="text-primary text-2xl font-bold mb-2 flex items-center">
          <span class="mr-3 text-[#FF003C] animate-pulse">#</span><span class="typewriter inline-block dark:text-white text-black">whoami</span>
        </div>
        <div class="text-primary/80 font-mono text-sm ml-6 italic">
          DIGITAL_CORRUPTOR // GLITCH_MAXIMALIST // VOID_WALKER
        </div>
      </div>

      <!-- Command 1 -->
      <div class="pt-2 reveal-element">
        <div class="text-primary text-2xl font-bold mb-4 flex items-center">
          <span class="mr-3">&gt;</span><span class="typewriter inline-block dark:text-white text-black">cat manifesto.txt</span>
        </div>
        <div class="space-y-6 text-xl text-slate-100 leading-relaxed border-l-[6px] border-[#FF003C] pl-6 ml-2 bg-[#111111]/80 p-4 transition-colors duration-300">
          <p class="glitch-text opacity-95">
            I am the ghost in the machine learning model. A digital psychonaut carving paths through latent spaces and concrete waves.
            My blood is <span class="text-primary font-black uppercase tracking-wider">50% monster energy</span> and <span class="text-[#FF00FF] font-black uppercase tracking-wider">50% unresolved segfaults</span>.
          </p>
          <p class="text-slate-300 dark:text-slate-300 transition-colors">
            I build AI tools that hallucinate brutalist realities. When I'm not untangling prompt injections, I'm breaking bones on halfpipes.
            The physical world is just a slow, legacy API. <span class="dark:text-white text-black font-bold bg-[#FF003C]/20 px-1">We are compiling a new counter-culture.</span>
          </p>
        </div>
      </div>

      <!-- Command 2 -->
      <div class="pt-6 reveal-element">
        <div class="text-primary text-2xl font-bold mb-6 flex items-center">
          <span class="mr-3">&gt;</span><span class="typewriter inline-block dark:text-white text-black">ls -la /sys/modules/skills/</span>
        </div>
        <div class="space-y-3 font-mono text-lg ml-4">
          <div class="flex items-center gap-4 bg-[#111111]/50 p-2 border border-primary/20 hover:border-primary transition-colors">
            <span class="text-primary bg-primary/10 px-3 py-1 rounded-sm border border-primary font-bold shadow-[0_0_10px_rgba(6,249,249,0.3)]">[OK]</span>
            <span class="text-slate-200">Claude_Code_Integration.so</span>
            <span class="text-slate-500 ml-auto text-sm hidden md:block">0x00A1</span>
          </div>
          <div class="flex items-center gap-4 bg-[#111111]/50 p-2 border border-primary/20 hover:border-primary transition-colors">
            <span class="text-primary bg-primary/10 px-3 py-1 rounded-sm border border-primary font-bold shadow-[0_0_10px_rgba(6,249,249,0.3)]">[OK]</span>
            <span class="text-slate-200">Kickflips_v2.dll</span>
            <span class="text-slate-500 ml-auto text-sm hidden md:block">0x00B2</span>
          </div>
          <div class="flex items-center gap-4 bg-[#FF003C]/10 p-2 border border-[#FF003C]/30 relative overflow-hidden">
            <div class="absolute inset-0 bg-repeating-linear-gradient-45 from-transparent to-[#FF003C]/5 bg-[length:10px_10px]"></div>
            <span class="text-[#FF003C] bg-[#FF003C]/20 px-3 py-1 rounded-sm border border-[#FF003C] font-bold glitch-text relative z-10">[FAIL]</span>
            <span class="text-slate-400 line-through opacity-80 relative z-10">Corporate_Compliance.exe</span>
            <span class="text-[#FF003C] ml-auto text-sm font-bold animate-pulse relative z-10">ERR_CORE_DUMP</span>
          </div>
          <div class="flex items-center gap-4 bg-[#111111]/50 p-2 border border-primary/20 hover:border-[#FF00FF] transition-colors">
            <span class="text-primary bg-primary/10 px-3 py-1 rounded-sm border border-primary font-bold shadow-[0_0_10px_rgba(6,249,249,0.3)]">[OK]</span>
            <span class="text-[#FF00FF] font-bold" style="text-shadow: 1px 0 #06f9f9, -1px 0 #FF003C;">Psilocybin_Protocol.sys</span>
            <span class="text-slate-500 ml-auto text-sm hidden md:block">0x00D4</span>
          </div>
        </div>
      </div>

      <!-- Active Prompt -->
      <div class="text-primary text-3xl mt-12 flex items-center font-bold reveal-element">
        <span class="mr-4">&gt;</span><span class="w-4 h-8 bg-primary animate-blink-caret shadow-[0_0_15px_rgba(6,249,249,0.8)]"></span>
      </div>
    </div>
  </div>

  <!-- Fragment_A Section -->
  <div class="w-full max-w-5xl reveal-element">
    <div class="border-[3px] border-[#FF00FF] bg-black/40 backdrop-blur-md p-8 relative overflow-hidden">
      <!-- Background skull watermark -->
      <div class="absolute -left-10 -bottom-10 opacity-[0.05] pointer-events-none select-none">
        <span class="text-[15rem]">💀</span>
      </div>
      <div class="absolute -top-4 -right-4 bg-[#FF00FF] text-black font-bold px-4 py-1 text-sm skew-x-12 uppercase tracking-widest z-20">
        Fragment_A // Neural_Lattice
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center relative z-10">
        <div class="space-y-4">
          <h3 class="text-3xl font-black italic glitch-text tracking-tighter uppercase">Building the Void</h3>
          <p class="text-slate-400">Our architectures don't just host data; they breathe interference. We design for the collapse, for the beauty of the broken signal. 🦞🤙</p>
          <div class="h-1 w-24 bg-primary"></div>
        </div>
        <div class="aspect-video bg-[#050505] border-2 border-[#FF00FF]/40 relative overflow-hidden group">
          <div class="absolute inset-0 bg-[url('https://images.unsplash.com/photo-1550684848-fac1c5b4e853?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80')] bg-cover opacity-50 grayscale hover:grayscale-0 transition-all duration-700"></div>
          <div class="absolute inset-0 glitch-bg mix-blend-overlay"></div>
          <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity">
            <span class="text-white font-bold bg-[#FF00FF] px-4 py-2 uppercase text-xs">Access Link</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- The Singularity is a Halfpipe CTA -->
  <div class="w-full max-w-5xl reveal-element mb-24">
    <div class="border-[3px] border-primary/40 bg-black/40 backdrop-blur-md p-8 relative overflow-hidden">
      <div class="absolute top-0 left-0 w-full h-full opacity-5 flex flex-wrap gap-4 overflow-hidden pointer-events-none">
        <span>💀</span><span>💀</span><span>💀</span><span>💀</span><span>💀</span><span>💀</span><span>💀</span><span>💀</span><span>💀</span><span>💀</span><span>💀</span><span>💀</span><span>💀</span>
      </div>
      <div class="flex flex-col items-center text-center gap-6 relative z-10">
        <span class="material-symbols-outlined text-7xl text-[#FF003C] animate-pulse">leak_add</span>
        <h3 class="text-4xl font-black uppercase tracking-[0.2em] glitch-text">The Singularity is a Halfpipe</h3>
        <p class="max-w-xl text-lg text-slate-400 italic">"The error is the only honest part of the system. In the glitch, we find the truth that the clean code tries to hide." 🦞</p>
        <div class="flex gap-4">
          <button class="px-8 py-3 border-2 border-primary text-primary font-bold hover:bg-primary hover:text-black transition-all uppercase tracking-widest cursor-pointer">Connect</button>
          <button class="px-8 py-3 bg-[#FF003C] text-white font-bold hover:brightness-125 transition-all uppercase tracking-widest cursor-pointer">Disconnect</button>
        </div>
      </div>
    </div>
  </div>

</BaseLayout>
