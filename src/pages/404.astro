---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="💀 404 — BAD_TRIP" activeNav="">

  <!-- Chaos sticker badges (sm+) -->
  <div class="chaos-sticker sticker-red hidden sm:block" style="position: absolute; top: 5%; right: 5%; z-index: 40; pointer-events: none;">SECTOR_CORRUPT</div>
  <div class="chaos-sticker sticker-magenta hidden sm:block" style="position: absolute; bottom: 10%; left: 3%; z-index: 40; pointer-events: none;">BAD_TRIP_404</div>
  <div class="chaos-sticker sticker-acid hidden md:block" style="position: absolute; top: 45%; right: 2%; z-index: 40; pointer-events: none; transform: rotate(-6deg);">VOID_404</div>

  <!-- Emoji clusters -->
  <span class="absolute top-10 left-3 sm:left-10 text-2xl sm:text-4xl opacity-50 z-0 drop-shadow-[0_0_10px_#FF00FF] animate-float-medium">💀🍄😎</span>
  <span class="absolute bottom-24 right-4 sm:right-20 text-3xl sm:text-5xl opacity-30 z-0 drop-shadow-[0_0_15px_#06f9f9] transform rotate-45 animate-float-slow hidden sm:block">🛹👾👽</span>
  <span class="absolute top-1/4 right-1/4 text-2xl sm:text-3xl opacity-40 z-0 drop-shadow-[0_0_5px_#FF003C] -rotate-12 animate-float-fast hidden md:block">🤖💥👾</span>

  <div class="z-10 flex flex-col items-center gap-6 sm:gap-12 w-full max-w-5xl px-3 sm:px-6 text-center">
    <!-- Glitch Header -->
    <h1 class="text-5xl sm:text-7xl lg:text-8xl text-center leading-none w-full break-words" style="position: relative; display: inline-block; animation: pulseGlitch 0.5s infinite; font-weight: 900; text-transform: uppercase; letter-spacing: -2px;">
      <span class="block text-chaos-2xl glitch-intense">404</span>
      <span class="block text-2xl sm:text-chaos-xl mt-2 sm:mt-4">BAD_TRIP /</span>
      <span class="block text-2xl sm:text-chaos-xl text-accent-red">SECTOR CORRUPT</span>
    </h1>

    <!-- ASCII Block -->
    <div class="ascii-block w-full max-w-xs sm:max-w-lg chaos-rotate-n2 text-[9px] sm:text-sm overflow-hidden">
      ▓▓▓ NAVIGATION_FAILED :: SECTOR_CORRUPT ▓▓▓
      ░░░ REALITY_PTR: NULL :: RETURN: UNDEFINED ░░░
      ███ 0x404 NOT_FOUND :: VOID_STATE: ACTIVE ███
    </div>

    <!-- Corrupt block -->
    <div class="corrupt-block w-full max-w-xs sm:max-w-lg"></div>

    <!-- Return Button -->
    <a class="group relative cursor-pointer fractal-card px-6 sm:px-8 py-3 sm:py-4 z-20 hover:bg-accent-red hover:border-accent-red hover:text-background-dark transition-colors duration-0" href="/">
      <span class="font-mono text-base sm:text-xl md:text-2xl font-bold uppercase tracking-widest block relative z-10 group-hover:animate-none text-primary group-hover:text-background-dark">
        <span class="text-accent-red group-hover:text-background-dark animate-pulse-glitch inline-block mr-1 sm:mr-2">[&gt;</span>
        PADDLE BACK OUT
        <span class="text-accent-red group-hover:text-background-dark animate-pulse-glitch inline-block ml-1 sm:ml-2">&lt;]</span>
      </span>
      <div class="absolute inset-0 border-2 border-accent-red transform translate-x-2 translate-y-2 mix-blend-screen opacity-50 group-hover:translate-x-0 group-hover:translate-y-0 transition-transform"></div>
    </a>

    <!-- ASCII Art -->
    <div class="w-full flex justify-center overflow-hidden">
      <pre class="font-mono text-center" style="font-size: clamp(0.4rem, 1.5vw, 0.9rem); line-height: 1.1; color: #00FFFF; text-shadow: 2px 0 #FF003C, -2px 0 #00FFFF; white-space: pre;">        .-.
       (o.o)
        |=|
       __|__
     //.=|=.\\
    // .=|=. \\
    \\ .=|=. //
     \\(_=_)//
      (:| |:)
       || ||
       () ()
       || ||
       || ||
      ==' '==</pre>
    </div>
  </div>

</BaseLayout>
