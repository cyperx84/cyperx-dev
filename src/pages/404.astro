---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 — CYPERX.DEV" activeNav="">
  <!-- Dark variant -->
  <div class="variant-dark bg-transparent min-h-[80vh] flex items-center justify-center px-4">
    <div class="text-center space-y-8 max-w-lg">
      <div class="text-[120px] sm:text-[180px] font-black italic font-['Space_Grotesk'] leading-none tracking-tighter text-[#39FF14]/20">404</div>
      <div class="space-y-3 -mt-12 relative">
        <h1 class="text-3xl sm:text-5xl font-black italic font-['Space_Grotesk'] tracking-tighter text-white">SIGNAL_LOST</h1>
        <p class="font-mono text-sm text-white/50">The requested resource has been consumed by the void.</p>
      </div>
      <div class="flex flex-col sm:flex-row gap-4 justify-center pt-4">
        <a href="/" class="inline-flex items-center gap-2 bg-[#39FF14] text-black px-6 py-3 font-black text-sm uppercase tracking-widest hover:bg-[#FF51FA] hover:text-white transition-all no-underline">
          <span class="material-symbols-outlined text-lg">arrow_forward</span>
          RETURN_HOME
        </a>
        <a href="/blog" class="inline-flex items-center gap-2 border border-white/20 text-white/60 px-6 py-3 font-mono text-sm uppercase tracking-widest hover:border-[#39FF14] hover:text-[#39FF14] transition-all no-underline">
          READ_BLOG
        </a>
        <a href="/projects" class="inline-flex items-center gap-2 border border-white/20 text-white/60 px-6 py-3 font-mono text-sm uppercase tracking-widest hover:border-[#39FF14] hover:text-[#39FF14] transition-all no-underline">
          VIEW_PROJECTS
        </a>
      </div>
      <p class="font-mono text-[10px] text-white/20 pt-8">ERR::RESOURCE_NOT_FOUND // ENTROPY_NOMINAL</p>
    </div>
  </div>

  <!-- Light variant -->
  <div class="variant-light bg-white min-h-[80vh] flex items-center justify-center px-4">
    <div class="text-center space-y-8 max-w-lg">
      <div class="text-[120px] sm:text-[180px] font-black italic font-['Space_Grotesk'] leading-none tracking-tighter text-[#FF51FA]/15">404</div>
      <div class="space-y-3 -mt-12 relative">
        <h1 class="text-3xl sm:text-5xl font-black italic font-['Space_Grotesk'] tracking-tighter text-[#131313]">Page Not Found</h1>
        <p class="text-[#131313]/50 text-base">This page doesn't exist — yet.</p>
      </div>
      <div class="flex flex-col sm:flex-row gap-4 justify-center pt-4">
        <a href="/" class="inline-flex items-center gap-2 bg-[#131313] text-white px-6 py-3 font-black text-sm uppercase tracking-widest hover:bg-[#FF51FA] transition-all no-underline">
          <span class="material-symbols-outlined text-lg">arrow_forward</span>
          Go Home
        </a>
        <a href="/blog" class="inline-flex items-center gap-2 border-2 border-[#131313]/20 text-[#131313]/60 px-6 py-3 font-mono text-sm uppercase tracking-widest hover:border-[#FF51FA] hover:text-[#FF51FA] transition-all no-underline">
          Read Blog
        </a>
        <a href="/projects" class="inline-flex items-center gap-2 border-2 border-[#131313]/20 text-[#131313]/60 px-6 py-3 font-mono text-sm uppercase tracking-widest hover:border-[#FF51FA] hover:text-[#FF51FA] transition-all no-underline">
          Projects
        </a>
      </div>
    </div>
  </div>

  <!-- Extreme variant -->
  <div class="variant-extreme min-h-[80vh] flex items-center justify-center px-4" style="background:transparent">
    <div class="text-center space-y-8 max-w-lg">
      <div class="text-[120px] sm:text-[180px] font-black italic font-['Space_Grotesk'] leading-none tracking-tighter glitch-text-404" data-text="404">404</div>
      <div class="space-y-3 -mt-12 relative">
        <h1 class="text-3xl sm:text-5xl font-black italic font-['Space_Grotesk'] tracking-tighter text-white glitch-border-vibrate inline-block px-4 py-2">VOID_BREACH</h1>
        <p class="font-mono text-sm text-white/50">Reality fragmented. This node doesn't exist in this timeline.</p>
      </div>
      <div class="flex flex-col sm:flex-row gap-4 justify-center pt-4">
        <a href="/" class="inline-flex items-center gap-2 bg-[#39FF14] text-black px-6 py-3 font-black text-sm uppercase tracking-widest hover:bg-[#FF51FA] hover:text-white transition-all no-underline shadow-[0_0_20px_rgba(57,255,20,0.4)]">
          <span class="material-symbols-outlined text-lg">arrow_forward</span>
          ESCAPE_VOID
        </a>
        <a href="/blog" class="inline-flex items-center gap-2 border border-[#39FF14]/30 text-[#39FF14]/60 px-6 py-3 font-mono text-sm uppercase tracking-widest hover:border-[#FF51FA] hover:text-[#FF51FA] transition-all no-underline">
          READ_BLOG
        </a>
        <a href="/projects" class="inline-flex items-center gap-2 border border-[#39FF14]/30 text-[#39FF14]/60 px-6 py-3 font-mono text-sm uppercase tracking-widest hover:border-[#FF51FA] hover:text-[#FF51FA] transition-all no-underline">
          VIEW_PROJECTS
        </a>
      </div>
      <p class="font-mono text-[10px] text-white/15 pt-8">TIMELINE::FRACTURED // BREACH_LVL::CRITICAL // ENTROPY::MAX</p>
    </div>
  </div>
</BaseLayout>

<style>
  .glitch-text-404 {
    color: #39FF14;
    text-shadow:
      2px 2px #FF51FA,
      -2px -2px #00f0ff,
      4px 0 #FF51FA;
    animation: glitch404 2s infinite;
  }
  @keyframes glitch404 {
    0%, 90%, 100% { text-shadow: 2px 2px #FF51FA, -2px -2px #00f0ff, 4px 0 #FF51FA; transform: none; }
    92% { text-shadow: -4px 2px #FF51FA, 3px -2px #00f0ff, -2px 0 #39FF14; transform: translate(3px, -2px); }
    94% { text-shadow: 3px -3px #FF51FA, -2px 4px #00f0ff, 5px 1px #39FF14; transform: translate(-2px, 3px); }
    96% { text-shadow: -2px 3px #FF51FA, 4px -1px #00f0ff, -3px 2px #39FF14; transform: translate(1px, -1px); }
  }
</style>
