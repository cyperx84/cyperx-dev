---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="💀 404 — SIGNAL_LOST" activeNav="">

  <style>
    /* 404-specific styles */
    @keyframes glitch-404 {
      0%   { text-shadow: 4px 0 #FF51FA, -4px 0 #39FF14; transform: translate(0); }
      10%  { text-shadow: -6px 2px #FF51FA, 6px -2px #39FF14; transform: translate(-3px, 1px); }
      20%  { text-shadow: 4px 0 #FF51FA, -4px 0 #39FF14; transform: translate(0); }
      30%  { text-shadow: 8px 0 #AC89FF, -8px 0 #FF51FA; transform: translate(4px, -2px); clip-path: inset(20% 0 60% 0); }
      31%  { clip-path: inset(0); transform: translate(0); }
      60%  { text-shadow: -5px 3px #39FF14, 5px -3px #FF51FA; transform: translate(-2px, 0); }
      70%  { text-shadow: 4px 0 #FF51FA, -4px 0 #39FF14; transform: translate(0); }
      85%  { text-shadow: -3px 0 #AC89FF, 3px 0 #FF51FA; transform: translate(2px, 1px); }
      100% { text-shadow: 4px 0 #FF51FA, -4px 0 #39FF14; transform: translate(0); }
    }

    @keyframes signal-scan {
      0%   { transform: translateY(-100%); opacity: 0; }
      10%  { opacity: 0.4; }
      90%  { opacity: 0.4; }
      100% { transform: translateY(100vh); opacity: 0; }
    }

    @keyframes static-flicker {
      0%, 100% { opacity: 0.03; }
      50%       { opacity: 0.07; }
    }

    @keyframes subtitle-blink {
      0%, 49% { opacity: 1; }
      50%, 100% { opacity: 0; }
    }

    .error-404-text {
      animation: glitch-404 3s infinite ease-in-out;
      font-size: clamp(6rem, 22vw, 18rem);
      font-weight: 900;
      font-style: italic;
      letter-spacing: -0.04em;
      line-height: 1;
      font-family: 'Space Grotesk', sans-serif;
    }

    .theme-dark .error-404-text   { color: #e2e2e2; }
    .theme-light .error-404-text  { color: #131313; }
    .theme-extreme .error-404-text { color: #fff; }

    .signal-lost {
      font-family: 'JetBrains Mono', monospace;
      font-size: clamp(1.2rem, 4vw, 2.5rem);
      text-transform: uppercase;
      letter-spacing: 0.3em;
      font-weight: 700;
    }

    .theme-dark .signal-lost   { color: #39FF14; }
    .theme-light .signal-lost  { color: #FF51FA; }
    .theme-extreme .signal-lost { color: #8eff71; animation: subtitle-blink 1s step-end infinite; }

    .noise-bg-404 {
      position: fixed;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
      background-size: 200px 200px;
      animation: static-flicker 0.2s infinite steps(1);
      pointer-events: none;
      z-index: 0;
      mix-blend-mode: overlay;
    }

    .scan-line {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 4px;
      background: linear-gradient(to right, transparent, rgba(57,255,20,0.6), transparent);
      animation: signal-scan 4s linear infinite;
      pointer-events: none;
      z-index: 1;
    }

    .error-page-content {
      position: relative;
      z-index: 10;
    }

    .ascii-404 {
      font-family: 'JetBrains Mono', monospace;
      font-size: clamp(0.35rem, 1.2vw, 0.8rem);
      line-height: 1.15;
      white-space: pre;
      user-select: none;
    }

    .theme-dark .ascii-404   { color: #39FF14; opacity: 0.6; }
    .theme-light .ascii-404  { color: #FF51FA; opacity: 0.5; }
    .theme-extreme .ascii-404 { color: #8eff71; opacity: 0.7; }

    .return-btn {
      display: inline-block;
      padding: 1rem 2.5rem;
      font-family: 'Space Grotesk', sans-serif;
      font-weight: 900;
      font-style: italic;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      font-size: 1.1rem;
      text-decoration: none;
      transition: transform 0.15s ease, box-shadow 0.15s ease;
      clip-path: polygon(8% 0, 100% 0, 92% 100%, 0 100%);
      position: relative;
      overflow: hidden;
    }

    .theme-dark .return-btn {
      background: #39FF14;
      color: #000;
      box-shadow: 0 0 30px rgba(57,255,20,0.3);
    }
    .theme-light .return-btn {
      background: #FF51FA;
      color: #fff;
      box-shadow: 0 0 30px rgba(255,81,250,0.3);
    }
    .theme-extreme .return-btn {
      background: #8eff71;
      color: #000;
      box-shadow: 0 0 50px rgba(142,255,113,0.5), 20px 20px 0 #ff51fa;
    }

    .return-btn:hover {
      transform: translateY(-3px) scale(1.04);
    }
    .return-btn:active {
      transform: translateY(1px) scale(0.98);
    }

    .corrupt-lines {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.65rem;
      opacity: 0.4;
      letter-spacing: 0.1em;
      text-transform: uppercase;
    }
    .theme-dark .corrupt-lines   { color: #FF51FA; }
    .theme-light .corrupt-lines  { color: #AC89FF; }
    .theme-extreme .corrupt-lines { color: #ff51fa; }
  </style>

  <!-- Noise + scan line -->
  <div class="noise-bg-404" aria-hidden="true"></div>
  <div class="scan-line" aria-hidden="true"></div>

  <main class="min-h-screen flex items-center justify-center pt-24 pb-16 px-4">
    <div class="error-page-content flex flex-col items-center gap-6 sm:gap-10 text-center max-w-4xl w-full">

      <!-- Big 404 -->
      <div class="relative">
        <div class="error-404-text select-none">404</div>
        <!-- Glitch layer -->
        <div class="error-404-text select-none absolute inset-0 opacity-40" style="clip-path:inset(40% 0 45% 0); animation: glitch-404 3s infinite ease-in-out 0.1s;" aria-hidden="true">404</div>
      </div>

      <!-- SIGNAL_LOST -->
      <div class="signal-lost">SIGNAL_LOST</div>

      <!-- Corrupt data lines -->
      <div class="corrupt-lines space-y-1">
        <div>▓▓▓ NAVIGATION_FAILED :: SECTOR_CORRUPT ▓▓▓</div>
        <div>░░░ REALITY_PTR: NULL :: RETURN: UNDEFINED ░░░</div>
        <div>███ 0x404 NOT_FOUND :: VOID_STATE: ACTIVE ███</div>
      </div>

      <!-- ASCII art -->
      <pre class="ascii-404" aria-hidden="true">
 _____ ___ _  _   _ _    ___  ___ _____
/ ____|   \  \| | | |  | / _ \/ __||_   _|
\__ \| |) | .` | |_| | |_) | (__ | |   
|___/|___/|_|\_|\___/|____/ \___||_|   
      </pre>

      <!-- Return link -->
      <a href="/" class="return-btn" data-reveal="scale">
        ← RETURN_TO_BASE
      </a>

      <!-- Status codes -->
      <div class="font-mono text-[10px] opacity-30 uppercase tracking-widest">
        ERR_PAGE_NOT_FOUND &nbsp;|&nbsp; STATUS: 404 &nbsp;|&nbsp; REBOOT_RECOMMENDED
      </div>
    </div>
  </main>

</BaseLayout>
