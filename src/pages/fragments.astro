---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="💀 Fragments — CyperX.dev" activeNav="fragments">

  <!-- Page header -->
  <div class="w-full max-w-5xl">
    <div class="flex items-center gap-3 sm:gap-4 mb-4 sm:mb-6">
      <h2 class="text-2xl sm:text-chaos-2xl glitch-intense tracking-widest opacity-30">ARCHIVE_FRAGMENTS</h2>
    </div>
  </div>

  <!-- Data dump -->
  <div class="data-dump w-full max-w-5xl text-[10px] sm:text-sm overflow-hidden hidden sm:block">
    SYS:FRAG_DB | RECORDS:∞ | CORRUPTION:ACTIVE | ENTROPY:MAX | VOID:OPEN
  </div>

  <!-- Tag Cloud — responsive grid instead of absolute positioning -->
  <div class="w-full max-w-5xl relative z-10 reveal-element active">
    <div class="fractal-card p-4 sm:p-8 relative overflow-hidden min-h-[300px] sm:min-h-[500px]">
      <!-- Emoji clusters (decorative) -->
      <div class="absolute text-2xl sm:text-3xl z-50 pointer-events-none mix-blend-difference hidden sm:block" style="top: 20%; left: 30%;">💀🍄🏂👽😎</div>
      <div class="absolute text-3xl sm:text-4xl z-50 pointer-events-none mix-blend-difference hidden md:block" style="bottom: 15%; right: 25%; transform: rotate(-20deg); opacity: 0.5;">👾🤖🛹👽😎</div>
      <div class="absolute text-2xl z-50 pointer-events-none hidden lg:block" style="top: 70%; left: 5%;">🍄⚠️👽😎</div>

      <!-- Glitch tags — responsive absolute positions, hidden on very small screens -->
      <div class="absolute glitch-tag text-primary hidden sm:block" style="top: 10%; left: 5%; font-size: clamp(14px, 2vw, 24px); transform: rotate(-5deg); font-family: 'Space Mono', monospace;">[FRAG: CLAUDE]</div>
      <div class="absolute glitch-tag text-text-main hidden sm:block" style="top: 30%; left: 40%; font-size: clamp(24px, 4vw, 72px); transform: rotate(10deg); font-family: 'Rubik Glitch', system-ui; color: #06f9f9;">PSYCHONAUT</div>
      <div class="absolute glitch-tag text-accent-red hidden md:block" style="top: 60%; left: 15%; font-size: clamp(20px, 3vw, 48px); transform: rotate(-12deg); font-family: 'Space Grotesk', sans-serif; font-weight: 700;">KICKFLIPS</div>
      <div class="absolute glitch-tag text-muted hidden lg:block" style="top: 80%; left: 60%; font-size: clamp(32px, 6vw, 128px); transform: rotate(5deg); font-family: 'Rubik Glitch', system-ui; opacity: 0.8;">SYS_CRASH</div>
      <div class="absolute glitch-tag text-text-main hidden sm:block" style="top: 15%; right: 10%; font-size: clamp(16px, 2.5vw, 36px); transform: rotate(15deg); font-family: 'Space Mono', monospace; color: #555555;">[FRAG: OPENCLAW]</div>
      <div class="absolute glitch-tag text-primary hidden md:block" style="top: 50%; right: 20%; font-size: clamp(24px, 4vw, 56px); transform: rotate(-8deg); font-family: 'VT323', monospace; letter-spacing: -2px;">GENERATIVE_ART</div>
      <div class="absolute glitch-tag text-muted font-body hidden lg:block" style="top: 85%; left: 20%; font-size: 20px; transform: rotate(25deg);">404_LORE</div>
      <div class="absolute glitch-tag text-accent-red font-heading hidden md:block" style="top: 25%; left: 80%; font-size: clamp(20px, 3vw, 42px); transform: rotate(5deg); opacity: 0.6;">HALLUCINATION</div>

      <!-- Fractal card floating (visible on all sizes) -->
      <div class="absolute fractal-card chaos-rotate-n2 hidden sm:block" style="top: 40%; left: 30%; width: clamp(160px, 20vw, 220px); padding: 1rem; z-index: 30;">
        <p class="text-primary font-mono text-xs">FRAGMENT_0xDEAD</p>
        <p class="text-white font-bold mt-1 text-sm">FRACTAL_MODE: ENGAGED</p>
        <div class="glitch-bar-static mt-2"></div>
        <p class="text-muted text-xs mt-1 font-mono">depth: ∞ | iter: NaN</p>
      </div>

      <!-- Mobile fallback: simple tag list when absolute layout is hidden -->
      <div class="sm:hidden flex flex-wrap gap-3 p-2">
        <span class="text-primary font-mono text-sm border border-primary px-2 py-1">[FRAG: CLAUDE]</span>
        <span class="text-accent-red font-bold text-lg">KICKFLIPS</span>
        <span class="text-white font-mono text-sm border border-accent-magenta px-2 py-1">[FRAG: OPENCLAW]</span>
        <span class="text-primary text-xl" style="font-family: 'VT323', monospace;">GENERATIVE_ART</span>
        <span class="text-muted text-sm font-mono">SYS_CRASH</span>
        <span class="text-accent-red font-bold">HALLUCINATION</span>
        <span class="text-white text-lg" style="font-family: 'Rubik Glitch', system-ui; color: #06f9f9;">PSYCHONAUT</span>
      </div>

      <!-- Corrupt block inside -->
      <div class="corrupt-block mt-4 hidden sm:block"></div>
    </div>
  </div>

  <!-- ASCII Block decoration -->
  <div class="ascii-block w-full max-w-5xl text-[10px] sm:text-sm overflow-hidden">
    ▓ FRAG_DB ▓ LOADING ░ CORRUPT ▒
  </div>

  <!-- Bottom binary noise (desktop only) -->
  <div class="w-full max-w-5xl hidden md:block">
    <p class="text-muted text-xs font-mono break-all leading-none opacity-30">
      01010011 01011001 01010011 01011111 01000101 01010010 01010010 01001111 01010010
    </p>
  </div>

</BaseLayout>

<style>
  .glitch-tag {
    transition: transform 0.1s cubic-bezier(0.25, 0.46, 0.45, 0.94), color 0.1s;
    cursor: pointer;
    white-space: nowrap;
    text-transform: uppercase;
  }
  .glitch-tag:hover {
    transform: scale(1.2);
    z-index: 100;
    color: #F8F8F8;
    text-shadow: 3px 0px 0px #FF003C, -3px 0px 0px #06f9f9;
    mix-blend-mode: exclusion;
  }
</style>
