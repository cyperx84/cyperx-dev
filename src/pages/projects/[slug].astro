---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { projects } from '../../data/projects';

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
---
<BaseLayout title={`CYPERX.DEV // ${project.name.toUpperCase()}`} activeNav="projects">

  <!-- Scroll progress bar -->
  <div id="scroll-progress" class="fixed top-0 left-0 h-[2px] z-[9999] transition-none" style="width:0%; background:#39FF14;"></div>

  <!-- Project images data for JS -->
  <div id="project-images-data" class="hidden" data-images={JSON.stringify(project.images || [])}></div>

  <!-- Chapter tracker (right side dots) -->
  <nav id="chapter-tracker" class="fixed right-4 top-1/2 -translate-y-1/2 z-[100] hidden lg:flex flex-col gap-3 items-center">
  </nav>

  <!-- ════════════════════════════════════════
       DARK VARIANT
  ════════════════════════════════════════ -->
  <div class="variant-dark bg-transparent text-[#e2e2e2] min-h-screen">
    <main class="relative pt-28 sm:pt-32 pb-16 sm:pb-24 px-4 sm:px-6 lg:px-12 max-w-4xl mx-auto min-h-screen">

      <!-- Back link -->
      <a href="/projects" class="inline-flex items-center gap-3 font-mono text-sm font-black text-[#39FF14] hover:text-[#FF51FA] transition-colors mb-8 sm:mb-12 group px-4 py-3 border border-[#39FF14]/30 hover:border-[#FF51FA] hover:bg-[#FF51FA]/5 active:scale-95" style="clip-path:polygon(0 0,100% 0,97% 100%,3% 100%)">
        <span class="group-hover:-translate-x-2 transition-transform text-lg">&larr;</span> BACK TO PROJECTS
      </a>

      <!-- Header -->
      <header class="mb-10 sm:mb-16">
        {project.image && (
          <div class="jag-img-wrap mb-8" style="height:360px;">
            <div class="jag-img-clip"><img src={project.image} alt={project.name} class="jag-img jag-loaded" loading="eager" fetchpriority="high" decoding="sync" width="1200" height="360" /></div>
            <svg class="jag-border" viewBox="0 0 100 100" preserveAspectRatio="none" aria-hidden="true">
              <polygon points="2,0 14,6 25,0 38,5 52,0 65,3 80,0 92,4 100,2 98,16 100,32 97,48 100,64 98,80 100,95 94,100 80,97 65,100 48,96 32,100 18,98 0,96 3,82 0,65 4,48 0,32 2,16" class="jag-stroke-outer" style="stroke:#39FF14" />
              <polygon points="4,2 16,8 27,2 40,7 54,2 67,5 82,2 94,6 98,4 96,18 98,34 95,50 98,66 96,82 98,97 92,98 78,95 63,98 46,94 30,98 16,96 2,94 5,80 2,63 6,46 2,30 4,18" class="jag-stroke-inner" style="stroke:#39FF14" />
            </svg>
          </div>
        )}
        <div class="flex flex-wrap items-center gap-3 mb-4">
          <span class="font-mono text-xs px-3 py-1 font-black" style={`background:${project.statusColor}; color:black`}>{project.status}</span>
          <span class="font-mono text-[10px] text-[#e2e2e2]/40"></span>
        </div>
        <h1 class="text-3xl sm:text-5xl lg:text-6xl font-black uppercase tracking-tighter italic leading-tight overflow-visible mb-4">{project.name}</h1>
        <p class="text-[#39FF14] font-mono text-sm italic mb-6">{project.tagline}</p>
        <p class="text-[#baccb0] text-base sm:text-lg border-l-4 border-[#39FF14] pl-4">{project.description}</p>
      </header>

      <!-- Full Description -->
      <section class="prose-dark storybook-prose mb-12 sm:mb-16" set:html={project.longDescription} />

      <!-- Tech Stack -->
      <section class="mb-10 sm:mb-12">
        <h2 class="font-mono text-[10px] text-[#e2e2e2]/40 tracking-[0.3em] uppercase mb-4">TECH_STACK</h2>
        <div class="flex flex-wrap gap-3">
          {project.stack.map(tech => (
            <span class="px-4 py-2 bg-[#1f1f1f] border border-[#39FF14]/20 font-mono text-xs text-[#39FF14]">{tech}</span>
          ))}
        </div>
      </section>

      <!-- Links -->
      {(project.links.github || project.links.live) && (
        <section class="mb-12 sm:mb-16">
          <h2 class="font-mono text-[10px] text-[#e2e2e2]/40 tracking-[0.3em] uppercase mb-4">LINKS</h2>
          <div class="flex flex-wrap gap-4">
            {project.links.github && (
              <a href={project.links.github} target="_blank" rel="noopener" class="bg-[#39FF14] text-black px-6 py-3 font-black italic tracking-tighter hover:bg-[#FF51FA] hover:text-white transition-all" style="clip-path:polygon(5% 0,100% 0,95% 100%,0 100%)">
                VIEW_SOURCE &gt;&gt;
              </a>
            )}
            {project.links.live && (
              <a href={project.links.live} target="_blank" rel="noopener" class="bg-[#FF51FA] text-white px-6 py-3 font-black italic tracking-tighter hover:bg-[#39FF14] hover:text-black transition-all" style="clip-path:polygon(5% 0,100% 0,95% 100%,0 100%)">
                OPEN_LIVE &gt;&gt;
              </a>
            )}
          </div>
        </section>
      )}

      <!-- Back -->
      <a href="/projects" class="inline-flex items-center gap-3 font-mono text-sm font-black text-[#e2e2e2]/50 hover:text-[#39FF14] transition-colors group px-4 py-3 border border-white/10 hover:border-[#39FF14]/40 active:scale-95" style="clip-path:polygon(0 0,100% 0,97% 100%,3% 100%)">
        <span class="group-hover:-translate-x-2 transition-transform text-lg">&larr;</span> ALL PROJECTS
      </a>
    </main>
  </div>


  <!-- ════════════════════════════════════════
       LIGHT VARIANT
  ════════════════════════════════════════ -->
  <div class="variant-light bg-white/90 text-[#131313] min-h-screen">
    <main class="pt-28 sm:pt-32 pb-16 sm:pb-24 px-4 sm:px-6 lg:px-12 max-w-4xl mx-auto">

      <!-- Back link -->
      <a href="/projects" class="inline-flex items-center gap-3 font-mono text-sm font-black text-[#131313] hover:text-[#FF51FA] transition-colors mb-8 sm:mb-12 group px-4 py-3 border-2 border-[#131313]/20 hover:border-[#FF51FA] hover:bg-[#FF51FA]/5 active:scale-95" style="clip-path:polygon(2% 0,100% 0,98% 100%,0 100%)">
        <span class="group-hover:-translate-x-2 transition-transform text-lg">&larr;</span> BACK TO PROJECTS
      </a>

      <!-- Header -->
      <header class="mb-10 sm:mb-16">
        {project.image && (
          <div class="jag-img-wrap mb-8" style="height:360px;">
            <div class="jag-img-clip"><img src={project.image} alt={project.name} class="jag-img jag-loaded" loading="eager" fetchpriority="high" decoding="sync" width="1200" height="360" /></div>
            <svg class="jag-border" viewBox="0 0 100 100" preserveAspectRatio="none" aria-hidden="true">
              <polygon points="2,0 14,6 25,0 38,5 52,0 65,3 80,0 92,4 100,2 98,16 100,32 97,48 100,64 98,80 100,95 94,100 80,97 65,100 48,96 32,100 18,98 0,96 3,82 0,65 4,48 0,32 2,16" class="jag-stroke-outer" style="stroke:#FF51FA" />
              <polygon points="4,2 16,8 27,2 40,7 54,2 67,5 82,2 94,6 98,4 96,18 98,34 95,50 98,66 96,82 98,97 92,98 78,95 63,98 46,94 30,98 16,96 2,94 5,80 2,63 6,46 2,30 4,18" class="jag-stroke-inner" style="stroke:#FF51FA" />
            </svg>
          </div>
        )}
        <div class="flex flex-wrap items-center gap-3 mb-4">
          <span class="font-mono text-xs px-3 py-1 font-black text-white" style={`background:${project.statusColor}`}>{project.status}</span>
          <span class="font-mono text-[10px] text-[#131313]/40"></span>
        </div>
        <h1 class="text-3xl sm:text-5xl lg:text-6xl font-black uppercase tracking-tighter leading-tight overflow-visible mb-4">{project.name}</h1>
        <p class="text-[#FF51FA] font-mono text-sm italic mb-6 font-bold">{project.tagline}</p>
        <p class="text-[#131313]/70 text-base sm:text-lg border-l-4 border-[#FF51FA] pl-4">{project.description}</p>
      </header>

      <!-- Full Description -->
      <section class="prose-light storybook-prose mb-12 sm:mb-16" set:html={project.longDescription} />

      <!-- Tech Stack -->
      <section class="mb-10 sm:mb-12">
        <h2 class="font-mono text-[10px] text-[#131313]/40 tracking-[0.3em] uppercase mb-4">TECH_STACK</h2>
        <div class="flex flex-wrap gap-3">
          {project.stack.map(tech => (
            <span class="px-4 py-2 bg-[#f0f0f0] font-mono text-xs text-[#131313]/70">{tech}</span>
          ))}
        </div>
      </section>

      <!-- Links -->
      {(project.links.github || project.links.live) && (
        <section class="mb-12 sm:mb-16">
          <h2 class="font-mono text-[10px] text-[#131313]/40 tracking-[0.3em] uppercase mb-4">LINKS</h2>
          <div class="flex flex-wrap gap-4">
            {project.links.github && (
              <a href={project.links.github} target="_blank" rel="noopener" class="inline-flex items-center gap-2 font-black uppercase tracking-widest text-[#39FF14] hover:text-[#FF51FA] transition-colors">
                VIEW SOURCE <span class="material-symbols-outlined text-base">arrow_forward</span>
              </a>
            )}
            {project.links.live && (
              <a href={project.links.live} target="_blank" rel="noopener" class="inline-flex items-center gap-2 font-black uppercase tracking-widest text-[#FF51FA] hover:text-[#39FF14] transition-colors">
                LIVE SITE <span class="material-symbols-outlined text-base">open_in_new</span>
              </a>
            )}
          </div>
        </section>
      )}

      <!-- Back -->
      <a href="/projects" class="inline-flex items-center gap-2 font-mono text-xs text-[#131313]/40 hover:text-[#FF51FA] transition-colors group">
        <span class="group-hover:-translate-x-1 transition-transform">&lt;&lt;</span> ALL PROJECTS
      </a>
    </main>
  </div>


  <!-- ════════════════════════════════════════
       EXTREME VARIANT
  ════════════════════════════════════════ -->
  <div class="variant-extreme bg-transparent text-white min-h-screen overflow-x-hidden" style="cursor:crosshair">
    <main class="relative pt-28 sm:pt-32 pb-16 sm:pb-24 px-4 sm:px-6 lg:px-12 max-w-4xl mx-auto min-h-screen">
      <div class="fixed inset-0 x-fractal-bg -z-10"></div>

      <!-- Back link -->
      <a href="/projects" class="inline-flex items-center gap-3 font-mono text-sm font-black text-[#8eff71] hover:text-[#ff51fa] transition-colors mb-8 sm:mb-12 group relative z-10 px-4 py-3 border border-[#8eff71]/40 hover:border-[#ff51fa] hover:bg-[#ff51fa]/10 active:scale-95" style="clip-path:polygon(0 5%,97% 0,100% 95%,3% 100%)">
        <span class="group-hover:-translate-x-2 transition-transform text-lg">&larr;</span> BACK TO PROJECTS
      </a>

      <!-- Header -->
      <header class="mb-10 sm:mb-16 relative z-10">
        {project.image && (
          <div class="jag-img-wrap mb-8 relative z-10" style="height:360px;">
            <div class="jag-img-clip"><img src={project.image} alt={project.name} class="jag-img jag-loaded" loading="eager" fetchpriority="high" decoding="sync" width="1200" height="360" /></div>
            <svg class="jag-border" viewBox="0 0 100 100" preserveAspectRatio="none" aria-hidden="true">
              <polygon points="2,0 14,6 25,0 38,5 52,0 65,3 80,0 92,4 100,2 98,16 100,32 97,48 100,64 98,80 100,95 94,100 80,97 65,100 48,96 32,100 18,98 0,96 3,82 0,65 4,48 0,32 2,16" class="jag-stroke-outer" style="stroke:#8eff71" />
              <polygon points="4,2 16,8 27,2 40,7 54,2 67,5 82,2 94,6 98,4 96,18 98,34 95,50 98,66 96,82 98,97 92,98 78,95 63,98 46,94 30,98 16,96 2,94 5,80 2,63 6,46 2,30 4,18" class="jag-stroke-inner" style="stroke:#8eff71" />
            </svg>
          </div>
        )}
        <div class="flex flex-wrap items-center gap-3 mb-4">
          <span class="font-mono text-xs px-3 py-1 font-black" style={`background:${project.statusColor}; color:black`}>{project.status}</span>
          <span class="font-mono text-[10px] text-[#ff51fa]"></span>
        </div>
        <h1 class="text-3xl sm:text-5xl lg:text-6xl font-black uppercase tracking-tighter leading-tight overflow-visible mb-4 x-vibrating-text">{project.name}</h1>
        <p class="text-[#8eff71] font-mono text-sm italic mb-6">{project.tagline}</p>
        <p class="text-white/70 text-base sm:text-lg border-l-4 border-[#8eff71] pl-4">{project.description}</p>
      </header>

      <!-- Full Description -->
      <section class="prose-extreme storybook-prose mb-12 sm:mb-16 relative z-10" set:html={project.longDescription} />

      <!-- Tech Stack -->
      <section class="mb-10 sm:mb-12 relative z-10">
        <h2 class="font-mono text-[10px] text-white/30 tracking-[0.3em] uppercase mb-4">TECH_STACK</h2>
        <div class="flex flex-wrap gap-3">
          {project.stack.map(tech => (
            <span class="px-4 py-2 bg-black/50 border border-[#8eff71]/30 font-mono text-xs text-[#8eff71]">{tech}</span>
          ))}
        </div>
      </section>

      <!-- Links -->
      {(project.links.github || project.links.live) && (
        <section class="mb-12 sm:mb-16 relative z-10">
          <h2 class="font-mono text-[10px] text-white/30 tracking-[0.3em] uppercase mb-4">LINKS</h2>
          <div class="flex flex-wrap gap-4">
            {project.links.github && (
              <a href={project.links.github} target="_blank" rel="noopener" class="bg-[#8eff71] text-[#0d6100] px-8 py-4 font-black uppercase tracking-tighter hover:bg-white hover:text-black transition-all shadow-[0_0_20px_rgba(142,255,113,0.5)]">
                VIEW_SOURCE &gt;&gt;
              </a>
            )}
            {project.links.live && (
              <a href={project.links.live} target="_blank" rel="noopener" class="bg-[#ff51fa] text-white px-8 py-4 font-black uppercase tracking-tighter hover:bg-white hover:text-black transition-all shadow-[0_0_20px_rgba(255,81,250,0.5)]">
                OPEN_LIVE &gt;&gt;
              </a>
            )}
          </div>
        </section>
      )}

      <!-- Back -->
      <a href="/projects" class="inline-flex items-center gap-3 font-mono text-sm font-black text-white/40 hover:text-[#8eff71] transition-colors group relative z-10 px-4 py-3 border border-white/10 hover:border-[#8eff71]/40 active:scale-95" style="clip-path:polygon(0 5%,97% 0,100% 95%,3% 100%)">
        <span class="group-hover:-translate-x-2 transition-transform text-lg">&larr;</span> ALL PROJECTS
      </a>
    </main>
  </div>

</BaseLayout>

<style is:global>
  /* Project prose styles (same palette as blog) */
  .prose-dark h2, .prose-light h2, .prose-extreme h2,
  .prose-dark h3, .prose-light h3, .prose-extreme h3,
  .prose-dark p, .prose-light p, .prose-extreme p,
  .prose-dark ul, .prose-light ul, .prose-extreme ul,
  .prose-dark ul li, .prose-light ul li, .prose-extreme ul li,
  .prose-dark code, .prose-light code, .prose-extreme code,
  .prose-dark strong, .prose-light strong, .prose-extreme strong {
    /* Handled by blog/[slug].astro global styles */
  }

  /* ══════════════════════════════════════════
     STORYBOOK SCROLL ANIMATIONS
  ══════════════════════════════════════════ */

  /* JS adds .storybook-ready before hiding — safe fallback if JS fails */
  .storybook-ready p,
  .storybook-ready h2,
  .storybook-ready ul,
  .storybook-ready li {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.6s ease-out, transform 0.6s ease-out;
  }

  .storybook-ready p.sb-visible,
  .storybook-ready ul.sb-visible,
  .storybook-ready li.sb-visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* h2 heading border reveal */
  .storybook-prose h2 {
    border-left: 4px solid transparent;
    padding-left: 0.75rem;
    transition: opacity 0.6s ease-out, transform 0.6s ease-out, border-color 0.6s ease-out 0.2s;
  }
  .storybook-prose h2.sb-visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* Dark variant h2 border */
  .variant-dark .storybook-prose h2.sb-visible {
    border-left-color: #39FF14;
  }
  /* Light variant h2 border */
  .variant-light .storybook-prose h2.sb-visible {
    border-left-color: #FF51FA;
  }
  /* Extreme variant h2 border */
  .variant-extreme .storybook-prose h2.sb-visible {
    border-left-color: #8eff71;
  }

  /* Chapter tracker dots */
  #chapter-tracker .chapter-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: rgba(255,255,255,0.2);
    transition: all 0.3s ease;
    cursor: pointer;
  }
  #chapter-tracker .chapter-dot.active {
    width: 10px;
    height: 10px;
    background: #39FF14;
    box-shadow: 0 0 8px rgba(57,255,20,0.6);
  }

  /* Scroll progress bar — variant colors handled via JS,
     but we set extreme glow here */
  .variant-extreme ~ #scroll-progress,
  .variant-extreme #scroll-progress {
    box-shadow: 0 0 8px rgba(142,255,113,0.5);
  }

  @keyframes x-fractal-shift {
    0%   { background-position: 0% 0%;     filter: hue-rotate(0deg); }
    100% { background-position: 100% 100%; filter: hue-rotate(360deg); }
  }
  @keyframes vibrate-effect {
    0%   { transform: translate(0,0); }
    25%  { transform: translate(1px, -1px); }
    50%  { transform: translate(-1px, 1px); }
    75%  { transform: translate(1px, 1px); }
    100% { transform: translate(0,0); }
  }
  .x-vibrating-text { animation: psychedelic-melt 6s ease-in-out infinite; text-shadow: 3px 0 #ff51fa, -3px 0 #8eff71; }
  .x-fractal-bg {
    background-image: url(https://lh3.googleusercontent.com/aida-public/AB6AXuCCF-Wu0arOTEDRI7pEIgN9zoNVdLKE4WsdOdqmG-mtDHqHKeMqx_pBPtjbjQ4HLpooT9zBpJxFZIdyqmNhwaR3F5bS0VU9SZlVRdaD5SIIexczbDXVJLbC3fYM2lj-LBSQE8z_t1hhuH-YwO4BAU9o7bwkQAjqbW5Q1Lla1YTPzZjwno57NJKB4OVSqJNG42o5Uyn6rRNAztZgkm42__gqzmM9KOWda7YxxqhQfjXKC-JYyYqX7MWlCNskOFkjixU_RUmSdE3msqg);
    background-size: 200%; animation: x-fractal-shift 20s linear infinite;
    opacity: 0.2; mix-blend-mode: screen; position: fixed; top: 0; left: 0; width: 100%; height: 100%;
  }
  .x-glitch-hover { position: relative; }
</style>

<script>
  // ── Scroll progress bar ──
  const progressBar = document.getElementById('scroll-progress');
  function updateProgress() {
    const scrollTop = window.scrollY;
    const docHeight = document.documentElement.scrollHeight - window.innerHeight;
    if (docHeight > 0 && progressBar) {
      progressBar.style.width = (scrollTop / docHeight * 100) + '%';
    }
  }
  window.addEventListener('scroll', updateProgress, { passive: true });

  // ── Inject project gallery images into prose at start / middle / 3/4 ──
  const projectImages: string[] = JSON.parse(
    document.getElementById('project-images-data')?.dataset.images || '[]'
  );
  if (projectImages.length >= 2) {
    document.querySelectorAll('.storybook-prose').forEach(container => {
      const h2s = Array.from(container.querySelectorAll('h2'));
      const insertPoints = [
        container.firstChild,               // start: before everything
        h2s[Math.floor(h2s.length / 2)] || null,  // middle: mid h2
        h2s[Math.floor(h2s.length * 0.75)] || null, // 3/4: late h2
      ];
      const imgs = projectImages.slice(1); // skip hero (index 0), use extras
      insertPoints.forEach((point, idx) => {
        const src = imgs[idx];
        if (!src || !point) return;
        const figure = document.createElement('figure');
        figure.className = 'project-inline-img storybook-prose-img';
        figure.style.cssText = 'margin:2.5rem 0; overflow:visible;';

        const ACCENTS = ['#39FF14','#FF51FA','#AC89FF'];
        const ac = ACCENTS[idx % ACCENTS.length];

        const wrap = document.createElement('div');
        wrap.className = 'jag-img-wrap';
        wrap.style.cssText = 'height:340px;';

        const clip = document.createElement('div');
        clip.className = 'jag-img-clip';

        const img = document.createElement('img');
        img.src = src;
        img.alt = `Project image ${idx + 2}`;
        img.className = 'jag-img jag-loaded';

        const svgNS = 'http://www.w3.org/2000/svg';
        const svg = document.createElementNS(svgNS, 'svg');
        svg.setAttribute('class', 'jag-border');
        svg.setAttribute('viewBox', '0 0 100 100');
        svg.setAttribute('preserveAspectRatio', 'none');
        svg.setAttribute('aria-hidden', 'true');
        const outer = document.createElementNS(svgNS, 'polygon');
        outer.setAttribute('points', '2,0 14,6 25,0 38,5 52,0 65,3 80,0 92,4 100,2 98,16 100,32 97,48 100,64 98,80 100,95 94,100 80,97 65,100 48,96 32,100 18,98 0,96 3,82 0,65 4,48 0,32 2,16');
        outer.setAttribute('class', 'jag-stroke-outer');
        outer.setAttribute('style', `stroke:${ac}`);
        const inner = document.createElementNS(svgNS, 'polygon');
        inner.setAttribute('points', '4,2 16,8 27,2 40,7 54,2 67,5 82,2 94,6 98,4 96,18 98,34 95,50 98,66 96,82 98,97 92,98 78,95 63,98 46,94 30,98 16,96 2,94 5,80 2,63 6,46 2,30 4,18');
        inner.setAttribute('class', 'jag-stroke-inner');
        inner.setAttribute('style', `stroke:${ac}; animation-delay:${idx*0.3}s`);
        svg.appendChild(outer);
        svg.appendChild(inner);

        clip.appendChild(img);
        wrap.appendChild(clip);
        wrap.appendChild(svg);
        figure.appendChild(wrap);
        if (point === container.firstChild) {
          container.insertBefore(figure, container.firstChild);
        } else {
          (point as Element).parentNode?.insertBefore(figure, point as Element);
        }
      });
    });
  }

  // ── Storybook scroll reveal ──
  const proseContainers = document.querySelectorAll('.storybook-prose');
  proseContainers.forEach(container => {
    container.classList.add('storybook-ready'); // only hide when JS is running
    const elements = container.querySelectorAll('p, h2, ul, li');
    let delay = 0;
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const el = entry.target as HTMLElement;
          const stagger = parseInt(el.dataset.sbDelay || '0', 10);
          setTimeout(() => {
            el.classList.add('sb-visible');
          }, stagger);
          observer.unobserve(el);
        }
      });
    }, { threshold: 0.15 });

    let sectionDelay = 0;
    elements.forEach(el => {
      const htmlEl = el as HTMLElement;
      if (el.tagName === 'H2' || el.tagName === 'P' || el.tagName === 'UL') {
        htmlEl.dataset.sbDelay = String(sectionDelay);
        sectionDelay += 80;
      } else if (el.tagName === 'LI') {
        htmlEl.dataset.sbDelay = String(sectionDelay);
        sectionDelay += 40;
      }
      observer.observe(el);
    });
  });

  // ── Chapter tracker (right-side dots for h2 headings) ──
  const tracker = document.getElementById('chapter-tracker');
  const headings = document.querySelectorAll('.storybook-prose h2');
  if (tracker && headings.length > 0) {
    headings.forEach((h2, i) => {
      const dot = document.createElement('div');
      dot.className = 'chapter-dot';
      dot.title = h2.textContent || '';
      dot.addEventListener('click', () => {
        h2.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
      tracker.appendChild(dot);
    });

    const dots = tracker.querySelectorAll('.chapter-dot');
    const headingObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const idx = Array.from(headings).indexOf(entry.target);
          dots.forEach((d, i) => d.classList.toggle('active', i === idx));
        }
      });
    }, { threshold: 0.5, rootMargin: '-20% 0px -60% 0px' });

    headings.forEach(h2 => headingObserver.observe(h2));
  }
</script>
